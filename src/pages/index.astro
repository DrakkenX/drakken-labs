---
import Layout from '../layouts/Layout.astro';
import SentinelCompanion from '../components/SentinelCompanion.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Capabilities from '../components/Capabilities.astro';
import Showcase from '../components/Showcase.astro';
import Process from '../components/Process.astro';
import Investment from '../components/Investment.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <SentinelCompanion />
  <Nav />
  <main id="main-content">
    <Hero />
    <Manifesto />
    <Capabilities />
    <Showcase />
    <Process />
    <Investment />
    <Contact />
  </main>
  <Footer />
</Layout>
