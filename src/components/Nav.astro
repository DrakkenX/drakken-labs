---
const links = [
  { label: 'Work',       href: '#showcase' },
  { label: 'Services',   href: '#capabilities' },
  { label: 'Process',    href: '#process' },
  { label: 'Investment', href: '#investment' },
  { label: 'Contact',    href: '#contact' },
];
---

<header id="site-nav" role="banner">
  <nav aria-label="Main navigation">
    <a href="#hero" class="nav-wordmark font-cinzel" aria-label="Drakken Labs home">
      DRAKKEN
    </a>

    <ul class="nav-links" role="list">
      {links.map(({ label, href }) => (
        <li>
          <a href={href} data-nav-link class="nav-link font-inter">{label}</a>
        </li>
      ))}
    </ul>

    <a href="#contact" class="btn-primary nav-cta font-inter">
      Start a Project
      <span class="btn-arrow" aria-hidden="true">→</span>
    </a>

    <button
      class="nav-mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile-menu"
      id="nav-toggle"
    >
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="nav-mobile-menu" id="nav-mobile-menu" aria-hidden="true" hidden>
    <ul role="list">
      {links.map(({ label, href }) => (
        <li><a href={href} class="mobile-link font-inter">{label}</a></li>
      ))}
      <li>
        <a href="#contact" class="mobile-cta font-inter">
          Start a Project →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const menu   = document.getElementById('nav-mobile-menu') as HTMLElement | null;
  const nav    = document.getElementById('site-nav') as HTMLElement | null;

  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.classList.toggle('open', isOpen);
    if (menu) {
      menu.hidden = !isOpen;
      menu.setAttribute('aria-hidden', String(!isOpen));
    }
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      isOpen = false;
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('open');
      if (menu) { menu.hidden = true; menu.setAttribute('aria-hidden', 'true'); }
    });
  });

  // Scrolled state
  const SCROLL_THRESHOLD = 48;
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > SCROLL_THRESHOLD);
  }, { passive: true });
</script>

<style>
  header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-nav);
    transition:
      background var(--t-deliberate) var(--ease-out-expo),
      backdrop-filter var(--t-deliberate) var(--ease-out-expo),
      border-color var(--t-deliberate) var(--ease-out-expo);
    border-bottom: 1px solid transparent;
  }

  header.scrolled {
    background: rgba(3, 3, 8, 0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: var(--edge);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    height: 72px;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-wordmark {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    color: var(--text-pure);
    text-decoration: none;
    transition: color var(--t-base);
    flex-shrink: 0;
    margin-right: 0.5rem;
  }
  .nav-wordmark:hover { color: var(--signal-cyan); }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0;
    margin-left: auto;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.8rem;
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 4px;
    transition:
      color var(--t-quick) var(--ease-out-expo),
      background var(--t-quick) var(--ease-out-expo);
  }
  .nav-link:hover,
  .nav-link.nav-active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-cta {
    margin-left: 1rem;
    padding: 9px 20px;
    font-size: 0.78rem;
    flex-shrink: 0;
  }

  /* Mobile toggle */
  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
    width: 32px;
    height: 32px;
  }

  .toggle-bar {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--text-secondary);
    transition:
      transform var(--t-base) var(--ease-out-expo),
      opacity var(--t-base);
    transform-origin: center;
  }

  .nav-mobile-toggle.open .toggle-bar:first-child {
    transform: translateY(3px) rotate(45deg);
  }
  .nav-mobile-toggle.open .toggle-bar:last-child {
    transform: translateY(-3px) rotate(-45deg);
  }

  /* Mobile menu */
  .nav-mobile-menu {
    background: rgba(7, 8, 13, 0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 1.5rem 2rem 2rem;
    border-bottom: 1px solid var(--edge);
  }

  .nav-mobile-menu ul { list-style: none; }
  .nav-mobile-menu li + li { margin-top: 0; }

  .mobile-link {
    display: block;
    padding: 0.85rem 0;
    font-size: 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--edge);
    transition: color var(--t-quick);
  }
  .mobile-link:hover { color: var(--text-primary); }

  .mobile-cta {
    display: block;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--signal-cyan);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .nav-mobile-toggle { display: flex; }
  }
</style>
