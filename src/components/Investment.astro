---
import SectionAnchor from './SectionAnchor.astro';

const tiers = [
  {
    id: 'exploration',
    name: 'EXPLORATION',
    price: 'RM 1,500 – 3,000',
    timeline: '1 week',
    desc: 'Scoping engagement. Deep problem audit, architecture recommendation, and delivery roadmap. No obligation to continue.',
    features: [
      'Problem space mapping',
      'Tech stack recommendation',
      'Effort estimate ± 20%',
      'Risk identification',
      'Written architecture doc',
    ],
    signal: 'cyan',
    featured: false,
    badge: null,
  },
  {
    id: 'execution',
    name: 'EXECUTION',
    price: 'RM 5,000 – 15,000',
    timeline: '3–6 weeks',
    desc: 'Full project delivery. Production-grade code, thoughtful architecture, daily progress. This is the standard engagement.',
    features: [
      'Full-stack development',
      'Claude API integrations',
      'Premium UI engineering',
      'Documentation handoff',
      'Post-ship support (2 weeks)',
    ],
    signal: 'violet',
    featured: true,
    badge: 'MOST COMMON',
  },
  {
    id: 'command',
    name: 'COMMAND',
    price: 'RM 8,000+ / mo',
    timeline: 'Retainer',
    desc: 'Monthly engagement for teams that need a dedicated AI-native engineer. Priority access, continuous delivery.',
    features: [
      'Unlimited scope iterations',
      'Dedicated availability',
      'AI system architecture',
      'Native desktop apps (Tauri)',
      'Strategy + execution',
    ],
    signal: 'amber',
    featured: false,
    badge: null,
  },
];
---

<section id="investment" aria-labelledby="inv-heading">
  <!-- //05 Section anchor — absolute so it never disrupts the tier grid below -->
  <SectionAnchor number="05" label="Investment" class="sa-absolute" />

  <div class="section-inner">
    <div class="section-header reveal">
      <div class="section-label"><span>INVESTMENT</span></div>
      <h2 id="inv-heading" class="section-heading">What It Costs</h2>
      <p class="section-sub font-inter reveal" data-delay="80">
        Fixed scope. Fixed price. No retainers unless you want one.
      </p>
    </div>

    <div class="tiers-grid" data-stagger data-stagger-step="100">
      {tiers.map(({ name, price, timeline, desc, features, signal, featured, badge }) => (
        <article
          class={`sacred-frame accent-top tier-card stagger-child${featured ? ' tier-featured' : ''}`}
          data-signal={signal}
        >
          <span class="corner-tl"></span>
          <span class="corner-tr"></span>
          <span class="corner-bl"></span>
          <span class="corner-br"></span>

          {badge && (
            <div class="tier-badge font-mono">{badge}</div>
          )}

          <div class="tier-header">
            <h3 class="tier-name font-cinzel">{name}</h3>
            <div class="tier-price font-inter">{price}</div>
            <div class="tier-timeline font-mono">{timeline}</div>
          </div>

          <p class="tier-desc font-inter">{desc}</p>

          <ul class="tier-features" role="list">
            {features.map((f) => (
              <li class="font-inter">
                <span class="feat-mark" aria-hidden="true" style={`color:var(--signal-${signal})`}>◆</span>
                {f}
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={featured ? 'btn-primary font-inter tier-cta' : 'btn-ghost font-inter tier-cta'}
          >
            Begin conversation
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>

    <p class="inv-note font-inter reveal" data-delay="200">
      Not sure which fits?
      <a href="#contact">Let's talk</a> — I'll tell you honestly if a simpler solution works.
    </p>
  </div>
</section>

<style>
  section {
    padding: 8rem 2rem;
    background: var(--deep);
    z-index: var(--z-page);
    position: relative;
  }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-header { margin-bottom: 3.5rem; }
  .section-sub { font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.75rem; }

  /* ── GRID ────────────────────────────────────────────── */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--edge);
    border: 1px solid var(--edge);
    margin-bottom: 2.5rem;
  }

  .tier-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--mid);
    border: none;
    border-radius: 0;
    position: relative;
    min-height: 520px;
  }

  .tier-featured {
    background: var(--rise);
  }

  /* Signal top-edge accent lines */
  .tier-card[data-signal="cyan"]::before   { background: rgba(0,212,255,0.45);   }
  .tier-card[data-signal="violet"]::before { background: rgba(167,139,250,0.55); }
  .tier-card[data-signal="amber"]::before  { background: rgba(251,191,36,0.45);  }

  /* Corner tick colors per signal */
  .tier-card[data-signal="cyan"]   .corner-tl,
  .tier-card[data-signal="cyan"]   .corner-tr,
  .tier-card[data-signal="cyan"]   .corner-bl,
  .tier-card[data-signal="cyan"]   .corner-br { border-color: var(--signal-cyan);   }
  .tier-card[data-signal="violet"] .corner-tl,
  .tier-card[data-signal="violet"] .corner-tr,
  .tier-card[data-signal="violet"] .corner-bl,
  .tier-card[data-signal="violet"] .corner-br { border-color: var(--signal-violet); }
  .tier-card[data-signal="amber"]  .corner-tl,
  .tier-card[data-signal="amber"]  .corner-tr,
  .tier-card[data-signal="amber"]  .corner-bl,
  .tier-card[data-signal="amber"]  .corner-br { border-color: var(--signal-amber);  }

  /* Badge */
  .tier-badge {
    position: absolute;
    top: -1px;
    right: 1.5rem;
    font-size: 0.52rem;
    letter-spacing: 0.2em;
    color: var(--signal-violet);
    background: var(--mid);
    padding: 0.2rem 0.65rem;
    border: 1px solid rgba(167,139,250,0.3);
    border-top: 2px solid var(--signal-violet);
  }
  .tier-featured .tier-badge { background: var(--rise); }

  .tier-header { display: flex; flex-direction: column; gap: 0.3rem; }

  .tier-name {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--text-pure);
  }

  .tier-price {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .tier-timeline {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
  }

  .tier-desc {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-secondary);
    flex-grow: 1;
  }

  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .tier-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .feat-mark {
    font-size: 0.42rem;
    margin-top: 0.38rem;
    flex-shrink: 0;
  }

  .tier-cta {
    margin-top: auto;
    width: 100%;
    justify-content: center;
  }

  /* Note */
  .inv-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }
  .inv-note a {
    color: var(--signal-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--t-quick);
  }
  .inv-note a:hover { border-bottom-color: var(--signal-cyan); }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .tiers-grid { grid-template-columns: 1fr; }
    .tier-featured { order: -1; }
    .tier-card { min-height: auto; }
  }
</style>
