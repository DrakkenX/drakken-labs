---
// Fires once per session (sessionStorage flag 'drakken-entered').
// Duration: ~3.2s total, then curtain-split reveal.
---

<div id="cinematic-loader" aria-hidden="true" role="presentation">
  <!-- Video background — blurred celestial drift -->
  <video
    class="loader-video"
    src="/media/loader-bg.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-hidden="true"
  ></video>

  <!-- Film grain on loader -->
  <div class="loader-grain" aria-hidden="true"></div>

  <!-- Viewport corner ticks -->
  <div class="loader-corner tl" aria-hidden="true"></div>
  <div class="loader-corner tr" aria-hidden="true"></div>
  <div class="loader-corner bl" aria-hidden="true"></div>
  <div class="loader-corner br" aria-hidden="true"></div>

  <!-- Center content -->
  <div class="loader-center">
    <p class="loader-label font-cinzel">[ INITIALIZING ]</p>

    <div class="loader-counter-wrap">
      <span class="loader-counter font-mono" id="loader-counter">0</span>
      <span class="loader-percent font-mono">%</span>
    </div>

    <div class="loader-progress-bar">
      <div class="loader-progress-fill" id="loader-progress-fill"></div>
    </div>

    <p class="loader-status font-cinzel" id="loader-status">Loading content...</p>
  </div>

  <!-- Curtain halves — split on exit -->
  <div class="loader-curtain-top" id="loader-curtain-top"></div>
  <div class="loader-curtain-bottom" id="loader-curtain-bottom"></div>
</div>

<script>
  (() => {
    const STORAGE_KEY = 'drakken-entered';
    const loader = document.getElementById('cinematic-loader');
    if (!loader) return;

    // Skip on repeat visits
    if (sessionStorage.getItem(STORAGE_KEY)) {
      loader.style.display = 'none';
      return;
    }

    // Block body scroll
    document.body.style.overflow = 'hidden';

    const counter    = document.getElementById('loader-counter') as HTMLElement;
    const fill       = document.getElementById('loader-progress-fill') as HTMLElement;
    const statusEl   = document.getElementById('loader-status') as HTMLElement;
    const curtainTop = document.getElementById('loader-curtain-top') as HTMLElement;
    const curtainBot = document.getElementById('loader-curtain-bottom') as HTMLElement;

    const STATUSES = [
      'Loading content...',
      'Calibrating Sentinel...',
      'Initializing 3D scene...',
      'Establishing connection...',
      'Ready to explore',
    ];

    // Animate corners in
    const corners = loader.querySelectorAll<HTMLElement>('.loader-corner');
    corners.forEach((c, i) => {
      setTimeout(() => c.classList.add('visible'), i * 60);
    });

    // easeOutExpo
    function ease(x: number): number {
      return x === 1 ? 1 : 1 - Math.pow(2, -10 * x);
    }

    // Reduced motion: just static hold then exit
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) {
      if (counter) counter.textContent = '100';
      if (fill) fill.style.width = '100%';
      if (statusEl) statusEl.textContent = 'Ready to explore';
      setTimeout(() => exitLoader(), 800);
      return;
    }

    // Counter animation — 2.4s
    const DURATION = 2400;
    const start = performance.now();
    let lastStatus = -1;

    function tick(now: number) {
      const progress = Math.min((now - start) / DURATION, 1);
      const eased    = ease(progress);
      const value    = Math.round(eased * 100);

      if (counter) counter.textContent = String(value);
      if (fill) fill.style.width = value + '%';

      // Status updates at ~20% intervals
      const statusIndex = Math.min(Math.floor(eased * STATUSES.length), STATUSES.length - 1);
      if (statusIndex !== lastStatus && statusEl) {
        statusEl.classList.add('fade-out');
        setTimeout(() => {
          if (statusEl) {
            statusEl.textContent = STATUSES[statusIndex] ?? '';
            statusEl.classList.remove('fade-out');
          }
        }, 120);
        lastStatus = statusIndex;
      }

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        // Hold 200ms then exit
        setTimeout(() => exitLoader(), 200);
      }
    }

    requestAnimationFrame(tick);

    function exitLoader() {
      if (!loader || !curtainTop || !curtainBot) return;

      // Fade counter area
      const center = loader.querySelector<HTMLElement>('.loader-center');
      if (center) {
        center.style.transition = 'opacity 300ms ease, transform 300ms ease';
        center.style.opacity = '0';
        center.style.transform = 'scale(1.05)';
      }

      // After brief fade, split curtains
      setTimeout(() => {
        curtainTop.classList.add('exit');
        curtainBot.classList.add('exit');

        // Remove loader after animation
        setTimeout(() => {
          loader.style.display = 'none';
          document.body.style.overflow = '';
          sessionStorage.setItem(STORAGE_KEY, '1');
        }, 650);
      }, 280);
    }
  })();
</script>

<style>
  #cinematic-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #030308;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── VIDEO BG ────────────────────────────────────────── */
  .loader-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
    filter: blur(12px) brightness(0.6);
    pointer-events: none;
  }

  /* ── GRAIN ───────────────────────────────────────────── */
  .loader-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.05;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* ── CORNER TICKS ────────────────────────────────────── */
  .loader-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: rgba(0, 212, 255, 0.6);
    border-style: solid;
    opacity: 0;
    transition: opacity 300ms ease;
    z-index: 2;
  }
  .loader-corner.tl { top: 20px;    left: 20px;   border-width: 1.5px 0 0 1.5px; }
  .loader-corner.tr { top: 20px;    right: 20px;  border-width: 1.5px 1.5px 0 0; }
  .loader-corner.bl { bottom: 20px; left: 20px;   border-width: 0 0 1.5px 1.5px; }
  .loader-corner.br { bottom: 20px; right: 20px;  border-width: 0 1.5px 1.5px 0; }
  .loader-corner.visible { opacity: 1; }

  /* ── CENTER CONTENT ──────────────────────────────────── */
  .loader-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .loader-label {
    font-size: 0.6875rem;
    letter-spacing: 0.28em;
    color: #00d4ff;
    font-variant: small-caps;
    opacity: 0.9;
  }

  .loader-counter-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    line-height: 1;
  }

  .loader-counter {
    font-size: clamp(4rem, 12vw, 6rem);
    font-weight: 400;
    color: #ffffff;
    font-variant-numeric: tabular-nums;
    min-width: 3ch;
    text-align: right;
    line-height: 1;
  }

  .loader-percent {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
  }

  /* Progress bar */
  .loader-progress-bar {
    width: 280px;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .loader-progress-fill {
    height: 100%;
    width: 0%;
    background: #00d4ff;
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.6);
    transition: width 0ms linear; /* instant — controlled by JS */
  }

  /* Status label */
  .loader-status {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.45);
    font-variant: small-caps;
    transition: opacity 120ms ease;
    height: 1.2em;
  }
  .loader-status.fade-out { opacity: 0; }

  /* ── CURTAINS ────────────────────────────────────────── */
  .loader-curtain-top,
  .loader-curtain-bottom {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    background: #030308;
    z-index: 3;
    transition: transform 600ms cubic-bezier(0.77, 0, 0.175, 1);
  }

  .loader-curtain-top    { top: 0; }
  .loader-curtain-bottom { bottom: 0; }

  .loader-curtain-top.exit    { transform: translateY(-100%); }
  .loader-curtain-bottom.exit { transform: translateY(100%); }

  /* ── REDUCED MOTION ──────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .loader-video { display: none; }
  }
</style>
