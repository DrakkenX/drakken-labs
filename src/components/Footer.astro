---
const navLinks = [
  { label: 'Manifesto',    href: '#manifesto' },
  { label: 'Capabilities', href: '#capabilities' },
  { label: 'Showcase',     href: '#showcase' },
  { label: 'Process',      href: '#process' },
  { label: 'Contact',      href: '#contact' },
];

const channels = [
  { label: 'X / TWITTER', href: 'https://x.com' },
  { label: 'LINKEDIN',     href: 'https://linkedin.com' },
  { label: 'GITHUB',       href: 'https://github.com/DrakkenX' },
];
---

<footer aria-label="Site footer">

  <!-- ROW 1: Top gradient divider -->
  <div class="footer-divider" aria-hidden="true"></div>

  <!-- ROW 2: Main footer — 3 columns -->
  <div class="footer-inner reveal">

    <!-- Identity -->
    <div class="footer-brand">
      <a href="#hero" class="footer-wordmark font-cinzel" aria-label="Drakken Labs — back to top">
        DRAKKEN
      </a>
      <p class="footer-studio font-mono">AI-NATIVE SOFTWARE STUDIO</p>
      <p class="footer-founder footer-italic">Han Myo Naing, Founder</p>
    </div>

    <!-- Navigation -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul role="list">
        {navLinks.map(({ label, href }) => (
          <li>
            <a href={href} class="footer-nav-link font-cinzel">{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Channels -->
    <div class="footer-channels">
      <span class="footer-channels-label font-mono">[ CHANNELS ]</span>
      <ul role="list">
        {channels.map(({ label, href }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-channel-link"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- ROW 3: Bottom sign-off -->
  <div class="footer-bottom">
    <span class="footer-copy font-mono">
      &copy; 2025 DRAKKEN LABS · OPERATING SINCE MMXXV
    </span>

    <div class="footer-location">
      <div class="location-mark" aria-hidden="true">
        <span class="mark-dot"></span>
        <span class="mark-line"></span>
        <span class="mark-dot"></span>
      </div>
      <span class="footer-built font-mono">BUILT IN MALAYSIA</span>
    </div>
  </div>

  <!-- Bottom gradient line — mirrors top divider, closes the footer -->
  <div class="footer-divider-bottom" aria-hidden="true"></div>

</footer>

<style>
  footer {
    background: var(--void);
    position: relative;
    z-index: var(--z-page);
  }

  /* ── ROW 1: Divider ────────────────────────────────────── */
  .footer-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(0,212,255,0.3) 30%,
      rgba(0,212,255,0.3) 70%,
      transparent
    );
    margin-top: 0;
  }

  /* ── ROW 2: Main footer ────────────────────────────────── */
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 2rem 2.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Identity */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-wordmark {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--text-pure);
    text-decoration: none;
    transition: color 200ms ease;
    display: inline-block;
    line-height: 1;
  }
  .footer-wordmark:hover { color: var(--signal-cyan); }

  .footer-studio {
    font-size: 0.5625rem;
    letter-spacing: 0.32em;
    color: rgba(0,212,255,0.6);
    margin-top: 0.1rem;
  }

  .footer-founder {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.45);
    margin-top: 0.25rem;
  }
  .footer-italic {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
  }

  /* Navigation */
  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0;
    margin: 0;
  }

  .footer-nav-link {
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-variant: small-caps;
    transition: color 180ms ease;
  }
  .footer-nav-link:hover { color: var(--signal-cyan); }

  /* Channels */
  .footer-channels {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-channels-label {
    font-size: 0.5625rem;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.35);
  }

  .footer-channels ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .footer-channel-link {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 180ms ease;
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
  }
  .footer-channel-link:hover { color: var(--signal-cyan); }

  /* ── ROW 3: Bottom sign-off ────────────────────────────── */
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.05);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.5625rem;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.35);
  }

  .footer-location {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Dot-line-dot mark */
  .location-mark {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .mark-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    opacity: 0.55;
    flex-shrink: 0;
  }
  .mark-line {
    width: 20px;
    height: 1px;
    background: var(--signal-cyan);
    opacity: 0.35;
    flex-shrink: 0;
  }

  .footer-built {
    font-size: 0.5625rem;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.35);
  }

  /* ── BOTTOM DIVIDER ───────────────────────────────────── */
  .footer-divider-bottom {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(0, 212, 255, 0.15) 30%,
      rgba(0, 212, 255, 0.15) 70%,
      transparent
    );
  }

  /* ── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 2.5rem;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
