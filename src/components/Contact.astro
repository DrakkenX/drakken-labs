---
---

<section id="contact" aria-labelledby="contact-heading">
  <!-- Violet ambient glow — Sentinel is central here -->
  <div class="contact-glow" aria-hidden="true"></div>

  <div class="section-inner">

    <!-- Left — identity -->
    <div class="contact-left reveal">
      <div class="section-label"><span>ESTABLISH CONTACT</span></div>

      <h2 id="contact-heading" class="contact-heading font-cinzel">
        Begin the work.
      </h2>

      <p class="contact-sub font-inter">
        Initial contact within 24 hours.<br />
        Replies are personal, written by Han.
      </p>

      <div class="contact-meta">
        <div class="meta-row">
          <span class="meta-label font-mono">DIRECT</span>
          <a href="mailto:drakken.diablo@gmail.com" class="meta-value font-mono">
            drakken.diablo@gmail.com
          </a>
        </div>
        <div class="meta-row">
          <span class="meta-label font-mono">HOURS</span>
          <span class="meta-value font-mono">GMT+8 · 09:00–22:00 Mon–Sat</span>
        </div>
        <div class="meta-row">
          <span class="meta-label font-mono">LOCATION</span>
          <span class="meta-value font-mono">Putra Heights, Malaysia</span>
        </div>
        <div class="meta-row">
          <span class="meta-label font-mono">STATUS</span>
          <span class="meta-value font-mono" style="color:var(--signal-mint)">
            <span class="status-dot"></span>
            Available — 2 slots open
          </span>
        </div>
      </div>
    </div>

    <!-- Right — form -->
    <div class="contact-right reveal" data-delay="120">
      <form id="contact-form" class="contact-form" novalidate>

        <div class="form-row">
          <div class="form-field">
            <label for="cf-name" class="form-label font-mono">NAME</label>
            <input
              type="text"
              id="cf-name"
              name="name"
              class="form-input font-inter"
              placeholder="Han Myo Naing"
              required
              autocomplete="name"
            />
          </div>
          <div class="form-field">
            <label for="cf-email" class="form-label font-mono">EMAIL</label>
            <input
              type="email"
              id="cf-email"
              name="email"
              class="form-input font-inter"
              placeholder="you@company.com"
              required
              autocomplete="email"
            />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="cf-type" class="form-label font-mono">PROJECT TYPE</label>
            <div class="form-select-wrap">
              <select id="cf-type" name="type" class="form-select font-inter" required>
                <option value="" disabled selected>Select a tier…</option>
                <option value="exploration">Exploration — RM 1,500–3,000</option>
                <option value="execution">Execution — RM 5,000–15,000</option>
                <option value="command">Command — RM 8,000+ / mo</option>
                <option value="exploring">Just exploring</option>
              </select>
              <span class="select-chevron" aria-hidden="true">↓</span>
            </div>
          </div>
          <div class="form-field">
            <label for="cf-budget" class="form-label font-mono">BUDGET RANGE</label>
            <div class="form-select-wrap">
              <select id="cf-budget" name="budget" class="form-select font-inter">
                <option value="" disabled selected>Approximate budget…</option>
                <option value="lt3k">Under RM 3,000</option>
                <option value="3-8k">RM 3,000 – 8,000</option>
                <option value="8-20k">RM 8,000 – 20,000</option>
                <option value="gt20k">RM 20,000+</option>
              </select>
              <span class="select-chevron" aria-hidden="true">↓</span>
            </div>
          </div>
        </div>

        <div class="form-field">
          <label for="cf-message" class="form-label font-mono">TELL ME ABOUT IT</label>
          <textarea
            id="cf-message"
            name="message"
            class="form-textarea font-inter"
            placeholder="Describe your project, the problem it solves, and your timeline…"
            rows="5"
            required
          ></textarea>
        </div>

        <div class="form-footer">
          <button type="submit" id="cf-submit" class="btn-primary font-inter submit-btn">
            <span id="btn-text">Send transmission</span>
            <span class="btn-arrow" aria-hidden="true" id="btn-arrow">→</span>
          </button>
          <p class="form-note font-mono">No spam. Direct reply, not a template.</p>
        </div>

        <!-- States -->
        <div id="form-success" class="form-success font-inter" hidden>
          <span class="success-glyph" aria-hidden="true">◆</span>
          Transmission received. Expect a reply within 24 hours.
        </div>
        <div id="form-error" class="form-error font-inter" hidden>
          Something failed. Email directly: drakken.diablo@gmail.com
        </div>

      </form>
    </div>

  </div>
</section>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement | null;
  const btnText  = document.getElementById('btn-text') as HTMLElement | null;
  const btnArrow = document.getElementById('btn-arrow') as HTMLElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('form-success') as HTMLElement | null;
  const errorEl   = document.getElementById('form-error') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !btnText || !form.checkValidity()) {
      form?.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    btnText.textContent = 'Sending…';
    if (btnArrow) btnArrow.style.opacity = '0.3';

    try {
      const res = await fetch('https://formspree.io/f/xwvzpeny', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        if (successEl) successEl.hidden = false;
        if (errorEl) errorEl.hidden = true;
        if (btnText) btnText.textContent = 'Sent ✓';
        document.dispatchEvent(new CustomEvent('sentinel:success'));
      } else {
        throw new Error('non-ok');
      }
    } catch {
      if (errorEl) errorEl.hidden = false;
      if (successEl) successEl.hidden = true;
      if (btnText) btnText.textContent = 'Send transmission';
      if (btnArrow) btnArrow.style.opacity = '1';
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  section {
    padding: 8rem 2rem;
    background: var(--void);
    position: relative;
    overflow: hidden;
    z-index: var(--z-page);
  }

  .contact-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -100px;
    right: -100px;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
    animation: cGlow 20s ease-in-out infinite;
  }

  @keyframes cGlow {
    0%,100% { transform: scale(1) translate(0,0); }
    50%      { transform: scale(1.08) translate(-3%,5%); }
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── LEFT ────────────────────────────────────────────── */
  .contact-left { display: flex; flex-direction: column; gap: 2rem; }

  .contact-heading {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--text-pure);
    font-style: italic;
    line-height: 1.2;
  }

  .contact-sub {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .contact-meta { display: flex; flex-direction: column; gap: 0; }

  .meta-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--edge);
  }

  .meta-label {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--text-ghost);
  }

  .meta-value {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--t-quick);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  a.meta-value:hover { color: var(--signal-cyan); }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--signal-mint);
    animation: dotBlink 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes dotBlink {
    0%,100% { opacity: 1; }
    50%      { opacity: 0.2; }
  }

  /* ── FORM ────────────────────────────────────────────── */
  .contact-form { display: flex; flex-direction: column; gap: 1.75rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-field { display: flex; flex-direction: column; gap: 0.5rem; }

  .form-label {
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: var(--text-ghost);
    text-transform: uppercase;
  }

  .form-input,
  .form-textarea,
  .form-select {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--edge);
    color: var(--text-primary);
    font-size: 0.9rem;
    padding: 0.6rem 0;
    width: 100%;
    outline: none;
    transition: border-color var(--t-base) var(--ease-out-expo);
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-input::placeholder,
  .form-textarea::placeholder { color: var(--text-ghost); }

  .form-input:focus,
  .form-textarea:focus,
  .form-select:focus {
    border-bottom: 2px solid var(--signal-cyan);
    padding-bottom: calc(0.6rem - 1px);
  }

  .form-select-wrap {
    position: relative;
  }

  .select-chevron {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-ghost);
    font-size: 0.7rem;
    pointer-events: none;
  }

  .form-select option { background: var(--mid); color: var(--text-primary); }

  .form-textarea { resize: vertical; min-height: 100px; line-height: 1.65; }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .submit-btn { flex-shrink: 0; }

  .form-note {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    color: var(--text-ghost);
  }

  /* States */
  .form-success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(74,222,128,0.06);
    border: 1px solid rgba(74,222,128,0.2);
    color: var(--signal-mint);
    font-size: 0.875rem;
  }
  .success-glyph { font-size: 0.5rem; flex-shrink: 0; }

  .form-error {
    padding: 1rem;
    background: rgba(239,68,68,0.06);
    border: 1px solid rgba(239,68,68,0.2);
    color: var(--signal-blood);
    font-size: 0.875rem;
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .section-inner { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 520px) {
    .form-row { grid-template-columns: 1fr; gap: 1.25rem; }
    .form-footer { flex-direction: column; align-items: stretch; }
    .submit-btn { width: 100%; justify-content: center; }
  }
</style>
