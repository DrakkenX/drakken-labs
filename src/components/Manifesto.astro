---
import SectionAnchor from './SectionAnchor.astro';

// 12 ambient particles — scattered across section bounds
const particles: Array<{x:string;y:string;size:number;opacity:number;dur:number;delay:number;dx:number;dy:number}> = [
  { x:'8%',  y:'18%', size:3, opacity:0.35, dur:13, delay:0,  dx:12,  dy:-10 },
  { x:'22%', y:'62%', size:2, opacity:0.28, dur:16, delay:2,  dx:-8,  dy:14  },
  { x:'42%', y:'12%', size:3, opacity:0.38, dur:11, delay:4,  dx:10,  dy:8   },
  { x:'68%', y:'38%', size:2, opacity:0.30, dur:14, delay:1,  dx:-14, dy:-8  },
  { x:'83%', y:'72%', size:3, opacity:0.25, dur:17, delay:3,  dx:8,   dy:-12 },
  { x:'12%', y:'82%', size:2, opacity:0.32, dur:12, delay:5,  dx:-10, dy:-6  },
  { x:'55%', y:'52%', size:3, opacity:0.27, dur:15, delay:2,  dx:6,   dy:10  },
  { x:'88%', y:'22%', size:2, opacity:0.25, dur:10, delay:6,  dx:-8,  dy:14  },
  { x:'34%', y:'88%', size:3, opacity:0.32, dur:13, delay:1,  dx:14,  dy:-8  },
  { x:'76%', y:'8%',  size:2, opacity:0.28, dur:16, delay:4,  dx:-6,  dy:12  },
  { x:'60%', y:'68%', size:3, opacity:0.25, dur:12, delay:3,  dx:10,  dy:-10 },
  { x:'4%',  y:'44%', size:2, opacity:0.36, dur:14, delay:0,  dx:-12, dy:8   },
];
---

<section id="manifesto" aria-labelledby="manifesto-heading">

  <!-- ── Cosmic texture background ──────────────────────────── -->
  <div class="m-bg" aria-hidden="true">
    <img
      id="m-bg-img"
      src="/media/texture-1.jpg"
      alt=""
      class="m-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="m-bg-vignette"></div>
    <div class="m-bg-tint"></div>
  </div>

  <!-- Ambient cyan glow -->
  <div class="m-glow" aria-hidden="true"></div>

  <!-- 12 ambient floating particles -->
  <div class="m-particles" aria-hidden="true">
    {particles.map((p, i) => (
      <div
        class={`particle particle-${i}`}
        style={`left:${p.x};top:${p.y};width:${p.size}px;height:${p.size}px;opacity:${p.opacity};--dur:${p.dur}s;--delay:-${p.delay}s;--dx:${p.dx}px;--dy:${p.dy}px`}
      ></div>
    ))}
  </div>

  <!-- ── Main layout wrapper ─────────────────────────────────── -->
  <div class="m-layout">

    <!-- //01 Section anchor — full-width above the column split -->
    <SectionAnchor number="01" label="Manifesto" />

    <!-- Two-column main area: 40% left metadata / 60% right editorial -->
    <div class="m-columns" id="manifesto-inner">

      <!-- ══ LEFT COLUMN: Sticky metadata (40%) ══════════════ -->
      <div class="m-left">

        <!-- BLOCK A: OPERATING -->
        <div class="meta-block" data-mb>
          <span class="meta-label">[ OPERATING ]</span>
          <p class="meta-value">Putra Heights, Selangor</p>
          <p class="meta-sub font-mono">GMT+8 · 09:00 — 22:00</p>
        </div>

        <!-- BLOCK B: DOCTRINE STATS (absorbs former HeroStats content) -->
        <div class="meta-block" data-mb>
          <span class="meta-label">[ DOCTRINE ]</span>
          <div class="doctrine-grid">
            <span class="dg-key font-cinzel">INTENTION</span>
            <span class="dg-val">8,959 lines / 5 days</span>
            <span class="dg-key font-cinzel">VELOCITY</span>
            <span class="dg-val">5–10× output velocity</span>
            <span class="dg-key font-cinzel">CRAFT</span>
            <span class="dg-val">60 fps · 0 errors</span>
            <span class="dg-key font-cinzel">PURPOSE</span>
            <span class="dg-val">Built to defend</span>
          </div>
        </div>

        <!-- BLOCK C: STATUS -->
        <div class="meta-block" data-mb>
          <span class="meta-label">[ STATUS ]</span>
          <p class="meta-value meta-mint">Accepting work</p>
          <p class="meta-sub font-mono">Q3 2025 calendar</p>
        </div>

        <!-- BLOCK D: DIRECT -->
        <div class="meta-block" data-mb>
          <span class="meta-label">[ DIRECT ]</span>
          <a href="mailto:hello@drakkenlabs.com" class="meta-value meta-email">
            hello@drakkenlabs.com
          </a>
          <p class="meta-sub font-mono">≤ 24 HOUR RESPONSE</p>
        </div>

        <!-- BLOCK E: VERSION META -->
        <div class="meta-block" data-mb>
          <span class="meta-label">[ DRAKKEN LABS · v1.0 ]</span>
          <p class="meta-sub font-mono">MMXXV — ESTABLISHED</p>
          <p class="meta-italic">Studio of one. Output of three.</p>
        </div>

      </div>

      <!-- ══ RIGHT COLUMN: Editorial content (60%) ════════════ -->
      <div class="m-right">

        <!-- Small subtitle above heading -->
        <p class="mr-subtitle font-mono">WHAT WE BELIEVE</p>

        <!-- PRIMARY HEADING — Hashgraph two-headline pattern -->
        <!-- Three lines: Cinzel / Cinzel+Instrument-italic / Cinzel -->
        <h2 id="manifesto-heading" class="mr-heading">
          <span class="mh-line font-cinzel">We build</span>
          <span class="mh-line">
            <span class="font-cinzel">what </span><span class="mh-italic">shouldn't</span>
          </span>
          <span class="mh-line font-cinzel">exist yet.</span>
        </h2>

        <!-- Structural divider — draws from center on reveal -->
        <div class="mr-divider" aria-hidden="true"></div>

        <!-- THREE DECLARATIONS -->
        <div class="mr-declarations">

          <div class="decl">
            <span class="decl-numeral mh-italic" aria-hidden="true">I.</span>
            <div class="decl-body">
              <p class="decl-label font-cinzel">SOFTWARE AS CEREMONY</p>
              <p class="decl-text">
                Code as craft. Every line considered. Every commit deliberate.
                We treat software as architecture: built to last, designed to be read.
              </p>
            </div>
          </div>

          <div class="decl">
            <span class="decl-numeral mh-italic" aria-hidden="true">II.</span>
            <div class="decl-body">
              <p class="decl-label font-cinzel">AI AS CREATIVE PARTNER</p>
              <p class="decl-text">
                Not replacement. Not autopilot. Claude writes the boilerplate so we
                can focus on the architecture decisions, the taste calls, the error
                states that actually matter.
              </p>
            </div>
          </div>

          <div class="decl">
            <span class="decl-numeral mh-italic" aria-hidden="true">III.</span>
            <div class="decl-body">
              <p class="decl-label font-cinzel">QUALITY COMPOUNDS</p>
              <p class="decl-text">
                Speed multiplies. Decisions stack. The future belongs to those
                who build with intention — and ship before consensus.
              </p>
            </div>
          </div>

        </div>

        <!-- SIGNOFF -->
        <div class="mr-signoff">
          <div class="signoff-line" aria-hidden="true"></div>
          <p class="signoff-mark mh-italic">— DRAKKEN</p>
          <p class="signoff-name font-mono">Han Myo Naing, Founder · MMXXV</p>
        </div>

      </div>
      <!-- /m-right -->

    </div>
    <!-- /m-columns -->

  </div>
  <!-- /m-layout -->

</section>

<script>
  (() => {
    const section = document.getElementById('manifesto');
    if (!section) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Snap everything to final state — no animations
    if (prefersReduced) {
      section.classList.add('is-revealed');
      section.querySelectorAll<HTMLElement>('[data-mb]').forEach((b) =>
        b.classList.add('mb-visible')
      );
      return;
    }

    // ── Right-column reveal: one-shot when section enters view ──
    const revealObs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          section.classList.add('is-revealed');
          revealObs.disconnect();
        }
      },
      { threshold: 0.25 }
    );
    revealObs.observe(section);

    // ── Left-column metadata: per-block observer (threshold 0.4) ─
    // Each block triggers individually as user scrolls through.
    // nth-child stagger in CSS adds 100ms between blocks.
    const blockObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('mb-visible');
            blockObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.4 }
    );
    section.querySelectorAll<HTMLElement>('[data-mb]').forEach((b) =>
      blockObs.observe(b)
    );

    // ── Background parallax — 0.25× scroll speed, desktop only ──
    if (!window.matchMedia('(max-width: 768px)').matches) {
      const loadParallax = async () => {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);

        const bgImg = document.getElementById('m-bg-img');
        if (!bgImg) return;

        gsap.to(bgImg, {
          yPercent: -25,
          ease: 'none',
          scrollTrigger: {
            trigger: '#manifesto',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      };

      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(loadParallax, { timeout: 3000 });
      } else {
        setTimeout(loadParallax, 600);
      }
    }
  })();
</script>

<style>
  /* ── FONT UTILITIES (local — used only in this component) ── */
  .font-cinzel        { font-family: 'Cinzel', Georgia, serif; }
  .mh-italic          {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
  }

  /* ── SECTION SHELL ──────────────────────────────────────── */
  section {
    position: relative;
    padding: 7.5rem 2rem 8rem;
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ── BACKGROUND ─────────────────────────────────────────── */
  .m-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .m-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.3) saturate(0.7) blur(0.5px);
    will-change: transform;
  }

  .m-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 10%, #030308 85%);
  }

  .m-bg-tint {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 212, 255, 0.012);
  }

  .m-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -80px;
    left: 15%;
    background: radial-gradient(ellipse at center, rgba(167,139,250,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    animation: mGlow 18s ease-in-out infinite;
  }
  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0,   0);  }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  /* ── PARTICLES ──────────────────────────────────────────── */
  .m-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--signal-cyan);
    box-shadow: 0 0 4px rgba(0, 212, 255, 0.5);
    animation: particleDrift var(--dur, 13s) ease-in-out var(--delay, 0s) infinite alternate;
  }

  @keyframes particleDrift {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(calc(var(--dx) * 0.6), calc(var(--dy) * -0.4)); }
    50%  { transform: translate(var(--dx), var(--dy)); }
    75%  { transform: translate(calc(var(--dx) * 0.3), calc(var(--dy) * 0.8)); }
    100% { transform: translate(0, 0); }
  }

  /* ── PAGE LAYOUT ────────────────────────────────────────── */
  .m-layout {
    position: relative;
    z-index: 4;
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  /* Two-column grid: 2fr (≈40%) left + 3fr (≈60%) right */
  .m-columns {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 0 5rem;
    position: relative;
  }

  /* Vertical structural spine at the gutter — subtle anchor */
  .m-columns::before {
    content: '';
    position: absolute;
    /* sits at the approximate column boundary */
    left: calc(40% + 0.5rem);
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(0, 212, 255, 0.15);
    pointer-events: none;
  }

  /* ── LEFT COLUMN: Sticky metadata ───────────────────────── */
  .m-left {
    position: sticky;
    top: 120px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-top: 0.25rem;
  }

  /* ── METADATA BLOCKS ───────────────────────────────────── */
  .meta-block {
    position: relative;
    padding-left: 14px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    /* Entry animation — triggered when each block enters viewport */
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 500ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 100ms stagger between meta blocks */
  .m-left .meta-block:nth-child(1) { transition-delay:   0ms; }
  .m-left .meta-block:nth-child(2) { transition-delay: 100ms; }
  .m-left .meta-block:nth-child(3) { transition-delay: 200ms; }
  .m-left .meta-block:nth-child(4) { transition-delay: 300ms; }
  .m-left .meta-block:nth-child(5) { transition-delay: 400ms; }

  .meta-block.mb-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Left vertical cyan border — Hashgraph density indicator */
  .meta-block::before {
    content: '';
    position: absolute;
    left: 0;
    top: 3px;
    bottom: 3px;
    width: 1px;
    background: rgba(0, 212, 255, 0.5);
    border-radius: 1px;
  }

  .meta-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    line-height: 1;
  }

  .meta-value {
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
  }

  .meta-sub {
    font-size: 11px;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }

  .meta-mint   { color: var(--signal-mint); }

  .meta-email {
    color: var(--signal-cyan);
    text-decoration: none;
    transition: opacity 180ms ease;
  }
  .meta-email:hover { opacity: 0.7; text-decoration: underline; }

  .meta-italic {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
  }

  /* ── DOCTRINE GRID: 2-col key/value table ──────────────── */
  .doctrine-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 14px;
    align-items: baseline;
  }

  .dg-key {
    font-size: 10px;
    letter-spacing: 0.3em;
    color: rgba(0, 212, 255, 0.6);
    font-variant: small-caps;
    white-space: nowrap;
    line-height: 1.3;
  }

  .dg-val {
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.3;
  }

  /* ── RIGHT COLUMN ───────────────────────────────────────── */
  .m-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ── SUBTITLE: "WHAT WE BELIEVE" ───────────────────────── */
  .mr-subtitle {
    font-size: 11px;
    letter-spacing: 0.4em;
    color: rgba(0, 212, 255, 0.55);
    margin-bottom: 32px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 500ms ease 200ms,
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms;
  }
  .is-revealed .mr-subtitle {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── PRIMARY HEADING ────────────────────────────────────── */
  /* Three display lines, MASSIVE — clamp from 56px to 128px */
  .mr-heading {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 48px;
    font-size: clamp(56px, 9vw, 128px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 0 80px rgba(0, 212, 255, 0.15);
  }

  .mh-line {
    display: block;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Staggered per-line delay — fires when .is-revealed is on section */
  .is-revealed .mr-heading .mh-line:nth-child(1) { transition-delay: 400ms; }
  .is-revealed .mr-heading .mh-line:nth-child(2) { transition-delay: 580ms; }
  .is-revealed .mr-heading .mh-line:nth-child(3) { transition-delay: 760ms; }

  .is-revealed .mh-line {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── DIVIDER — draws from left on reveal ────────────────── */
  .mr-divider {
    width: 80px;
    height: 1px;
    background: rgba(0, 212, 255, 0.5);
    margin-bottom: 48px;
    transform-origin: left center;
    transform: scaleX(0);
    opacity: 0;
    transition:
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1) 1000ms,
      opacity   400ms ease 1000ms;
  }
  .is-revealed .mr-divider {
    transform: scaleX(1);
    opacity: 1;
  }

  /* ── THREE DECLARATIONS ─────────────────────────────────── */
  .mr-declarations {
    display: flex;
    flex-direction: column;
    max-width: 580px;
    width: 100%;
    margin-bottom: 64px;
  }

  .decl {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding-block: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .decl:first-child { padding-top: 0; }
  .decl:last-child  { border-bottom: none; padding-bottom: 0; }

  /* Declaration stagger delays */
  .is-revealed .mr-declarations .decl:nth-child(1) { transition-delay: 1200ms; }
  .is-revealed .mr-declarations .decl:nth-child(2) { transition-delay: 1450ms; }
  .is-revealed .mr-declarations .decl:nth-child(3) { transition-delay: 1700ms; }

  .is-revealed .decl {
    opacity: 1;
    transform: translateY(0);
  }

  /* Roman numeral — Instrument Serif italic, cyan */
  .decl-numeral {
    font-size: 32px;
    color: rgba(0, 212, 255, 0.7);
    line-height: 1;
    flex-shrink: 0;
    padding-top: 2px;
    min-width: 36px;
  }

  .decl-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Declaration label — Cinzel small-caps */
  .decl-label {
    font-size: 14px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.9);
    font-variant: small-caps;
    line-height: 1.2;
  }

  /* Declaration body — Geist regular */
  .decl-text {
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── SIGNOFF ────────────────────────────────────────────── */
  .mr-signoff {
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transition: opacity 800ms ease 2000ms;
  }
  .is-revealed .mr-signoff { opacity: 1; }

  .signoff-line {
    width: 60px;
    height: 1px;
    background: rgba(0, 212, 255, 0.5);
    margin-bottom: 10px;
  }

  .signoff-mark {
    font-size: 20px;
    color: rgba(0, 212, 255, 0.75);
    letter-spacing: 0.15em;
    line-height: 1;
  }

  .signoff-name {
    font-size: 10px;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── MOBILE (<768px) ────────────────────────────────────── */
  @media (max-width: 768px) {
    section {
      padding: 5rem 1.5rem 6rem;
    }

    /* Stack: left column first, then right */
    .m-columns {
      grid-template-columns: 1fr;
      gap: 3rem 0;
    }

    /* Hide the spine — no columns to divide */
    .m-columns::before { display: none; }

    /* Left column: no longer sticky */
    .m-left {
      position: static;
      border-bottom: 1px solid rgba(0, 212, 255, 0.1);
      padding-bottom: 2.5rem;
    }

    /* Heading: scale down */
    .mr-heading {
      font-size: clamp(2.5rem, 11vw, 4rem);
    }

    /* Body text: slightly smaller */
    .decl-text { font-size: 15px; }

    /* Hide half the particles on mobile for performance */
    .particle:nth-child(odd) { display: none; }
  }

  /* ── REDUCED MOTION ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .particle  { animation: none !important; }
    .m-glow    { animation: none !important; }

    .mr-subtitle,
    .mh-line,
    .mr-divider,
    .decl,
    .mr-signoff,
    .meta-block {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
