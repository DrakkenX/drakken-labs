---
// 12 ambient particles — bumped size (3-5px) and opacity (0.30-0.50)
const particles: Array<{x:string;y:string;size:number;opacity:number;dur:number;delay:number;dx:number;dy:number}> = [
  { x:'8%',  y:'18%', size:4, opacity:0.40, dur:13, delay:0,  dx:12,  dy:-10 },
  { x:'22%', y:'62%', size:5, opacity:0.32, dur:16, delay:2,  dx:-8,  dy:14  },
  { x:'42%', y:'12%', size:3, opacity:0.45, dur:11, delay:4,  dx:10,  dy:8   },
  { x:'68%', y:'38%', size:4, opacity:0.35, dur:14, delay:1,  dx:-14, dy:-8  },
  { x:'83%', y:'72%', size:5, opacity:0.30, dur:17, delay:3,  dx:8,   dy:-12 },
  { x:'12%', y:'82%', size:3, opacity:0.38, dur:12, delay:5,  dx:-10, dy:-6  },
  { x:'55%', y:'52%', size:4, opacity:0.32, dur:15, delay:2,  dx:6,   dy:10  },
  { x:'88%', y:'22%', size:5, opacity:0.30, dur:10, delay:6,  dx:-8,  dy:14  },
  { x:'34%', y:'88%', size:3, opacity:0.38, dur:13, delay:1,  dx:14,  dy:-8  },
  { x:'76%', y:'8%',  size:4, opacity:0.34, dur:16, delay:4,  dx:-6,  dy:12  },
  { x:'60%', y:'68%', size:5, opacity:0.30, dur:12, delay:3,  dx:10,  dy:-10 },
  { x:'4%',  y:'44%', size:3, opacity:0.42, dur:14, delay:0,  dx:-12, dy:8   },
];
---

<section id="manifesto" aria-labelledby="manifesto-heading">

  <!-- L1: Cosmic texture background -->
  <div class="m-bg" aria-hidden="true">
    <img
      src="/media/texture-1.jpg"
      alt=""
      class="m-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="m-bg-vignette"></div>
  </div>

  <!-- L6: Ambient floating particles (pure CSS) -->
  <div class="m-particles" aria-hidden="true">
    {particles.map((p, i) => (
      <div
        class={`particle particle-${i}`}
        style={`left:${p.x};top:${p.y};width:${p.size}px;height:${p.size}px;opacity:${p.opacity};--dur:${p.dur}s;--delay:-${p.delay}s;--dx:${p.dx}px;--dy:${p.dy}px`}
      ></div>
    ))}
  </div>

  <!-- L7: Side ornament lines -->
  <div class="ornament ornament-l" aria-hidden="true">
    <div class="ornament-line"></div>
    <span class="ornament-text">EST · 2025</span>
    <div class="ornament-line"></div>
  </div>
  <div class="ornament ornament-r" aria-hidden="true">
    <div class="ornament-line"></div>
    <span class="ornament-text">DRAKKEN LABS</span>
    <div class="ornament-line"></div>
  </div>

  <!-- Violet ambient glow -->
  <div class="m-glow" aria-hidden="true"></div>

  <!-- Main editorial content -->
  <div class="m-inner">

    <!-- L2: DANZAN-style section label -->
    <div class="m-label" aria-label="Manifesto">
      <div class="m-label-line"></div>
      <div class="m-label-center">
        <!-- Δ triangle left -->
        <svg class="m-delta" viewBox="0 0 10 10" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="5,0 10,10 0,10" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
        <span class="m-label-text font-cinzel">MANIFESTO</span>
        <!-- Δ triangle right (inverted) -->
        <svg class="m-delta m-delta-r" viewBox="0 0 10 10" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="5,0 10,10 0,10" fill="none" stroke="#00d4ff" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="m-label-line"></div>
    </div>

    <!-- L3: Heading with word-by-word reveal (CSS-driven stagger via --w) -->
    <h2 id="manifesto-heading" class="m-heading font-serif">
      <span class="word" style="--w:0">We</span>
      <span class="word" style="--w:1">build</span>
      <span class="word" style="--w:2">what</span>
      <span class="word italic" style="--w:3">shouldn't</span>
      <span class="word" style="--w:4">exist</span>
      <span class="word" style="--w:5">yet.</span>
    </h2>

    <!-- L4: Three manifesto lines -->
    <div class="m-lines">
      <p class="m-line font-inter" style="--li:0">
        Software as ceremony. Code as craft.
      </p>
      <p class="m-line font-inter" style="--li:1">
        AI as creative partner — not replacement.
      </p>
      <p class="m-line font-inter" style="--li:2">
        Quality compounds. Speed multiplies.
        The future belongs to those who build with intention.
      </p>
    </div>

    <!-- L5: Signature signoff -->
    <div class="m-signoff">
      <div class="m-signoff-line"></div>
      <p class="m-signoff-name font-serif">— DRAKKEN</p>
      <p class="m-signoff-attr font-mono">Han Myo Naing, Founder</p>
    </div>

  </div>
</section>

<script>
  (() => {
    // ── Word-by-word heading reveal (one-shot IntersectionObserver) ──
    const heading = document.querySelector<HTMLElement>('#manifesto-heading');
    const words   = heading?.querySelectorAll<HTMLElement>('.word');
    const lines   = document.querySelectorAll<HTMLElement>('.m-line');
    const signoff = document.querySelector<HTMLElement>('.m-signoff');

    if (!heading || !words?.length) return;

    const LINE_1_DELAY  = 1400; // ms after heading.in-view fires
    const SIGNOFF_DELAY = 2600; // ms after heading.in-view fires

    let fired = false;
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || fired) return;
          fired = true;

          // CSS transition-delay (via --w) drives the word stagger
          // — just add the class once and CSS does the rest
          heading.classList.add('in-view');

          // Lines fade up after heading words cascade (6 words × 180ms + 600ms ≈ 1680ms)
          lines.forEach((line, i) => {
            setTimeout(() => line.classList.add('revealed'), LINE_1_DELAY + i * 300);
          });

          // Signoff appears after all three lines
          setTimeout(() => signoff?.classList.add('revealed'), SIGNOFF_DELAY);

          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.2, rootMargin: '-30px 0px' }
    );

    obs.observe(heading);

    // ── Background parallax ──────────────────────────────────────
    const bg = document.querySelector<HTMLElement>('.m-bg-img');
    if (!bg) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const loadParallax = async () => {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);
      gsap.to(bg, {
        yPercent: -30,
        ease: 'none',
        scrollTrigger: {
          trigger: '#manifesto',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      });
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadParallax, { timeout: 3000 });
    } else {
      setTimeout(loadParallax, 600);
    }
  })();
</script>

<style>
  section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 5rem;
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ══ L1: BACKGROUND IMAGE ═══════════════════════════════════ */
  .m-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .m-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.35) saturate(0.7) blur(1px);
    transform: translateY(0);
    will-change: transform;
  }

  .m-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 50%,
      transparent 20%,
      #030308 90%
    );
  }

  /* ══ L6: PARTICLES ══════════════════════════════════════════ */
  .m-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--signal-cyan);
    box-shadow: 0 0 6px rgba(0, 212, 255, 0.5);
    /* --dur, --delay, --dx, --dy all set via inline style as CSS custom props */
    animation: particleDrift var(--dur, 13s) ease-in-out var(--delay, 0s) infinite alternate;
  }

  /* Each particle uses CSS custom property offsets for unique drift */
  @keyframes particleDrift {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(calc(var(--dx) * 0.6), calc(var(--dy) * -0.4)); }
    50%  { transform: translate(var(--dx), var(--dy)); }
    75%  { transform: translate(calc(var(--dx) * 0.3), calc(var(--dy) * 0.8)); }
    100% { transform: translate(0, 0); }
  }

  /* ══ L7: SIDE ORNAMENT LINES ════════════════════════════════ */
  .ornament {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 60%;
    z-index: 2;
    pointer-events: none;
  }

  .ornament-l { left: 32px; }
  .ornament-r { right: 32px; }

  .ornament-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 212, 255, 0.45) 30%,
      rgba(0, 212, 255, 0.45) 70%,
      transparent 100%
    );
    min-height: 40px;
  }

  .ornament-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.45);   /* bumped from 0.28 */
    text-transform: uppercase;
    white-space: nowrap;
    margin: 10px 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .ornament-r .ornament-text {
    transform: rotate(180deg);
  }

  /* Ensure ornaments are visible above background */
  .ornament {
    z-index: 3 !important;  /* above particles (z=1), below inner content (z=3, same is fine) */
  }

  /* ══ AMBIENT GLOW ═══════════════════════════════════════════ */
  .m-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -100px;
    left: 15%;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
    animation: mGlow 18s ease-in-out infinite;
  }

  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0, 0); }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  /* ══ INNER CONTENT ══════════════════════════════════════════ */
  .m-inner {
    position: relative;
    z-index: 3;
    max-width: 860px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* ══ L2: SECTION LABEL ══════════════════════════════════════ */
  .m-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .m-label-line {
    width: 60px;
    height: 1px;
    background: rgba(0, 212, 255, 0.5);
    flex-shrink: 0;
  }

  .m-label-center {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .m-delta {
    width: 9px;
    height: 9px;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .m-delta-r {
    transform: rotate(180deg);
  }

  .m-label-text {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.32em;
    color: rgba(0, 212, 255, 0.7);
    font-variant: small-caps;
  }

  /* ══ L3: HEADING — word-by-word reveal ══════════════════════ */
  .m-heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: normal;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: -0.01em;
    max-width: 1000px;
    text-align: center;
    margin-bottom: 3.5rem;
    text-shadow: 0 0 60px rgba(0, 212, 255, 0.15);
    text-wrap: balance;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25em 0.3em;
  }

  /* Each word: hidden until .in-view fires on parent <h2> */
  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    /* transition-delay drives the stagger — purely CSS, no JS setTimeout */
    transition:
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--w) * 180ms),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--w) * 180ms);
    margin-right: 0.1em; /* small gap between words */
  }

  .word.italic {
    font-style: italic;
    margin-right: 0.05em;
  }

  /* JS adds .in-view to the <h2> — CSS transition-delay creates the stagger */
  .m-heading.in-view .word {
    opacity: 1;
    transform: translateY(0);
  }

  /* ══ L4: THREE MANIFESTO LINES ══════════════════════════════ */
  .m-lines {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3.5rem;
    max-width: 740px;
    width: 100%;
  }

  .m-line {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.68);
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity  0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    text-wrap: pretty;
  }

  .m-line.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ══ L5: SIGNATURE SIGNOFF ══════════════════════════════════ */
  .m-signoff {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity  0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .m-signoff.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .m-signoff-line {
    width: 60px;
    height: 1px;
    background: rgba(0, 212, 255, 0.5);
    margin-bottom: 0.25rem;
  }

  .m-signoff-name {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 0.9375rem;
    color: rgba(0, 212, 255, 0.65);
    letter-spacing: 0.2em;
  }

  .m-signoff-attr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.32);
    text-transform: uppercase;
  }

  /* ══ MOBILE ════════════════════════════════════════════════ */
  @media (max-width: 768px) {
    section { padding: 6rem 2rem; }
    .ornament { display: none; }
    .m-bg-img { filter: brightness(0.25) saturate(0.6) blur(2px); }
    /* Reduce particle count via CSS (show only even-indexed) */
    .particle:nth-child(odd) { display: none; }
  }

  /* ══ REDUCED MOTION ════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .particle  { animation: none; }
    .m-bg-img  { animation: none; }
    .m-glow    { animation: none; }
    /* Snap everything to final state */
    .word      { opacity: 1 !important; transform: none !important; transition: none !important; }
    .m-line    { opacity: 1 !important; transform: none !important; transition: none !important; }
    .m-signoff { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>
