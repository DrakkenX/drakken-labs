---
---

<section id="manifesto" aria-labelledby="manifesto-heading">
  <!-- Full-bleed photographic background -->
  <div class="section-bg manifesto-bg" aria-hidden="true">
    <img
      src="/media/texture-1.jpg"
      alt=""
      class="section-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="section-bg-vignette"></div>
  </div>

  <!-- Left vertical thread — echoes hero beam -->
  <div class="thread-line" aria-hidden="true"></div>

  <!-- Violet ambient -->
  <div class="manifesto-glow" aria-hidden="true"></div>

  <div class="manifesto-inner">
    <!-- Section label with flanking lines -->
    <div class="section-label reveal">
      <span>MANIFESTO</span>
    </div>

    <!-- Heading — "shouldn't" gets Instrument Serif italic accent -->
    <h2 id="manifesto-heading" class="manifesto-heading font-serif reveal" data-delay="80">
      We build what <em class="word-accent">shouldn't</em> exist yet.
    </h2>

    <!-- Lines stagger in -->
    <div class="manifesto-lines" data-stagger data-stagger-step="200" data-stagger-delay="200">
      <p class="manifesto-line stagger-child font-inter">
        Software as ceremony. Code as craft.
        AI as creative partner, not replacement.
      </p>
      <p class="manifesto-line secondary stagger-child font-inter">
        Quality compounds. Speed multiplies.<br />
        The future belongs to those who build with intention.
      </p>
    </div>
  </div>
</section>

<script>
  (() => {
    // Parallax on manifesto background image
    const bg = document.querySelector<HTMLElement>('.manifesto-bg .section-bg-img');
    if (!bg) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const loadParallax = async () => {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      gsap.to(bg, {
        yPercent: -30,
        ease: 'none',
        scrollTrigger: {
          trigger: '#manifesto',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      });
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadParallax, { timeout: 3000 });
    } else {
      setTimeout(loadParallax, 600);
    }
  })();
</script>

<style>
  section {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 8rem 4rem;
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ── BACKGROUND IMAGE ────────────────────────────────── */
  .section-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .section-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%; /* extra height for parallax travel */
    object-fit: cover;
    filter: brightness(0.25) saturate(0.6) blur(1px);
    transform: translateY(0);
    will-change: transform;
  }

  .section-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 30% 50%,
      transparent 0%,
      #030308 80%
    );
  }

  /* Ambient violet glow */
  .manifesto-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    top: -100px;
    left: 20%;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
    animation: mGlow 18s ease-in-out infinite;
  }

  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0, 0); }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  .manifesto-inner {
    position: relative;
    z-index: 2;
    max-width: 720px;
    padding-left: 3rem;
  }

  /* Heading — Instrument Serif italic */
  .manifesto-heading {
    font-style: italic;
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    line-height: 1.25;
    color: var(--text-pure);
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  /* Instrument Serif italic accent on "shouldn't" */
  .word-accent {
    font-style: italic;
    font-family: 'Instrument Serif', Georgia, serif;
    color: rgba(255, 255, 255, 0.95);
    /* subtle cyan tint — the emotional anchor */
    text-shadow: 0 0 20px rgba(0, 212, 255, 0.12);
  }

  /* Paragraph lines */
  .manifesto-lines {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .manifesto-line {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.75;
    color: rgba(232, 237, 245, 0.68);
    max-width: 560px;
    text-wrap: pretty;
  }

  .manifesto-line.secondary {
    color: rgba(139, 148, 168, 0.8);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 768px) {
    section { padding: 6rem 1.5rem; }
    .manifesto-inner { padding-left: 1.5rem; }
    .thread-line { left: 16px; }
    .section-bg-img { filter: brightness(0.2) saturate(0.5) blur(2px); }
  }
</style>
