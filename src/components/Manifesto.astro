---
import SectionAnchor from './SectionAnchor.astro';

// 12 ambient particles — scattered across section bounds (unchanged)
const particles: Array<{x:string;y:string;size:number;opacity:number;dur:number;delay:number;dx:number;dy:number}> = [
  { x:'8%',  y:'18%', size:3, opacity:0.35, dur:13, delay:0,  dx:12,  dy:-10 },
  { x:'22%', y:'62%', size:2, opacity:0.28, dur:16, delay:2,  dx:-8,  dy:14  },
  { x:'42%', y:'12%', size:3, opacity:0.38, dur:11, delay:4,  dx:10,  dy:8   },
  { x:'68%', y:'38%', size:2, opacity:0.30, dur:14, delay:1,  dx:-14, dy:-8  },
  { x:'83%', y:'72%', size:3, opacity:0.25, dur:17, delay:3,  dx:8,   dy:-12 },
  { x:'12%', y:'82%', size:2, opacity:0.32, dur:12, delay:5,  dx:-10, dy:-6  },
  { x:'55%', y:'52%', size:3, opacity:0.27, dur:15, delay:2,  dx:6,   dy:10  },
  { x:'88%', y:'22%', size:2, opacity:0.25, dur:10, delay:6,  dx:-8,  dy:14  },
  { x:'34%', y:'88%', size:3, opacity:0.32, dur:13, delay:1,  dx:14,  dy:-8  },
  { x:'76%', y:'8%',  size:2, opacity:0.28, dur:16, delay:4,  dx:-6,  dy:12  },
  { x:'60%', y:'68%', size:3, opacity:0.25, dur:12, delay:3,  dx:10,  dy:-10 },
  { x:'4%',  y:'44%', size:2, opacity:0.36, dur:14, delay:0,  dx:-12, dy:8   },
];
---

<section id="manifesto" aria-labelledby="manifesto-heading">

  <!-- ── Cosmic texture background ────────────────────────── -->
  <div class="m-bg" aria-hidden="true">
    <img
      id="m-bg-img"
      src="/media/texture-1.jpg"
      alt=""
      class="m-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="m-bg-vignette"></div>
    <div class="m-bg-tint"></div>
  </div>

  <!-- Ambient glow -->
  <div class="m-glow" aria-hidden="true"></div>

  <!-- 12 ambient floating particles -->
  <div class="m-particles" aria-hidden="true">
    {particles.map((p, i) => (
      <div
        class={`particle particle-${i}`}
        style={`left:${p.x};top:${p.y};width:${p.size}px;height:${p.size}px;opacity:${p.opacity};--dur:${p.dur}s;--delay:-${p.delay}s;--dx:${p.dx}px;--dy:${p.dy}px`}
      ></div>
    ))}
  </div>

  <!-- ── Single-column container ──────────────────────────── -->
  <div class="m-container">

    <!-- //01 Section anchor -->
    <SectionAnchor number="01" label="Manifesto" />

    <!-- Eyebrow -->
    <p class="m-eyebrow font-mono">WHAT WE BELIEVE</p>

    <!-- MASSIVE three-line heading — the whole show -->
    <h2 id="manifesto-heading" class="m-heading">
      <span class="m-line font-cinzel">We build</span>
      <span class="m-line">
        <span class="font-cinzel">what </span><em class="m-italic">shouldn't</em>
      </span>
      <span class="m-line font-cinzel">exist yet.</span>
    </h2>

    <!-- Single unified body paragraph — no I/II/III split -->
    <p class="m-body">
      Software is ceremony — code as craft, every commit deliberate.
      We treat AI as a creative partner, not a replacement: it writes
      the boilerplate so we can focus on architecture decisions, taste
      calls, and the error states that actually matter. Quality
      compounds. Speed multiplies. The future belongs to those who
      build with intention — and ship before consensus.
    </p>

    <!-- Subtle CTA link -->
    <a href="#showcase" class="m-cta">
      <span>See what we've built</span>
      <span class="m-arrow" aria-hidden="true">→</span>
    </a>

    <!-- Signoff -->
    <div class="m-signoff">
      <div class="m-signoff-line" aria-hidden="true"></div>
      <p class="m-signoff-mark m-italic">— DRAKKEN</p>
      <p class="m-signoff-name font-mono">Han Myo Naing, Founder · MMXXV</p>
    </div>

  </div>

</section>

<script>
  (() => {
    const section = document.getElementById('manifesto');
    if (!section) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Snap to final state immediately
    if (prefersReduced) {
      section.classList.add('is-revealed');
      return;
    }

    // One-shot section reveal — triggers all staggered children
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          section.classList.add('is-revealed');
          obs.disconnect();
        }
      },
      { threshold: 0.25 }
    );
    obs.observe(section);

    // Background parallax — 0.25× scroll speed, desktop only
    if (!window.matchMedia('(max-width: 768px)').matches) {
      const loadParallax = async () => {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);

        const bgImg = document.getElementById('m-bg-img');
        if (!bgImg) return;

        gsap.to(bgImg, {
          yPercent: -25,
          ease: 'none',
          scrollTrigger: {
            trigger: '#manifesto',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      };

      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(loadParallax, { timeout: 3000 });
      } else {
        setTimeout(loadParallax, 600);
      }
    }
  })();
</script>

<style>
  /* ── LOCAL FONT UTILITIES ───────────────────────────────── */
  .font-cinzel { font-family: 'Cinzel', Georgia, serif; }
  .m-italic    {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
  }

  /* ── SECTION SHELL ──────────────────────────────────────── */
  section {
    position: relative;
    padding-block: 10rem;    /* 160px top/bottom */
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ── BACKGROUND ─────────────────────────────────────────── */
  .m-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .m-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.3) saturate(0.7) blur(0.5px);
    will-change: transform;
  }

  .m-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 10%, #030308 85%);
  }

  .m-bg-tint {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 212, 255, 0.012);
  }

  .m-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -80px;
    left: 15%;
    background: radial-gradient(ellipse at center, rgba(167, 139, 250, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    animation: mGlow 18s ease-in-out infinite;
  }
  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0,   0);  }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  /* ── PARTICLES ──────────────────────────────────────────── */
  .m-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--signal-cyan);
    box-shadow: 0 0 4px rgba(0, 212, 255, 0.5);
    animation: particleDrift var(--dur, 13s) ease-in-out var(--delay, 0s) infinite alternate;
  }

  @keyframes particleDrift {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(calc(var(--dx) * 0.6), calc(var(--dy) * -0.4)); }
    50%  { transform: translate(var(--dx), var(--dy)); }
    75%  { transform: translate(calc(var(--dx) * 0.3), calc(var(--dy) * 0.8)); }
    100% { transform: translate(0, 0); }
  }

  /* ── SINGLE-COLUMN CONTAINER ────────────────────────────── */
  .m-container {
    position: relative;
    z-index: 4;
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: clamp(24px, 5vw, 80px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;   /* left-aligned — matches Hashgraph */
  }

  /* ── EYEBROW ────────────────────────────────────────────── */
  .m-eyebrow {
    font-size: 11px;
    letter-spacing: 0.4em;
    color: rgba(0, 212, 255, 0.65);
    text-transform: uppercase;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms,
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms;
  }
  .is-revealed .m-eyebrow {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── MASSIVE HEADING ────────────────────────────────────── */
  /* Three display lines — the whole show                      */
  /* clamp(64px, 11vw, 168px) per spec                        */
  .m-heading {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 64px;
    font-size: clamp(64px, 11vw, 168px);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.96);
    text-shadow: 0 0 80px rgba(0, 212, 255, 0.12);
    max-width: 1100px;
  }

  .m-line {
    display: block;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Per-line stagger — only fires when section is revealed */
  .is-revealed .m-heading .m-line:nth-child(1) { transition-delay: 400ms; }
  .is-revealed .m-heading .m-line:nth-child(2) { transition-delay: 600ms; }
  .is-revealed .m-heading .m-line:nth-child(3) { transition-delay: 800ms; }

  .is-revealed .m-line {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── BODY PARAGRAPH ─────────────────────────────────────── */
  /* Single unified block — no I/II/III splits                */
  .m-body {
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    letter-spacing: -0.005em;
    max-width: 680px;
    margin-top: 64px;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1) 1200ms,
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1) 1200ms;
  }
  .is-revealed .m-body {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── CTA LINK ───────────────────────────────────────────── */
  .m-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 48px;
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: rgba(0, 212, 255, 0.9);
    text-decoration: underline;
    text-decoration-color: rgba(0, 212, 255, 0.3);
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
    transition:
      color 180ms ease,
      text-decoration-color 180ms ease;
    opacity: 0;
    transform: translateY(10px);
    /* animation transition separate from hover transition */
    --reveal-transition:
      opacity 500ms cubic-bezier(0.16, 1, 0.3, 1) 1500ms,
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 1500ms;
    transition: color 180ms ease, text-decoration-color 180ms ease, opacity 500ms cubic-bezier(0.16, 1, 0.3, 1) 1500ms, transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 1500ms;
  }
  .is-revealed .m-cta {
    opacity: 1;
    transform: translateY(0);
  }
  /* Suppress reveal transition once visible so hover works cleanly */
  .is-revealed .m-cta {
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .m-cta:hover {
      color: rgba(0, 212, 255, 1);
      text-decoration-color: rgba(0, 212, 255, 0.6);
    }
  }

  .m-arrow {
    display: inline-block;
    transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (hover: hover) and (pointer: fine) {
    .m-cta:hover .m-arrow {
      transform: translateX(4px);
    }
  }

  /* ── SIGNOFF ────────────────────────────────────────────── */
  .m-signoff {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 120px;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1) 1800ms,
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1) 1800ms;
  }
  .is-revealed .m-signoff {
    opacity: 1;
    transform: translateY(0);
  }

  .m-signoff-line {
    width: 60px;
    height: 1px;
    background: rgba(0, 212, 255, 0.4);
    margin-bottom: 12px;
  }

  .m-signoff-mark {
    font-size: 20px;
    color: rgba(0, 212, 255, 0.75);
    letter-spacing: 0.15em;
    line-height: 1;
  }

  .m-signoff-name {
    font-size: 10px;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── MOBILE (<768px) ────────────────────────────────────── */
  @media (max-width: 768px) {
    section {
      padding-block: 5rem;
    }

    .m-heading {
      font-size: clamp(36px, 10vw, 56px);
      margin-bottom: 40px;
    }

    .m-body {
      font-size: clamp(16px, 4vw, 18px);
      margin-top: 40px;
    }

    .m-cta {
      margin-top: 32px;
    }

    .m-signoff {
      margin-top: 72px;
    }

    /* Hide half the particles for performance */
    .particle:nth-child(odd) { display: none; }
  }

  /* ── REDUCED MOTION ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .particle  { animation: none !important; }
    .m-glow    { animation: none !important; }

    .m-eyebrow,
    .m-line,
    .m-body,
    .m-cta,
    .m-signoff {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
