---
// 12 ambient particles — scattered across section bounds
const particles: Array<{x:string;y:string;size:number;opacity:number;dur:number;delay:number;dx:number;dy:number}> = [
  { x:'8%',  y:'18%', size:3, opacity:0.35, dur:13, delay:0,  dx:12,  dy:-10 },
  { x:'22%', y:'62%', size:2, opacity:0.28, dur:16, delay:2,  dx:-8,  dy:14  },
  { x:'42%', y:'12%', size:3, opacity:0.38, dur:11, delay:4,  dx:10,  dy:8   },
  { x:'68%', y:'38%', size:2, opacity:0.30, dur:14, delay:1,  dx:-14, dy:-8  },
  { x:'83%', y:'72%', size:3, opacity:0.25, dur:17, delay:3,  dx:8,   dy:-12 },
  { x:'12%', y:'82%', size:2, opacity:0.32, dur:12, delay:5,  dx:-10, dy:-6  },
  { x:'55%', y:'52%', size:3, opacity:0.27, dur:15, delay:2,  dx:6,   dy:10  },
  { x:'88%', y:'22%', size:2, opacity:0.25, dur:10, delay:6,  dx:-8,  dy:14  },
  { x:'34%', y:'88%', size:3, opacity:0.32, dur:13, delay:1,  dx:14,  dy:-8  },
  { x:'76%', y:'8%',  size:2, opacity:0.28, dur:16, delay:4,  dx:-6,  dy:12  },
  { x:'60%', y:'68%', size:3, opacity:0.25, dur:12, delay:3,  dx:10,  dy:-10 },
  { x:'4%',  y:'44%', size:2, opacity:0.36, dur:14, delay:0,  dx:-12, dy:8   },
];
---

<section id="manifesto" aria-labelledby="manifesto-heading">

  <!-- Cosmic texture background -->
  <div class="m-bg" aria-hidden="true">
    <img
      id="m-bg-img"
      src="/media/texture-1.jpg"
      alt=""
      class="m-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="m-bg-vignette"></div>
    <div class="m-bg-tint"></div>
  </div>

  <!-- Ambient cyan glow -->
  <div class="m-glow" aria-hidden="true"></div>

  <!-- 12 ambient floating particles -->
  <div class="m-particles" aria-hidden="true">
    {particles.map((p, i) => (
      <div
        class={`particle particle-${i}`}
        style={`left:${p.x};top:${p.y};width:${p.size}px;height:${p.size}px;opacity:${p.opacity};--dur:${p.dur}s;--delay:-${p.delay}s;--dx:${p.dx}px;--dy:${p.dy}px`}
      ></div>
    ))}
  </div>

  <!-- Side ornament lines -->
  <div class="ornament ornament-l" aria-hidden="true">
    <div class="ornament-line"></div>
    <span class="ornament-text">EST · 2025</span>
    <div class="ornament-line"></div>
  </div>
  <div class="ornament ornament-r" aria-hidden="true">
    <div class="ornament-line"></div>
    <span class="ornament-text">DRAKKEN LABS</span>
    <div class="ornament-line"></div>
  </div>

  <!-- Main editorial content -->
  <div class="manifesto-content">

    <!-- Section label: [ • MANIFESTO • ] -->
    <div class="manifesto-label">
      <span class="label-bracket">[</span>
      <span class="label-dot" aria-hidden="true"></span>
      <span class="label-text font-cinzel">MANIFESTO</span>
      <span class="label-dot" aria-hidden="true"></span>
      <span class="label-bracket">]</span>
    </div>

    <!-- Main heading: Cinzel with ONLY "shouldn't" in Instrument Serif italic -->
    <h2 id="manifesto-heading" class="manifesto-heading">
      <span class="word font-cinzel" style="--i:0">We</span>
      <span class="word font-cinzel" style="--i:1">build</span>
      <span class="word font-cinzel" style="--i:2">what</span>
      <span class="word font-instrument-italic" style="--i:3">shouldn't</span>
      <span class="word font-cinzel" style="--i:4">exist</span>
      <span class="word font-cinzel" style="--i:5">yet.</span>
    </h2>

    <!-- Three declarations: Geist Regular, left-aligned -->
    <div class="manifesto-declarations">
      <p class="declaration" style="--d:0">
        <span class="dec-mark" aria-hidden="true">I.</span>
        Software as ceremony. Code as craft.
      </p>
      <p class="declaration" style="--d:1">
        <span class="dec-mark" aria-hidden="true">II.</span>
        AI as creative partner — not replacement.
      </p>
      <p class="declaration" style="--d:2">
        <span class="dec-mark" aria-hidden="true">III.</span>
        Quality compounds. Speed multiplies. The future belongs to those who build with intention.
      </p>
    </div>

    <!-- Signoff -->
    <div class="manifesto-signoff">
      <div class="signoff-line"></div>
      <div class="signoff-mark">— DRAKKEN</div>
      <div class="signoff-name font-mono">Han Myo Naing, Founder</div>
    </div>

  </div>

</section>

<script>
  (() => {
    const section = document.getElementById('manifesto');
    if (!section) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Snap to final state immediately if reduced motion
    if (prefersReduced) {
      section.classList.add('is-revealed');
      return;
    }

    // One-shot IntersectionObserver reveal — fires once when section enters view
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          section.classList.add('is-revealed');
          obs.disconnect();
        }
      },
      { threshold: 0.18 }
    );
    obs.observe(section);

    // Background parallax — only on desktop, only if not reduced motion
    if (!window.matchMedia('(max-width: 768px)').matches) {
      const loadParallax = async () => {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);

        const bgImg = document.getElementById('m-bg-img');
        if (!bgImg) return;

        gsap.to(bgImg, {
          yPercent: -25,
          ease: 'none',
          scrollTrigger: {
            trigger: '#manifesto',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      };

      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(loadParallax, { timeout: 3000 });
      } else {
        setTimeout(loadParallax, 600);
      }
    }
  })();
</script>

<style>
  /* ── SECTION SHELL ─────────────────────────────────────── */
  section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7.5rem 2rem 8rem;  /* 120px top, tighter than old 8rem all sides */
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ── BACKGROUND ────────────────────────────────────────── */
  .m-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .m-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.32) saturate(0.65) blur(0.5px);
    will-change: transform;
  }

  .m-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 10%,
      #030308 85%
    );
  }

  .m-bg-tint {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 212, 255, 0.012);
  }

  /* Ambient glow — violet, breathing */
  .m-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -80px;
    left: 15%;
    background: radial-gradient(ellipse at center, rgba(167,139,250,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    animation: mGlow 18s ease-in-out infinite;
  }
  @keyframes mGlow {
    0%,100% { transform: scale(1) translate(0,0); }
    50%      { transform: scale(1.1) translate(3%,5%); }
  }

  /* ── PARTICLES ─────────────────────────────────────────── */
  .m-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--signal-cyan);
    box-shadow: 0 0 4px rgba(0,212,255,0.5);
    animation: particleDrift var(--dur, 13s) ease-in-out var(--delay, 0s) infinite alternate;
  }

  @keyframes particleDrift {
    0%   { transform: translate(0,0); }
    25%  { transform: translate(calc(var(--dx)*0.6), calc(var(--dy)*-0.4)); }
    50%  { transform: translate(var(--dx), var(--dy)); }
    75%  { transform: translate(calc(var(--dx)*0.3), calc(var(--dy)*0.8)); }
    100% { transform: translate(0,0); }
  }

  /* ── SIDE ORNAMENTS ────────────────────────────────────── */
  .ornament {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 60%;
    z-index: 3;
    pointer-events: none;
  }
  .ornament-l { left: 32px; }
  .ornament-r { right: 32px; }

  .ornament-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0,212,255,0.4) 30%,
      rgba(0,212,255,0.4) 70%,
      transparent 100%
    );
    min-height: 40px;
  }
  .ornament-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.4);
    white-space: nowrap;
    margin: 10px 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
  .ornament-r .ornament-text { transform: rotate(180deg); }

  /* ── MAIN CONTENT ──────────────────────────────────────── */
  .manifesto-content {
    position: relative;
    z-index: 4;
    max-width: 860px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* ── SECTION LABEL ─────────────────────────────────────── */
  .manifesto-label {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 4rem;
    font-size: 12px;
    letter-spacing: 0.4em;

    opacity: 0;
    transform: translateY(16px);
    transition: opacity 800ms ease, transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .is-revealed .manifesto-label {
    opacity: 1;
    transform: translateY(0);
  }

  .label-bracket {
    font-family: 'Cinzel', Georgia, serif;
    font-variant: small-caps;
    color: rgba(0,212,255,0.4);
  }
  .label-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    opacity: 0.7;
    flex-shrink: 0;
  }
  .label-text {
    color: rgba(0,212,255,0.65);
    font-variant: small-caps;
    font-size: 12px;
    letter-spacing: 0.4em;
  }

  /* ── HEADING ───────────────────────────────────────────── */
  .manifesto-heading {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 400;
    color: rgba(255,255,255,0.96);
    line-height: 1.18;
    letter-spacing: -0.012em;
    text-shadow: 0 0 60px rgba(0,212,255,0.15);
    max-width: 1000px;
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2em 0.28em;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(400ms + var(--i, 0) * 120ms);
  }
  .is-revealed .word {
    opacity: 1;
    transform: translateY(0);
  }

  .font-cinzel { font-family: 'Cinzel', Georgia, serif; }
  /* ONLY "shouldn't" uses Instrument Serif italic */
  .font-instrument-italic {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
  }

  /* ── DECLARATIONS ──────────────────────────────────────── */
  .manifesto-declarations {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 720px;
    margin-bottom: 5rem;
  }

  .declaration {
    position: relative;
    padding-left: 56px;
    padding-bottom: 1.75rem;
    text-align: left;

    /* Geist Regular — the key typography shift */
    font-family: 'Geist', 'Helvetica Neue', system-ui, sans-serif;
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    font-weight: 400;
    color: rgba(255,255,255,0.78);
    line-height: 1.55;

    opacity: 0;
    transform: translateY(16px);
    transition: opacity 700ms ease, transform 700ms ease;
    transition-delay: calc(1400ms + var(--d, 0) * 250ms);
  }
  .is-revealed .declaration {
    opacity: 1;
    transform: translateY(0);
  }

  /* Roman numeral mark — Instrument Serif italic, cyan */
  .dec-mark {
    position: absolute;
    left: 0;
    top: 0.1em;
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 0.7em;
    color: rgba(0,212,255,0.7);
    line-height: 1;
  }

  /* ── SIGNOFF ───────────────────────────────────────────── */
  .manifesto-signoff {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;

    opacity: 0;
    transition: opacity 800ms ease;
    transition-delay: 2400ms;
  }
  .is-revealed .manifesto-signoff {
    opacity: 1;
  }

  .signoff-line {
    width: 60px;
    height: 1px;
    background: rgba(0,212,255,0.5);
    margin-bottom: 1rem;
  }
  .signoff-mark {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 1.125rem;
    color: rgba(0,212,255,0.75);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }
  .signoff-name {
    font-size: 0.625rem;
    letter-spacing: 0.32em;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
  }

  /* ── MOBILE ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    section {
      padding: 5rem 1.5rem 6rem;
    }
    .ornament { display: none; }
    .manifesto-heading {
      font-size: clamp(2rem, 8vw, 3rem);
      margin-bottom: 3rem;
    }
    .declaration {
      font-size: clamp(1rem, 4vw, 1.25rem);
      padding-left: 40px;
    }
    .manifesto-declarations { max-width: 100%; }
    .particle:nth-child(odd) { display: none; }
  }

  /* ── REDUCED MOTION ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .particle  { animation: none !important; }
    .m-glow    { animation: none !important; }
    .manifesto-label,
    .word,
    .declaration,
    .manifesto-signoff {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
