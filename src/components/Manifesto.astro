---
---

<section id="manifesto" aria-labelledby="manifesto-heading">
  <!-- Left vertical thread — echoes hero beam -->
  <div class="thread-line" aria-hidden="true"></div>

  <!-- Violet ambient -->
  <div class="manifesto-glow" aria-hidden="true"></div>

  <div class="manifesto-inner">
    <!-- Section label with flanking lines -->
    <div class="section-label reveal">
      <span>MANIFESTO</span>
    </div>

    <!-- Heading -->
    <h2 id="manifesto-heading" class="manifesto-heading font-serif reveal" data-delay="80">
      We build what shouldn't exist yet.
    </h2>

    <!-- Lines stagger in -->
    <div class="manifesto-lines" data-stagger data-stagger-step="200" data-stagger-delay="200">
      <p class="manifesto-line stagger-child font-inter">
        Software as ceremony. Code as craft.
        AI as creative partner, not replacement.
      </p>
      <p class="manifesto-line secondary stagger-child font-inter">
        Quality compounds. Speed multiplies.<br />
        The future belongs to those who build with intention.
      </p>
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 8rem 4rem;
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* Ambient violet glow */
  .manifesto-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    top: -100px;
    left: 20%;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
    animation: mGlow 18s ease-in-out infinite;
  }

  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0, 0); }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  .manifesto-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    padding-left: 3rem;
  }

  /* Heading — Instrument Serif italic for editorial authority */
  .manifesto-heading {
    font-style: italic;
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    line-height: 1.25;
    color: var(--text-pure);
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  /* Paragraph lines */
  .manifesto-lines {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .manifesto-line {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.75;
    color: rgba(232, 237, 245, 0.68);
    max-width: 560px;
    text-wrap: pretty;
  }

  .manifesto-line.secondary {
    color: rgba(139, 148, 168, 0.8);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 768px) {
    section { padding: 6rem 1.5rem; }
    .manifesto-inner { padding-left: 1.5rem; }
    .thread-line { left: 16px; }
  }
</style>
