---
import SectionAnchor from './SectionAnchor.astro';

// ── INJECTION 1: Build-time deterministic star field ──────────────────────
// xorshift32 — same values every build, zero runtime cost
let _s = 0xD3ADB33F;
const xr = (): number => {
  _s ^= _s << 13; _s ^= _s >> 17; _s ^= _s << 5;
  return (_s >>> 0) / 0x100000000;
};

// Layer A: 60 twinkling stars (white, tiny, subtle)
const stars = Array.from({ length: 60 }, () => ({
  x:      xr() * 100,
  y:      xr() * 100,
  size:   xr() > 0.62 ? 2 : 1,
  twMin:  +(0.06 + xr() * 0.12).toFixed(3),
  twMax:  +(0.20 + xr() * 0.22).toFixed(3),
  twDur:  +(3.2  + xr() * 4.8).toFixed(1),
  twDly:  +(xr() * 6.5).toFixed(2),
}));

// Layer B: 12 drifting cyan dust dots (kept from original, renamed)
const particles: Array<{x:string;y:string;size:number;opacity:number;dur:number;delay:number;dx:number;dy:number}> = [
  { x:'8%',  y:'18%', size:3, opacity:0.35, dur:13, delay:0,  dx:12,  dy:-10 },
  { x:'22%', y:'62%', size:2, opacity:0.28, dur:16, delay:2,  dx:-8,  dy:14  },
  { x:'42%', y:'12%', size:3, opacity:0.38, dur:11, delay:4,  dx:10,  dy:8   },
  { x:'68%', y:'38%', size:2, opacity:0.30, dur:14, delay:1,  dx:-14, dy:-8  },
  { x:'83%', y:'72%', size:3, opacity:0.25, dur:17, delay:3,  dx:8,   dy:-12 },
  { x:'12%', y:'82%', size:2, opacity:0.32, dur:12, delay:5,  dx:-10, dy:-6  },
  { x:'55%', y:'52%', size:3, opacity:0.27, dur:15, delay:2,  dx:6,   dy:10  },
  { x:'88%', y:'22%', size:2, opacity:0.25, dur:10, delay:6,  dx:-8,  dy:14  },
  { x:'34%', y:'88%', size:3, opacity:0.32, dur:13, delay:1,  dx:14,  dy:-8  },
  { x:'76%', y:'8%',  size:2, opacity:0.28, dur:16, delay:4,  dx:-6,  dy:12  },
  { x:'60%', y:'68%', size:3, opacity:0.25, dur:12, delay:3,  dx:10,  dy:-10 },
  { x:'4%',  y:'44%', size:2, opacity:0.36, dur:14, delay:0,  dx:-12, dy:8   },
];
---

<section id="manifesto" aria-labelledby="manifesto-heading">

  <!-- ═══ BACKGROUND SYSTEM (z 1-6, lowest → highest) ════════ -->

  <!-- Layer C: 3 nebula glows — slow breathe, cyan atmosphere -->
  <div class="m-nebula nb1" aria-hidden="true"></div>
  <div class="m-nebula nb2" aria-hidden="true"></div>
  <div class="m-nebula nb3" aria-hidden="true"></div>

  <!-- Layer A: 60-star field — individual twinkle per star -->
  <div class="m-stars" aria-hidden="true">
    {stars.map((s) => (
      <div
        class="star"
        style={`left:${s.x.toFixed(2)}%;top:${s.y.toFixed(2)}%;width:${s.size}px;height:${s.size}px;--tw-min:${s.twMin};--tw-max:${s.twMax};--tw-dur:${s.twDur}s;--tw-dly:${s.twDly}s`}
      ></div>
    ))}
  </div>

  <!-- Vignette — dark edges to keep focus on content -->
  <div class="m-vignette" aria-hidden="true"></div>

  <!-- Layer D: Constellation SVG — two groups, slowly rotating -->
  <svg
    class="m-constellation"
    viewBox="0 0 1400 900"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Alpha constellation: 5 stars, upper-right, rotates CW ~90s -->
    <g class="const-alpha">
      <line x1="860" y1="130" x2="980" y2="210" stroke="rgba(0,212,255,0.18)" stroke-width="0.8"/>
      <line x1="980" y1="210" x2="930" y2="340" stroke="rgba(0,212,255,0.14)" stroke-width="0.8"/>
      <line x1="930" y1="340" x2="800" y2="295" stroke="rgba(0,212,255,0.14)" stroke-width="0.8"/>
      <line x1="800" y1="295" x2="840" y2="180" stroke="rgba(0,212,255,0.16)" stroke-width="0.8"/>
      <line x1="840" y1="180" x2="860" y2="130" stroke="rgba(0,212,255,0.12)" stroke-width="0.8"/>
      <circle cx="860" cy="130" r="1.8" fill="rgba(0,212,255,0.55)"/>
      <circle cx="980" cy="210" r="1.5" fill="rgba(0,212,255,0.45)"/>
      <circle cx="930" cy="340" r="1.6" fill="rgba(0,212,255,0.50)"/>
      <circle cx="800" cy="295" r="1.4" fill="rgba(0,212,255,0.40)"/>
      <circle cx="840" cy="180" r="1.7" fill="rgba(0,212,255,0.48)"/>
    </g>
    <!-- Beta constellation: 4 stars, lower-left, rotates CCW ~120s -->
    <g class="const-beta">
      <line x1="230" y1="560" x2="330" y2="630" stroke="rgba(0,212,255,0.14)" stroke-width="0.8"/>
      <line x1="330" y1="630" x2="295" y2="730" stroke="rgba(0,212,255,0.12)" stroke-width="0.8"/>
      <line x1="295" y1="730" x2="180" y2="680" stroke="rgba(0,212,255,0.14)" stroke-width="0.8"/>
      <line x1="180" y1="680" x2="230" y2="560" stroke="rgba(0,212,255,0.10)" stroke-width="0.8"/>
      <circle cx="230" cy="560" r="1.6" fill="rgba(0,212,255,0.45)"/>
      <circle cx="330" cy="630" r="1.4" fill="rgba(0,212,255,0.38)"/>
      <circle cx="295" cy="730" r="1.5" fill="rgba(0,212,255,0.42)"/>
      <circle cx="180" cy="680" r="1.3" fill="rgba(0,212,255,0.35)"/>
    </g>
  </svg>

  <!-- Layer B: Drifting cyan dust (original particles, preserved) -->
  <div class="m-particles" aria-hidden="true">
    {particles.map((p, i) => (
      <div
        class={`particle particle-${i}`}
        style={`left:${p.x};top:${p.y};width:${p.size}px;height:${p.size}px;opacity:${p.opacity};--dur:${p.dur}s;--delay:-${p.delay}s;--dx:${p.dx}px;--dy:${p.dy}px`}
      ></div>
    ))}
  </div>

  <!-- Violet ambient glow (original, preserved) -->
  <div class="m-glow" aria-hidden="true"></div>

  <!-- INJECTION 6: Roaming light leak — moves corner to corner over 40s -->
  <div class="m-light-leak" aria-hidden="true"></div>

  <!-- INJECTION 1: Shooting star — JS-triggered every 18-25s (desktop only) -->
  <div class="m-shooting-star" id="m-shooting-star" aria-hidden="true"></div>

  <!-- ═══ CONTENT (z 8) ═══════════════════════════════════════ -->
  <div class="m-container">

    <!-- //01 Section anchor -->
    <SectionAnchor number="01" label="Manifesto" />

    <!-- Eyebrow -->
    <p class="m-eyebrow font-mono">WHAT WE BELIEVE</p>

    <!-- INJECTION 2: Massive heading — magnetic hover + breathing + italic glow -->
    <h2 id="manifesto-heading" class="m-heading">
      <span class="m-line font-cinzel">We build</span>
      <span class="m-line">
        <span class="font-cinzel">what </span><em class="m-italic">shouldn't</em>
      </span>
      <span class="m-line font-cinzel">exist yet.</span>
    </h2>

    <!-- INJECTION 3: Body — 5-paragraph editorial, each fades in as a beat -->
    <div class="m-body">
      <p class="m-body-line bp1">Software is ceremony — code as craft, every commit deliberate.</p>
      <p class="m-body-line bp2">We treat AI as a creative partner, not a replacement: it writes the boilerplate so we can focus on the architecture decisions, the taste calls, and the error states that actually matter.</p>
      <p class="m-body-line bp3">Quality compounds. Speed multiplies. Decisions stack.</p>
      <p class="m-body-line bp4">The future belongs to those who build with intention — and ship before consensus.</p>
      <p class="m-body-line bp5">One studio. One operator. Every line considered.</p>
    </div>

    <!-- INJECTION 4: Living CTA — continuous arrow bob + underline draw -->
    <a href="#showcase" class="m-cta">
      <span>See what we've built</span>
      <span class="m-arrow" aria-hidden="true">→</span>
    </a>

    <!-- INJECTION 5: Signoff — pulse line + glow mark -->
    <div class="m-signoff">
      <div class="m-signoff-line" aria-hidden="true"></div>
      <p class="m-signoff-mark m-italic">— DRAKKEN</p>
      <p class="m-signoff-name font-mono">Han Myo Naing, Founder · MMXXV</p>
    </div>

  </div>

</section>

<script>
  (() => {
    const section = document.getElementById('manifesto');
    if (!section) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const noHover  = window.matchMedia('(hover: none)').matches;

    // ── Reduced motion: snap everything to final state ─────────
    if (prefersReduced) {
      section.classList.add('is-revealed', 'is-breathing');
      return;
    }

    // ── Section reveal — one-shot IntersectionObserver ─────────
    const revealObs = new IntersectionObserver(
      (entries) => {
        if (!entries[0]?.isIntersecting) return;
        section.classList.add('is-revealed');
        revealObs.disconnect();

        // Heading breathing starts after all entrance animations finish (~2.2s)
        setTimeout(() => {
          section.classList.add('is-breathing');
        }, 2200);

        // Magnetic hover setup — after entrance completes (~2.5s, desktop only)
        if (!isMobile && !noHover) {
          setTimeout(() => setupMagneticHover(), 2500);
        }
      },
      { threshold: 0.25 }
    );
    revealObs.observe(section);

    // ── INJECTION 1: Shooting star — desktop only ───────────────
    if (!isMobile) {
      let ssTimeout: ReturnType<typeof setTimeout>;

      function spawnShootingStar() {
        const el = document.getElementById('m-shooting-star');
        if (!el) return;

        // Random Y start (10-55% of section height)
        const sH = section.offsetHeight;
        el.style.top = `${(0.10 + Math.random() * 0.45) * sH}px`;

        el.classList.remove('m-shooting');
        void (el as HTMLElement).offsetWidth; // reflow restart
        el.classList.add('m-shooting');

        ssTimeout = setTimeout(spawnShootingStar, 18000 + Math.random() * 7000);
      }

      // First star after 4-7 seconds
      ssTimeout = setTimeout(spawnShootingStar, 4000 + Math.random() * 3000);
    }

    // ── INJECTION 2: Magnetic hover on heading lines ────────────
    function setupMagneticHover() {
      const heading = document.getElementById('manifesto-heading');
      if (!heading) return;

      const lines = Array.from(heading.querySelectorAll<HTMLElement>('.m-line'));
      if (!lines.length) return;

      // Remove CSS entrance transitions — no longer needed, entrance is done
      lines.forEach((l) => { l.style.transition = 'none'; });

      const MAX_MOVE = 8;   // px max displacement per axis
      const DAMPING  = 0.08; // 0-1, lower = springier

      // State per line: current interpolated position + target
      const state = lines.map(() => ({ cx: 0, cy: 0, tx: 0, ty: 0 }));
      let rafId = 0;
      let active = false;

      function tick() {
        let running = false;
        lines.forEach((line, i) => {
          const s = state[i]!;
          const dx = s.tx - s.cx;
          const dy = s.ty - s.cy;
          if (Math.abs(dx) > 0.04 || Math.abs(dy) > 0.04) {
            s.cx += dx * DAMPING;
            s.cy += dy * DAMPING;
            line.style.transform = `translate(${s.cx.toFixed(2)}px, ${s.cy.toFixed(2)}px)`;
            running = true;
          } else if (s.cx !== 0 || s.cy !== 0) {
            // Snap to rest
            s.cx = 0; s.cy = 0;
            line.style.transform = '';
          }
        });
        if (running) rafId = requestAnimationFrame(tick);
        else active = false;
      }

      heading.addEventListener('mousemove', (e: MouseEvent) => {
        lines.forEach((line, i) => {
          const r = line.getBoundingClientRect();
          const cx = r.left + r.width  / 2;
          const cy = r.top  + r.height / 2;
          const dist = Math.max(0, 1 - Math.hypot(e.clientX - cx, e.clientY - cy) / 500);
          state[i]!.tx = ((e.clientX - cx) / Math.max(r.width, 1))  * MAX_MOVE * dist;
          state[i]!.ty = ((e.clientY - cy) / Math.max(r.height, 1)) * MAX_MOVE * dist;
        });
        if (!active) { active = true; rafId = requestAnimationFrame(tick); }
      });

      heading.addEventListener('mouseleave', () => {
        lines.forEach((_, i) => { state[i]!.tx = 0; state[i]!.ty = 0; });
        if (!active) { active = true; rafId = requestAnimationFrame(tick); }
      });
    }
  })();
</script>

<style>
  /* ── LOCAL FONT UTILITIES ───────────────────────────────── */
  .font-cinzel { font-family: 'Cinzel', Georgia, serif; }
  .m-italic    { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }

  /* ── SECTION SHELL ──────────────────────────────────────── */
  section {
    position: relative;
    padding-block: 10rem;
    background: var(--deep);
    overflow: hidden;
    z-index: var(--z-page);
  }

  /* ════════════════════════════════════════════════════════════
     INJECTION 1 — ANIMATED CONSTELLATION BACKGROUND
     ════════════════════════════════════════════════════════════ */

  /* ── Layer C: Nebula glows (z:1) ────────────────────────── */
  .m-nebula {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }
  .nb1 {
    width: 700px; height: 700px;
    top: -180px; right: -120px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.055) 0%, transparent 68%);
    animation: nebulaGlow 17s ease-in-out 0s infinite alternate;
  }
  .nb2 {
    width: 520px; height: 520px;
    top: 25%; left: -140px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.040) 0%, transparent 65%);
    animation: nebulaGlow 22s ease-in-out -8s infinite alternate;
  }
  .nb3 {
    width: 600px; height: 600px;
    bottom: -160px; right: 18%;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.045) 0%, transparent 66%);
    animation: nebulaGlow 19s ease-in-out -4s infinite alternate;
  }
  @keyframes nebulaGlow {
    from { opacity: 0.55; transform: scale(1);    }
    to   { opacity: 1.0;  transform: scale(1.12); }
  }

  /* ── Layer A: Star field (z:2) ──────────────────────────── */
  .m-stars {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .star {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    animation: starTwinkle var(--tw-dur, 5s) ease-in-out var(--tw-dly, 0s) infinite alternate;
  }
  @keyframes starTwinkle {
    from { opacity: var(--tw-min, 0.08); }
    to   { opacity: var(--tw-max, 0.30); }
  }

  /* ── Section vignette — keeps edges dark (z:3) ──────────── */
  .m-vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 20%, rgba(7, 8, 13, 0.60) 75%, rgba(3, 3, 8, 0.90) 100%);
  }

  /* ── Layer D: Constellation SVG (z:3) ───────────────────── */
  .m-constellation {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    pointer-events: none;
  }
  .const-alpha {
    transform-box: fill-box;
    transform-origin: center;
    animation: constCW 90s linear infinite;
  }
  .const-beta {
    transform-box: fill-box;
    transform-origin: center;
    animation: constCCW 120s linear infinite;
  }
  @keyframes constCW  { to { transform: rotate(360deg);  } }
  @keyframes constCCW { to { transform: rotate(-360deg); } }

  /* ── Layer B: Drifting cyan dust (z:4) ──────────────────── */
  .m-particles {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--signal-cyan);
    box-shadow: 0 0 4px rgba(0, 212, 255, 0.5);
    animation: particleDrift var(--dur, 13s) ease-in-out var(--delay, 0s) infinite alternate;
  }
  @keyframes particleDrift {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(calc(var(--dx) * 0.6), calc(var(--dy) * -0.4)); }
    50%  { transform: translate(var(--dx), var(--dy)); }
    75%  { transform: translate(calc(var(--dx) * 0.3), calc(var(--dy) * 0.8)); }
    100% { transform: translate(0, 0); }
  }

  /* ── Violet ambient glow (z:4) ──────────────────────────── */
  .m-glow {
    position: absolute;
    width: 700px; height: 700px;
    top: -80px; left: 15%;
    background: radial-gradient(ellipse at center, rgba(167, 139, 250, 0.055) 0%, transparent 70%);
    pointer-events: none;
    z-index: 4;
    animation: mGlow 18s ease-in-out infinite;
  }
  @keyframes mGlow {
    0%, 100% { transform: scale(1)   translate(0,   0);  }
    50%       { transform: scale(1.1) translate(3%, 5%); }
  }

  /* ── INJECTION 6: Roaming light leak (z:5) ──────────────── */
  /* Traverses corners of the section over 40s, barely visible   */
  .m-light-leak {
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    top: 50%; left: 50%;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.022) 0%, transparent 65%);
    pointer-events: none;
    z-index: 5;
    /* Transform: center the circle then move it corner to corner */
    animation: lightLeak 40s linear infinite;
  }
  @keyframes lightLeak {
    0%   { transform: translate(-350px, -350px) translate(-45vw, -40vh); }
    25%  { transform: translate(-350px, -350px) translate(45vw,  -40vh); }
    50%  { transform: translate(-350px, -350px) translate(45vw,   40vh); }
    75%  { transform: translate(-350px, -350px) translate(-45vw,  40vh); }
    100% { transform: translate(-350px, -350px) translate(-45vw, -40vh); }
  }

  /* ── INJECTION 1: Shooting star (z:6) ───────────────────── */
  .m-shooting-star {
    position: absolute;
    left: -140px;
    top: 25%;   /* overridden per-shot by JS */
    width: 140px;
    height: 2px;
    border-radius: 1px;
    background: linear-gradient(to right, transparent 0%, rgba(255, 255, 255, 0.85) 75%, transparent 100%);
    pointer-events: none;
    z-index: 6;
    opacity: 0;
    transform: rotate(-18deg);
  }
  .m-shooting-star.m-shooting {
    animation: shootAcross 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes shootAcross {
    0%   { transform: translateX(0)           rotate(-18deg); opacity: 0; }
    6%   { opacity: 1; }
    88%  { opacity: 0.85; }
    100% { transform: translateX(calc(100vw + 180px)) rotate(-18deg); opacity: 0; }
  }

  /* ═══════════════════════════════════════════════════════════
     CONTENT SYSTEM
     ═══════════════════════════════════════════════════════════ */

  /* ── Single-column container (z:8) ─────────────────────── */
  .m-container {
    position: relative;
    z-index: 8;
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: clamp(24px, 5vw, 80px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ── Eyebrow ────────────────────────────────────────────── */
  .m-eyebrow {
    font-size: 11px;
    letter-spacing: 0.4em;
    color: rgba(0, 212, 255, 0.65);
    text-transform: uppercase;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity  500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms,
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms;
  }
  .is-revealed .m-eyebrow { opacity: 1; transform: translateY(0); }

  /* ── INJECTION 2: Massive heading ───────────────────────── */
  .m-heading {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 64px;
    font-size: clamp(64px, 11vw, 168px);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.96);
    text-shadow: 0 0 80px rgba(0, 212, 255, 0.12);
    max-width: 1100px;
  }

  /* Entrance: starts invisible, translates up on reveal */
  .m-line {
    display: block;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity   700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .is-revealed .m-heading .m-line:nth-child(1) { transition-delay: 400ms; }
  .is-revealed .m-heading .m-line:nth-child(2) { transition-delay: 600ms; }
  .is-revealed .m-heading .m-line:nth-child(3) { transition-delay: 800ms; }
  .is-revealed .m-line { opacity: 1; transform: translateY(0); }

  /* EFFECT B: Idle breathing — applied after is-breathing class (set by JS at +2.2s)
     Negative delays start at midpoint (opacity:1) to avoid snap-on.
     Animation-delay is negative so it appears mid-breath when applied. */
  .is-breathing .m-line:nth-child(1) { animation: headingBreathe 7s ease-in-out -3.5s  infinite; }
  .is-breathing .m-line:nth-child(2) { animation: headingBreathe 9s ease-in-out -4.5s  infinite; }
  .is-breathing .m-line:nth-child(3) { animation: headingBreathe 6s ease-in-out -3.0s  infinite; }
  @keyframes headingBreathe {
    0%, 100% { opacity: 0.96; }
    50%       { opacity: 1.0;  }
  }

  /* EFFECT C: Italic "shouldn't" word — continuous cyan glow pulse */
  .m-italic {
    animation: italicGlow 4s ease-in-out infinite;
  }
  @keyframes italicGlow {
    0%, 100% { text-shadow: 0 0 28px rgba(0, 212, 255, 0.14); }
    50%       { text-shadow: 0 0 52px rgba(0, 212, 255, 0.38); }
  }

  /* ── INJECTION 3: Body — 5-paragraph editorial reveal + shimmer ── */
  .m-body {
    font-family: 'Geist', 'Helvetica Neue', sans-serif;
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    letter-spacing: -0.005em;
    max-width: 680px;
    margin-top: 64px;
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
