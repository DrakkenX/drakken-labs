---
---

<section id="showcase" aria-labelledby="showcase-heading">
  <div class="section-inner">
    <div class="section-header reveal">
      <p class="section-label font-mono">WORK</p>
      <h2 id="showcase-heading" class="section-title font-cinzel">
        What's Been Built
      </h2>
    </div>

    <div class="bento-grid">
      <!-- Main feature: AEGIS -->
      <article class="sacred-frame bento-main reveal" data-delay="100">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="aegis-visual" aria-hidden="true">
          <div class="aegis-orb"></div>
          <div class="aegis-ring ring-1"></div>
          <div class="aegis-ring ring-2"></div>
          <div class="aegis-ring ring-3"></div>
          <div class="aegis-scan"></div>
        </div>

        <div class="bento-main-content">
          <div class="bento-tag font-mono">DEFENSIVE INTELLIGENCE</div>
          <h3 class="bento-title font-cinzel">AEGIS</h3>
          <p class="bento-desc font-inter">
            Premium Windows security tool for civilian threat monitoring and evidence collection.
            Built for families facing targeted cyberattacks.
          </p>
          <div class="bento-stack font-mono">Tauri · Rust · Three.js · Claude API</div>
          <div class="bento-status">
            <span class="status-dot"></span>
            <span class="font-mono status-text">Private Testing</span>
          </div>
        </div>

        <div class="bento-classified font-mono">[CONFIDENTIAL · ALPHA-3]</div>
      </article>

      <!-- Stats -->
      <article class="sacred-frame bento-stats reveal" data-delay="160">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <p class="section-label font-mono">STUDIO STATS</p>
        <div class="stats-list">
          {[
            ['Projects shipped', '1'],
            ['Lines of code', '8,959'],
            ['Days to ship', '5'],
            ['Currently accepting', '2 slots'],
          ].map(([label, value]) => (
            <div class="stat-row">
              <span class="stat-label font-inter">{label}</span>
              <span class="stat-value font-mono">{value}</span>
            </div>
          ))}
        </div>
        <div class="availability-badge font-mono">
          <span class="avail-dot"></span>
          2 slots remaining this month
        </div>
      </article>

      <!-- Methodology -->
      <article class="sacred-frame bento-method reveal" data-delay="220">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="bento-tag font-mono">METHODOLOGY</div>
        <h3 class="bento-sub-title font-cinzel">AI Workflow System</h3>
        <p class="bento-desc font-inter">
          Memory-based development enabling 5–10× output velocity. Used to ship AEGIS in 5 days.
        </p>

        <div class="method-diagram" aria-hidden="true">
          <div class="method-node font-mono">MEMORY</div>
          <div class="method-arrow">→</div>
          <div class="method-node font-mono">AI</div>
          <div class="method-arrow">→</div>
          <div class="method-node font-mono">BUILD</div>
        </div>
      </article>

      <!-- Next frontier: MAVIS -->
      <article class="sacred-frame bento-next reveal" data-delay="280">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="bento-tag font-mono">NEXT FRONTIER</div>
        <h3 class="bento-sub-title font-cinzel">MAVIS</h3>
        <p class="bento-desc font-inter">
          Master AI orchestration ecosystem. Personal Jarvis, built right.
        </p>

        <div class="mavis-orb-wrapper" aria-hidden="true">
          <div class="mavis-orb"></div>
        </div>

        <div class="bento-stack font-mono">Status: In design · ETA Q3 2025</div>
      </article>
    </div>
  </div>
</section>

<style>
  section {
    padding: 7rem 2rem;
    background: var(--deep);
  }

  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-header { margin-bottom: 3.5rem; }
  .section-label { font-size: 0.65rem; letter-spacing: 0.3em; color: var(--text-tertiary); margin-bottom: 0.75rem; }
  .section-title { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 600; letter-spacing: 0.12em; color: var(--text-pure); }

  /* ── BENTO ────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--edge);
    border: 1px solid var(--edge);
  }

  /* AEGIS spans full width */
  .bento-main {
    grid-column: 1;
    grid-row: 1;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--mid);
    min-height: 360px;
    position: relative;
    overflow: hidden;
  }

  .bento-stats {
    grid-column: 2;
    grid-row: 1;
    padding: 2rem;
    background: var(--mid);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bento-method {
    grid-column: 1;
    grid-row: 2;
    padding: 2rem;
    background: var(--mid);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bento-next {
    grid-column: 2;
    grid-row: 2;
    padding: 2rem;
    background: var(--mid);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  /* ── AEGIS VISUAL ─────────────────────────────────── */
  .aegis-visual {
    position: relative;
    width: 100%;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aegis-orb {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #00d4ff, #0047a8);
    box-shadow: 0 0 20px rgba(0,212,255,0.4), 0 0 40px rgba(0,212,255,0.15);
    animation: orbPulse 3s ease-in-out infinite;
    position: relative;
    z-index: 2;
  }
  @keyframes orbPulse {
    0%,100% { transform: scale(1);   box-shadow: 0 0 20px rgba(0,212,255,0.4); }
    50%     { transform: scale(1.08); box-shadow: 0 0 30px rgba(0,212,255,0.6); }
  }

  .aegis-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(0,212,255,0.2);
    animation: ringExpand 3s ease-in-out infinite;
  }
  .ring-1 { width: 56px;  height: 56px;  animation-delay: 0s; }
  .ring-2 { width: 84px;  height: 84px;  animation-delay: 0.3s; }
  .ring-3 { width: 112px; height: 112px; animation-delay: 0.6s; }
  @keyframes ringExpand {
    0%,100% { opacity: 0.6; transform: scale(1); }
    50%     { opacity: 0.2; transform: scale(1.05); }
  }

  .aegis-scan {
    position: absolute;
    left: 50%;
    top: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(0,212,255,0.5), transparent);
    transform-origin: center;
    animation: scanLine 4s linear infinite;
  }
  @keyframes scanLine {
    from { transform: translateX(-50px) rotate(-15deg); opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    to   { transform: translateX(50px) rotate(15deg); opacity: 0; }
  }

  /* ── CONTENT ELEMENTS ─────────────────────────────── */
  .bento-tag {
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    color: var(--text-tertiary);
  }

  .bento-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--text-pure);
  }

  .bento-sub-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--text-pure);
  }

  .bento-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .bento-stack {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    margin-top: auto;
  }

  .bento-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal-amber);
    animation: dotBlink 2s ease-in-out infinite;
  }
  @keyframes dotBlink {
    0%,100% { opacity: 1; }
    50%     { opacity: 0.3; }
  }
  .status-text { font-size: 0.65rem; letter-spacing: 0.1em; color: var(--signal-amber); }

  .bento-classified {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--text-ghost);
  }

  /* Stats */
  .stats-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--edge);
  }
  .stat-label { font-size: 0.8rem; color: var(--text-secondary); }
  .stat-value { font-size: 0.8rem; letter-spacing: 0.08em; color: var(--signal-cyan); }

  .availability-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--signal-mint);
    margin-top: auto;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(74,222,128,0.2);
    background: rgba(74,222,128,0.04);
  }
  .avail-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--signal-mint);
    flex-shrink: 0;
  }

  /* Method diagram */
  .method-diagram {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1rem;
  }
  .method-node {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--signal-cyan);
    padding: 0.35rem 0.6rem;
    border: 1px solid rgba(0,212,255,0.25);
    background: rgba(0,212,255,0.04);
  }
  .method-arrow { font-size: 0.7rem; color: var(--text-ghost); }

  /* MAVIS orb */
  .mavis-orb-wrapper {
    display: flex;
    justify-content: flex-end;
    margin-top: auto;
  }
  .mavis-orb {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, rgba(167,139,250,0.8), rgba(50,30,120,0.6));
    box-shadow: 0 0 24px rgba(167,139,250,0.3);
    animation: mavisFloat 4s ease-in-out infinite;
  }
  @keyframes mavisFloat {
    0%,100% { transform: translateY(0); }
    50%     { transform: translateY(-6px); }
  }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 768px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bento-main,
    .bento-stats,
    .bento-method,
    .bento-next { grid-column: 1; grid-row: auto; }
  }
</style>
