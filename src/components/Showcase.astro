---
---

<section id="showcase" aria-labelledby="showcase-heading">

  <!-- Background -->
  <div class="section-bg showcase-bg" aria-hidden="true">
    <img src="/media/texture-2.jpg" alt="" class="section-bg-img" loading="lazy" decoding="async" width="1920" height="1080"/>
    <div class="section-bg-vignette"></div>
    <div class="section-bg-tint"></div>
  </div>

  <div class="section-inner">

    <!-- ─── TIER 1: HEADING ─────────────────────────────── -->
    <div class="sc-header reveal">
      <span class="sc-frame-label font-mono">[ SHOWCASE · FIELD-TESTED ]</span>
      <h2 id="showcase-heading" class="sc-heading">
        What's Been <em class="sc-italic">Built</em>
      </h2>
      <span class="sc-sub-label font-mono">[ ONE SHIPPED · ONE LIVE · ONE IN ARCHITECTURE ]</span>
    </div>

    <!-- ─── TIER 2: AEGIS HERO TILE ──────────────────────── -->
    <article class="aegis-hero sacred-frame" id="aegis-hero-tile" aria-label="AEGIS — Shipped Project">
      <span class="corner-tl"></span><span class="corner-tr"></span>
      <span class="corner-bl"></span><span class="corner-br"></span>

      <!-- LEFT: Content 58% -->
      <div class="aegis-left">

        <div class="status-pill font-mono">
          <span class="status-dot" aria-hidden="true"></span>
          LIVE · DEPLOYED
        </div>

        <div class="aegis-nameblock">
          <h3 class="aegis-name font-cinzel">AEGIS</h3>
          <p class="aegis-tagline sc-italic">Sentinel Defense Grid</p>
        </div>

        <p class="aegis-desc">
          Civilian-grade cyber defense for Windows. Three-layer honeypot,
          attacker fingerprinting, evidence-grade forensics. Built in 5 days
          for families targeted by state-level threat actors.
        </p>

        <div class="aegis-stat-strip">
          <div class="aegis-stat">
            <span class="as-label font-mono">LINES OF CODE</span>
            <span class="as-value" data-count-to="8959">0</span>
            <span class="as-sub font-mono">PRODUCTION READY</span>
          </div>
          <div class="as-sep" aria-hidden="true"></div>
          <div class="aegis-stat">
            <span class="as-label font-mono">BUILD WINDOW</span>
            <span class="as-value">5 DAYS</span>
            <span class="as-sub font-mono">MAY 14–18, 2025</span>
          </div>
          <div class="as-sep" aria-hidden="true"></div>
          <div class="aegis-stat">
            <span class="as-label font-mono">STATUS</span>
            <span class="as-value">v1.0</span>
            <span class="as-sub font-mono">SHIPPED &amp; INSTALLED</span>
          </div>
        </div>

        <div class="aegis-ctas">
          <a href="#aegis-detail" class="cta-primary font-mono">VIEW CASE STUDY →</a>
          <a href="#contact" class="cta-secondary font-mono">REQUEST DEMO</a>
        </div>

      </div>

      <!-- RIGHT: Shield Visualization 42% -->
      <div class="aegis-right" aria-hidden="true">
        <div class="shield-viz" id="shield-viz">

          <!-- L5: Pulse pings (rendered behind SVG) -->
          <div class="pulse-ping pp1"></div>
          <div class="pulse-ping pp2"></div>
          <div class="pulse-ping pp3"></div>

          <!-- Main SVG: rings, octagon, scan line -->
          <svg class="shield-svg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="scanGradH" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#00d4ff" stop-opacity="0"/>
                <stop offset="50%" stop-color="#00d4ff" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#00d4ff" stop-opacity="0"/>
              </linearGradient>
              <clipPath id="outerRingClip">
                <circle cx="150" cy="150" r="138"/>
              </clipPath>
              <filter id="softGlow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
              <filter id="octGlow" x="-25%" y="-25%" width="150%" height="150%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>

            <!-- L1: Outer rotating ring (dashed, tick marks at N/S/E/W) -->
            <g class="ring-outer-g">
              <circle cx="150" cy="150" r="136" fill="none" stroke="#00d4ff"
                stroke-width="1" stroke-dasharray="3 11" opacity="0.65"/>
              <line x1="150" y1="14"  x2="150" y2="26"  stroke="#00d4ff" stroke-width="1.5" opacity="0.7"/>
              <line x1="150" y1="274" x2="150" y2="286" stroke="#00d4ff" stroke-width="1.5" opacity="0.7"/>
              <line x1="14"  y1="150" x2="26"  y2="150" stroke="#00d4ff" stroke-width="1.5" opacity="0.7"/>
              <line x1="274" y1="150" x2="286" y2="150" stroke="#00d4ff" stroke-width="1.5" opacity="0.7"/>
            </g>

            <!-- L2: Middle counter-rotating ring -->
            <circle cx="150" cy="150" r="108" fill="none" stroke="#a78bfa"
              stroke-width="1" opacity="0.5" class="ring-mid-el"/>

            <!-- L3: Inner octagon (static) — radius 68 from center -->
            <polygon
              points="150,82 198,102 218,150 198,198 150,218 102,198 82,150 102,102"
              fill="rgba(0,212,255,0.04)"
              stroke="#00d4ff"
              stroke-width="2"
              filter="url(#octGlow)"/>
            <!-- Top triangle -->
            <polygon points="150,100 159,117 141,117"
              fill="none" stroke="#00d4ff" stroke-width="1.5" opacity="0.85"/>
            <!-- Center A -->
            <text x="150" y="170" text-anchor="middle"
              font-family="Cinzel, Georgia, serif"
              font-size="40" font-weight="400"
              fill="#00d4ff" opacity="0.92"
              filter="url(#softGlow)">A</text>
            <!-- Bottom inverted triangle -->
            <polygon points="150,197 159,180 141,180"
              fill="none" stroke="#00d4ff" stroke-width="1.5" opacity="0.85"/>

            <!-- L4: Scan line — horizontal, sweeps top→bottom, clipped to outer ring -->
            <rect x="12" y="-1" width="276" height="2"
              fill="url(#scanGradH)"
              clip-path="url(#outerRingClip)"
              class="scan-line-el"
              filter="url(#softGlow)"/>
          </svg>

          <!-- L6: Orbital dots (CSS positioned, counter-rotate to keep labels upright) -->
          <div class="orbit-spinner os1">
            <div class="orbit-counter oc1">
              <div class="orbit-dot-el"></div>
              <span class="orbit-label font-mono">HONEYPOT · ACTIVE</span>
            </div>
          </div>
          <div class="orbit-spinner os2">
            <div class="orbit-counter oc2">
              <div class="orbit-dot-el"></div>
              <span class="orbit-label font-mono">EVIDENCE · LOGGING</span>
            </div>
          </div>
          <div class="orbit-spinner os3">
            <div class="orbit-counter oc3">
              <div class="orbit-dot-el"></div>
              <span class="orbit-label font-mono">BSOD · MONITORING</span>
            </div>
          </div>

          <!-- L7: Data strip (CSS-cycled telemetry) -->
          <div class="shield-data-strip font-mono" aria-live="polite" aria-atomic="true">
            <span class="data-line dl1">PORT_2222: LISTENING | PORT_2323: LISTENING | DECOY_FILES: 47</span>
            <span class="data-line dl2">ARP_SCAN: 12 NODES | SHA-256 CHAIN: VALID</span>
            <span class="data-line dl3">UPTIME: 99.97% | LAST EVENT: T-00:00:14</span>
          </div>

        </div>
      </div>

    </article>

    <!-- ─── TIER 3: SUPPORTING CARDS ─────────────────────── -->
    <div class="support-row">

      <!-- Card A: Drakken Labs Site -->
      <article class="support-card card-drakken sacred-frame reveal" data-delay="140"
        aria-label="Drakken Labs — Live Site">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="card-inner">
          <div class="support-tag font-mono" style="color:var(--signal-cyan)">
            <span class="tag-bracket">[</span>&nbsp;LIVE&nbsp;<span class="tag-bracket">]</span>
          </div>
          <h3 class="support-title font-cinzel">DRAKKEN LABS</h3>
          <p class="support-sub">This site you're reading</p>
          <p class="support-desc">
            Built in 1 day. Astro + Three.js + Motion One.<br/>
            AI-leveraged frontend craft.
          </p>
          <p class="support-stats font-mono">1,400+ LOC · 60 FPS · ASTRO 4</p>
        </div>

        <div class="kanji-mark font-cinzel" aria-hidden="true">守</div>
      </article>

      <!-- Card B: MAVIS -->
      <article class="support-card card-mavis sacred-frame reveal" data-delay="200"
        aria-label="MAVIS — In Architecture">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="mavis-construction" aria-hidden="true"></div>

        <div class="card-inner">
          <div class="support-tag font-mono" style="color:var(--signal-amber)">
            <span class="tag-bracket">[</span>&nbsp;IN ARCHITECTURE&nbsp;<span class="tag-bracket">]</span>
          </div>
          <h3 class="support-title font-cinzel mavis-dim">MAVIS</h3>
          <p class="support-sub">Personal AI Companion</p>
          <p class="support-desc">
            The orchestrator. Memory-first. Voice-driven.<br/>
            Currently in architecture phase.
          </p>
          <p class="support-stats font-mono" style="color:var(--signal-amber)">
            DESIGN PHASE · Q3 2025 TARGET
          </p>
        </div>

        <div class="mavis-lock" aria-hidden="true">
          <svg width="14" height="16" viewBox="0 0 14 16" fill="none">
            <rect x="1" y="7" width="12" height="8" rx="1.5"
              stroke="rgba(251,191,36,0.45)" stroke-width="1.2"/>
            <path d="M4 7V5a3 3 0 016 0v2"
              stroke="rgba(251,191,36,0.45)" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
      </article>

    </div>

    <!-- ─── STUDIO STATS STRIP ────────────────────────────── -->
    <div class="studio-strip reveal" data-delay="260">
      <div class="ss-metric">
        <span class="ss-label font-mono">PROJECTS SHIPPED</span>
        <span class="ss-value">1</span>
      </div>
      <div class="ss-sep" aria-hidden="true"></div>
      <div class="ss-metric">
        <span class="ss-label font-mono">LINES THIS YEAR</span>
        <span class="ss-value">8,959</span>
      </div>
      <div class="ss-sep" aria-hidden="true"></div>
      <div class="ss-metric">
        <span class="ss-label font-mono">STACK PRIMARY</span>
        <span class="ss-value">TAURI · RUST · AI</span>
      </div>
      <div class="ss-sep" aria-hidden="true"></div>
      <div class="ss-metric">
        <span class="ss-label font-mono">STUDIO BIRTHED</span>
        <span class="ss-value">MMXXV</span>
      </div>
      <div class="ss-sep" aria-hidden="true"></div>
      <div class="ss-metric">
        <span class="ss-label font-mono">STATUS</span>
        <span class="ss-value" style="color:var(--signal-mint)">ACCEPTING WORK</span>
      </div>
    </div>

  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('showcase');
    const heroTile = document.getElementById('aegis-hero-tile');
    const shieldViz = document.getElementById('shield-viz');
    if (!section) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function easeOutExpo(t: number): number {
      return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
    }

    function countUp(el: HTMLElement, target: number, duration: number, delay: number) {
      setTimeout(() => {
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          el.textContent = Math.round(easeOutExpo(t) * target).toLocaleString();
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = target.toLocaleString();
        };
        requestAnimationFrame(tick);
      }, delay);
    }

    let activated = false;

    function activate() {
      if (activated) return;
      activated = true;

      // Stagger in AEGIS hero
      if (heroTile) {
        heroTile.classList.add('hero-visible');
      }

      // Start shield animations after 600ms
      if (shieldViz && !prefersReduced) {
        setTimeout(() => shieldViz.classList.add('shield-active'), 600);
      } else if (shieldViz) {
        shieldViz.classList.add('shield-active');
      }

      // Count up AEGIS stat
      const countEl = section.querySelector<HTMLElement>('[data-count-to="8959"]');
      if (countEl && !prefersReduced) {
        countUp(countEl, 8959, 600, 1500);
      } else if (countEl) {
        countEl.textContent = '8,959';
      }
    }

    if (prefersReduced) {
      // Snap to final state immediately
      activate();
      return;
    }

    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          activate();
          obs.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    obs.observe(section);

    // Background parallax
    const bgImg = document.querySelector<HTMLElement>('.showcase-bg .section-bg-img');
    if (bgImg && !window.matchMedia('(max-width: 768px)').matches) {
      const loadParallax = async () => {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);
        gsap.to(bgImg, {
          yPercent: -40,
          ease: 'none',
          scrollTrigger: {
            trigger: '#showcase',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      };
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(loadParallax, { timeout: 3000 });
      } else {
        setTimeout(loadParallax, 600);
      }
    }
  })();
</script>

<style>
  /* ── SECTION BASE ─────────────────────────────────────── */
  section {
    padding: 8rem 2rem;
    background: var(--deep);
    position: relative;
    z-index: var(--z-page);
    overflow: hidden;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── SECTION BACKGROUND ───────────────────────────────── */
  .section-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .section-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.3) saturate(0.7);
    will-change: transform;
  }
  .section-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, transparent 30%, #07080d 85%);
  }
  .section-bg-tint {
    position: absolute;
    inset: 0;
    background: rgba(0,212,255,0.04);
  }

  /* ── TIER 1: HEADING ──────────────────────────────────── */
  .sc-header {
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }
  .sc-frame-label {
    font-size: 0.6875rem;
    letter-spacing: 0.32em;
    color: var(--signal-cyan);
    opacity: 0.9;
  }
  .sc-heading {
    font-size: clamp(2.5rem, 7vw, 5.25rem);
    line-height: 1;
    color: var(--text-pure);
    letter-spacing: -0.01em;
    font-weight: 400;
  }
  .sc-italic {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
  }
  .sc-sub-label {
    font-size: 0.625rem;
    letter-spacing: 0.32em;
    color: rgba(255,255,255,0.4);
    margin-top: 0.25rem;
  }

  /* ── TIER 2: AEGIS HERO TILE ──────────────────────────── */
  .aegis-hero {
    display: grid;
    grid-template-columns: 58% 42%;
    min-height: 480px;
    background: var(--mid);
    border: 1px solid var(--edge);
    position: relative;
    overflow: hidden;
    margin-bottom: 1px;

    /* Entrance: starts hidden, transitions in via hero-visible class */
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 800ms cubic-bezier(0.23, 1, 0.32, 1) 200ms,
      transform 800ms cubic-bezier(0.23, 1, 0.32, 1) 200ms;
  }
  .aegis-hero.hero-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── LEFT SIDE ────────────────────────────────────────── */
  .aegis-left {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-right: 1px solid var(--edge);
    position: relative;
    z-index: 1;
  }

  /* Status pill */
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(0,212,255,0.08);
    border: 1px solid rgba(0,212,255,0.3);
    border-radius: 9999px;
    padding: 0.375rem 1rem;
    width: fit-content;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    color: var(--signal-cyan);

    opacity: 0;
    transform: translateY(10px);
    transition: opacity 400ms ease 900ms, transform 400ms ease 900ms;
  }
  .aegis-hero.hero-visible .status-pill {
    opacity: 1;
    transform: translateY(0);
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal-cyan);
    flex-shrink: 0;
    animation: statusPulse 1.5s ease-in-out infinite;
  }
  @keyframes statusPulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.35; transform: scale(0.8); }
  }

  /* Name block */
  .aegis-nameblock {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;

    opacity: 0;
    transform: translateY(12px);
    transition: opacity 500ms ease 1020ms, transform 500ms ease 1020ms;
  }
  .aegis-hero.hero-visible .aegis-nameblock {
    opacity: 1;
    transform: translateY(0);
  }
  .aegis-name {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--text-pure);
    line-height: 1;
    text-shadow: 0 0 50px rgba(0,212,255,0.2);
  }
  .aegis-tagline {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 1.375rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.3;
  }

  /* Description */
  .aegis-desc {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    max-width: 460px;

    opacity: 0;
    transform: translateY(10px);
    transition: opacity 500ms ease 1140ms, transform 500ms ease 1140ms;
  }
  .aegis-hero.hero-visible .aegis-desc {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stat strip */
  .aegis-stat-strip {
    display: flex;
    border: 1px solid var(--edge);
    background: var(--deep);
    flex-shrink: 0;

    opacity: 0;
    transform: translateY(10px);
    transition: opacity 500ms ease 1260ms, transform 500ms ease 1260ms;
  }
  .aegis-hero.hero-visible .aegis-stat-strip {
    opacity: 1;
    transform: translateY(0);
  }
  .aegis-stat {
    flex: 1;
    padding: 0.875rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .as-sep {
    width: 1px;
    background: var(--edge);
    flex-shrink: 0;
  }
  .as-label {
    font-size: 0.5625rem;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
  }
  .as-value {
    font-family: 'Outfit', 'Helvetica Neue', sans-serif;
    font-size: 1.75rem;
    color: var(--text-pure);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .as-sub {
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--signal-cyan);
    opacity: 0.6;
  }

  /* CTAs */
  .aegis-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;

    opacity: 0;
    transform: translateY(10px);
    transition: opacity 500ms ease 1800ms, transform 500ms ease 1800ms;
  }
  .aegis-hero.hero-visible .aegis-ctas {
    opacity: 1;
    transform: translateY(0);
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    color: var(--signal-cyan);
    text-decoration: none;
    padding: 0.5rem 1.125rem;
    border: 1px solid rgba(0,212,255,0.35);
    border-radius: 9999px;
    background: rgba(0,212,255,0.06);
    transition:
      color 200ms ease,
      border-color 200ms ease,
      background 200ms ease,
      transform 160ms ease;
  }
  .cta-primary:hover {
    color: #fff;
    border-color: rgba(0,212,255,0.7);
    background: rgba(0,212,255,0.12);
    transform: translateX(2px);
  }
  .cta-primary:active { transform: scale(0.97); }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    padding: 0.5rem 1.125rem;
    border: 1px solid var(--edge);
    border-radius: 9999px;
    transition:
      color 200ms ease,
      border-color 200ms ease,
      transform 160ms ease;
  }
  .cta-secondary:hover {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.3);
    transform: translateX(2px);
  }
  .cta-secondary:active { transform: scale(0.97); }

  /* ── RIGHT SIDE / SHIELD VIZ ──────────────────────────── */
  .aegis-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .shield-viz {
    position: relative;
    width: 300px;
    height: 360px;
    flex-shrink: 0;
  }

  /* SVG fills top 300px of the container */
  .shield-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 300px;
    height: 300px;
    overflow: visible;
  }

  /* ── LAYER 1: Outer ring rotation ─────────────────────── */
