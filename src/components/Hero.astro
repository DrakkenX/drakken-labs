---
---

<section id="hero" aria-label="Drakken Labs" data-animate="false">

  <!-- VIDEO BACKGROUND — deepest layer -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/media/hero-atmosphere.mp4"
      autoplay muted loop playsinline preload="metadata"
    ></video>
    <div class="hero-video-vignette"></div>
    <div class="hero-video-grain"></div>
  </div>

  <!-- ────────────────────────────────────────────────────── -->
  <!-- DRAKKEN LOGOMARK — single designed SVG, no effect pile -->
  <!-- ────────────────────────────────────────────────────── -->
  <!--
    Geometry: 8-point X-star (4 arm tips at diagonals + 4 notch waist
    points at cardinals). fill-rule="evenodd" + inner 8-point void creates
    the layered depth. Reads as crown / blade / wings simultaneously.
    Slow 120s rotation + 8s opacity breathe. One mark, atmospheric.
  -->
  <svg
    class="drakken-logomark"
    aria-hidden="true"
    viewBox="0 0 800 800"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <!-- Cyan gradient: light ice → signal cyan → bright aqua -->
      <linearGradient id="lm-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%"   stop-color="#e8f7ff" stop-opacity="1"/>
        <stop offset="48%"  stop-color="#00d4ff" stop-opacity="1"/>
        <stop offset="100%" stop-color="#7ae8ff" stop-opacity="1"/>
      </linearGradient>
      <!-- Outer glow filter — soft, wide -->
      <filter id="lm-glow" x="-35%" y="-35%" width="170%" height="170%">
        <feGaussianBlur stdDeviation="10" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>

    <!--
      OUTER X STAR (8 vertices):
        NE tip (640,160) · N notch (400,280) · NW tip (160,160)
        W notch (280,400) · SW tip (160,640) · S notch (400,520)
        SE tip (640,640) · E notch (520,400)

      INNER VOID STAR (8 vertices, r=70 / notch=26):
        Creates the center negative-space that gives the mark depth.

      fill-rule="evenodd" punches the void through the outer shape.
    -->
    <path
      class="lm-shape"
      fill="url(#lm-grad)"
      fill-rule="evenodd"
      filter="url(#lm-glow)"
      d="
        M 640,160 L 400,280 L 160,160 L 280,400
        L 160,640 L 400,520 L 640,640 L 520,400 Z
        M 449,351 L 400,374 L 351,351 L 374,400
        L 351,449 L 400,426 L 449,449 L 426,400 Z
      "
    />
  </svg>

  <!-- LAYER 6: BLADE FLASH — idle sweep every 8s -->
  <div class="blade-flash" aria-hidden="true"></div>

  <!-- Viewport corner ticks -->
  <div class="viewport-corner tl" aria-hidden="true"></div>
  <div class="viewport-corner tr" aria-hidden="true"></div>
  <div class="viewport-corner bl" aria-hidden="true"></div>
  <div class="viewport-corner br" aria-hidden="true"></div>

  <!-- Aurora atmosphere -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-1"></div>
    <div class="aurora-2"></div>
    <div class="aurora-3"></div>
  </div>

  <!-- Vertical light beam + shimmer -->
  <div class="hero-beam" aria-hidden="true">
    <div class="beam-shimmer"></div>
  </div>

  <!-- ─────────────────────────────────────────────── -->
  <!-- MAIN CONTENT — LAYER 2 + 4 + 5 live here       -->
  <!-- ─────────────────────────────────────────────── -->
  <div class="hero-content" data-parallax="8">

    <!-- LAYER 2: WORDMARK — cyan flash then white settle, per letter
         Each span: ::before = cyan overlay (flashes, then fades)
                    base     = white letter (fades in at 60% of animation)
         Approach: content: attr(data-letter) on ::before — no JS needed.
    -->
    <h1 class="drakken-wordmark font-cinzel" aria-label="DRAKKEN">
      <span data-letter="D" style="--i:0">D</span><span
        data-letter="R" style="--i:1">R</span><span
        data-letter="A" style="--i:2">A</span><span
        data-letter="K" style="--i:3">K</span><span
        data-letter="K" style="--i:4">K</span><span
        data-letter="E" style="--i:5">E</span><span
        data-letter="N" style="--i:6">N</span>
    </h1>

    <p class="hero-name font-inter">Han Myo Naing</p>

    <p class="hero-tagline font-mono">
      <span class="tl-seg">AI-NATIVE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">SOFTWARE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">STUDIO</span>
    </p>

    <p class="hero-sub font-inter">
      Built in Malaysia&thinsp;·&thinsp;Operating worldwide
    </p>

    <!-- LAYER 4: SIGNATURE QUOTE LINE -->
    <div class="hero-quote" data-parallax="4" aria-label="Drakken Manifesto">
      <div class="quote-line" aria-hidden="true"></div>
      <p class="quote-text font-serif">"We build what defends."</p>
      <span class="quote-attr font-mono">— DRAKKEN MANIFESTO</span>
    </div>

    <!-- LAYER 5: SLASH-IN CTAs -->
    <div class="hero-actions">
      <a href="#contact" class="btn-primary font-inter hero-cta" style="--ci:0">
        Start a Project
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class="btn-ghost font-inter hero-cta" style="--ci:1">
        Manifesto
        <span class="btn-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

  <!-- LAYER 8: SCROLL PROMPT — traveling dot -->
  <div class="hero-scroll-prompt" aria-hidden="true">
    <span class="scroll-label font-mono">SCROLL</span>
    <div class="scroll-track">
      <div class="scroll-dot"></div>
    </div>
  </div>

</section>

<!-- ──────────────────────────────────────────────────────── -->
<!--  JS — animation timing + mouse parallax                  -->
<!-- ──────────────────────────────────────────────────────── -->
<script>
  (() => {
    const hero = document.getElementById('hero') as HTMLElement | null;
    if (!hero) return;

    // ── Trigger animations after loader exits (or immediately) ──
    function startAnimations() {
      hero!.dataset['animate'] = 'true';
    }

    const loader = document.getElementById('cinematic-loader');
    if (!loader || loader.style.display === 'none' || !loader.parentElement) {
      // No loader (repeat visit or direct) — 600ms grace for render + compositing
      setTimeout(startAnimations, 600);
    } else {
      // Watch for loader curtain to finish, then wait 600ms before revealing
      const obs = new MutationObserver(() => {
        if (loader.style.display === 'none') {
          // Loader's curtain split takes ~600ms — wait for it to fully exit
          setTimeout(startAnimations, 600);
          obs.disconnect();
        }
      });
      obs.observe(loader, { attributes: true, attributeFilter: ['style'] });
    }

    // ── Mouse parallax ──────────────────────────────────────
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;

    const parallaxEls = hero.querySelectorAll<HTMLElement>('[data-parallax]');
    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    let rafId: number;
    let isHovered = false;

    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      // Normalized -1 to 1 from center
      targetX = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
      targetY = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
      isHovered = true;
    });

    hero.addEventListener('mouseleave', () => {
      targetX = 0;
      targetY = 0;
      isHovered = false;
    });

    function animateParallax() {
      rafId = requestAnimationFrame(animateParallax);

      // Damp toward target (Emil Kowalski spring feel)
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      // Skip if movement negligible
      if (Math.abs(currentX) < 0.0005 && Math.abs(currentY) < 0.0005 && !isHovered) return;

      parallaxEls.forEach((el) => {
        const strength = parseFloat(el.dataset['parallax'] ?? '8');
        const tx = currentX * strength;
        const ty = currentY * strength;
        el.style.transform = `translate(${tx}px, ${ty}px)`;
      });
    }

    animateParallax();

    // ── Scroll prompt fade on scroll ────────────────────────
    const scrollPrompt = hero.querySelector<HTMLElement>('.hero-scroll-prompt');
    if (scrollPrompt) {
      window.addEventListener('scroll', () => {
        const gone = window.scrollY > 80;
        scrollPrompt.style.opacity = gone ? '0' : '';
        scrollPrompt.style.pointerEvents = gone ? 'none' : '';
      }, { passive: true });
    }

  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     BASE SECTION
     ═══════════════════════════════════════════════════════ */
  section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--void);
    z-index: var(--z-page);
  }

  /* ── VIDEO BG ──────────────────────────────────────────── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: blur(2px) brightness(0.6) saturate(1.2);
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, #030308 90%);
  }

  .hero-video-grain {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  @media (max-width: 768px) {
    .hero-video { display: none; }
    .hero-video-bg {
      background: radial-gradient(ellipse at 50% 30%, rgba(0,212,255,0.08), transparent 65%);
    }
  }

  /* ═══════════════════════════════════════════════════════
     DRAKKEN LOGOMARK — one mark, atmospheric
     8-point X-star (outer bold) + 8-point void (inner depth).
     120s slow rotation + 8s opacity/glow breathe.
     ═══════════════════════════════════════════════════════ */
  .drakken-logomark {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Base: positioned + offset. Animation keyframes carry this
       translate so the mark stays put during rotation.          */
    transform: translate(calc(-50% + 8vw), -50%);
    width: clamp(380px, 60vh, 720px);
    height: clamp(380px, 60vh, 720px);
    pointer-events: none;
    user-select: none;
    z-index: 2;
    opacity: 0;   /* hidden until data-animate fires */
    will-change: transform, opacity;
  }

  /* Fade in → then rotation + breathe take over their properties */
  section[data-animate="true"] .drakken-logomark {
    animation:
      lmFadeIn  2.0s cubic-bezier(0, 0, 0.38, 0.9) 0.5s  forwards,
      lmRotate  120s linear                         2.5s  infinite,
      lmBreathe 8s   ease-in-out                    2.5s  infinite;
  }

  /* Opacity: 0 → 0.18 (one-shot, holds via forwards fill)          */
  @keyframes lmFadeIn {
    from { opacity: 0;    }
    to   { opacity: 0.18; }
  }

  /* Rotation: full 360deg over 120s, carrying the centering translate */
  @keyframes lmRotate {
    from { transform: translate(calc(-50% + 8vw), -50%) rotate(0deg);   }
    to   { transform: translate(calc(-50% + 8vw), -50%) rotate(360deg); }
  }

  /* Breathe: opacity 0.18 ↔ 0.24 + glow expansion over 8s          */
  /* lmBreathe listed last → wins over lmFadeIn's opacity after 2.5s */
  @keyframes lmBreathe {
    0%, 100% {
      opacity: 0.18;
      filter: drop-shadow(0 0 55px rgba(0, 212, 255, 0.28));
    }
    50% {
      opacity: 0.24;
      filter: drop-shadow(0 0 90px rgba(0, 212, 255, 0.44));
    }
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 6 — BLADE FLASH (idle, pure CSS)
     ═══════════════════════════════════════════════════════ */
  .blade-flash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }

  /* Blade flash: position:fixed escapes all overflow:hidden clipping.
     White streak is more visible on dark backgrounds than cyan.      */
  .blade-flash::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 480px;
    height: 100vh;
    /* White core + cyan glow wings — high visibility on dark bg */
    background: linear-gradient(
      108deg,
      transparent               0%,
      transparent              30%,
      rgba(0,  212, 255, 0.08) 38%,
      rgba(255, 255, 255, 0.35) 46%,
      rgba(255, 255, 255, 0.50) 50%,
      rgba(255, 255, 255, 0.35) 54%,
      rgba(0,  212, 255, 0.08) 62%,
      transparent              70%,
      transparent             100%
    );
    box-shadow: 0 0 80px rgba(0, 212, 255, 0.6);
    filter: blur(0.5px) brightness(1.3);
    opacity: 0;
    pointer-events: none;
    z-index: 50;
    animation: none; /* gated — no fire until data-animate="true" */
  }

  /* Gate: flash only after the hero entrance sequence is complete */
  section[data-animate="true"] .blade-flash::after {
    animation: bladeFlash 6s cubic-bezier(0.2, 0.6, 0.3, 1) 5.0s infinite;
  }

  @keyframes bladeFlash {
    /* 0-23% ≈ 1.38s: katana slash top-left → bottom-right across full viewport */
    0%    { transform: translate(-30vw, -20vh); opacity: 0;   }
    5%    {                                     opacity: 1;   }
    20%   {                                     opacity: 0.7; }
    23%   { transform: translate(130vw, 120vh); opacity: 0;   }
    /* 23-100%: waiting for next 6s cycle */
    24%, 100% { transform: translate(130vw, 120vh); opacity: 0; }
  }

  /* ─────────────────────────────────────────────────────── */
  /* AURORA                                                   */
  /* ─────────────────────────────────────────────────────── */
  .hero-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .aurora-1 {
    position: absolute;
    width: 900px; height: 900px;
    top: -200px; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(0,212,255,0.13) 0%, rgba(0,212,255,0.04) 40%, transparent 72%);
    filter: blur(40px);
    animation: auraPulse 8s ease-in-out infinite;
  }

  .aurora-2 {
    position: absolute;
    width: 500px; height: 500px;
    bottom: 10%; left: -5%;
    background: radial-gradient(ellipse at center, rgba(167,139,250,0.08) 0%, transparent 70%);
    animation: auraDrift2 17s ease-in-out infinite;
  }

  .aurora-3 {
    position: absolute;
    width: 400px; height: 400px;
    top: -5%; right: 5%;
    background: radial-gradient(ellipse at center, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: auraDrift3 21s ease-in-out infinite;
  }

  @keyframes auraPulse {
    0%,100% { opacity: 1;    transform: translateX(-50%) scale(1);    }
    50%     { opacity: 0.75; transform: translateX(-50%) scale(1.08); }
  }
  @keyframes auraDrift2 {
    0%,100% { transform: translate(0,0) scale(1);   }
    50%     { transform: translate(4%,8%) scale(1.1); }
  }
  @keyframes auraDrift3 {
    0%,100% { transform: translate(0,0) scale(1.05);  }
    50%     { transform: translate(-5%,6%) scale(0.95); }
  }

  /* ─────────────────────────────────────────────────────── */
  /* LIGHT BEAM + SHIMMER                                     */
  /* ─────────────────────────────────────────────────────── */
  .hero-beam {
    position: absolute;
    left: 50%; top: 0;
    width: 1.5px; height: 60%;
    transform: translateX(-50%) scaleY(0);
    transform-origin: top center;
    background: linear-gradient(to bottom, rgba(0,212,255,0.7) 0%, rgba(0,212,255,0.12) 80%, transparent 100%);
    box-shadow: 0 0 8px rgba(0,212,255,0.35);
    z-index: 2;
    overflow: hidden;
  }

  section[data-animate="true"] .hero-beam {
    animation: beamDrop 0.6s cubic-bezier(0.16,1,0.3,1) 0.3s both;
  }

  @keyframes beamDrop {
    from { transform: translateX(-50%) scaleY(0); }
    to   { transform: translateX(-50%) scaleY(1); }
  }

  .beam-shimmer {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 200px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.6), transparent);
    animation: beamShimmer 12s cubic-bezier(0.4,0,0.2,1) 2s infinite;
    opacity: 0;
  }

  @keyframes beamShimmer {
    0%   { transform: translateY(-100%); opacity: 0; }
    8%   { opacity: 1; }
    92%  { opacity: 1; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  /* ═══════════════════════════════════════════════════════
     HERO CONTENT WRAPPER (Layer 2, 4, 5)
     ═══════════════════════════════════════════════════════ */
  .hero-content {
    position: relative;
    z-index: 4;
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 900px;
    width: 100%;
    will-change: transform;
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 2 — SVG STROKE-DRAW WORDMARK
     ═══════════════════════════════════════════════════════ */
  .hero-title-wrap {
    position: relative;
    margin-bottom: 1.1rem;
    line-height: 1;
    display: block;
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 2 — DRAKKEN WORDMARK: CYAN FLASH → WHITE SETTLE
     Per-letter: ::before = cyan overlay (1→0 opacity = flash)
                 base     = white letter (0→1 opacity = settle)
     Stagger: 200ms between letters. Total reveal: ~2500ms.
     ═══════════════════════════════════════════════════════ */
  .drakken-wordmark {
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1;
    user-select: none;
    white-space: nowrap;
    text-align: center;
    display: block;
    margin-bottom: 1.1rem;
    text-shadow:
      0 0 40px rgba(0, 212, 255, 0.15),
      0 0 80px rgba(0, 212, 255, 0.08);
  }

  .drakken-wordmark span {
    position: relative;
    display: inline-block;
    color: var(--text-pure);
    opacity: 0;
  }

  /* Cyan flash overlay — uses the data-letter attribute as content */
  .drakken-wordmark span::before {
    content: attr(data-letter);
    position: absolute;
    inset: 0;
    color: #00d4ff;
    text-shadow:
      0 0 20px rgba(0, 212, 255, 0.9),
      0 0 40px rgba(0, 212, 255, 0.5);
    opacity: 0;
    pointer-events: none;
  }

  /* Base letter: invisible → white (starts at 60% of 1000ms = 600ms in) */
  section[data-animate="true"] .drakken-wordmark span {
    animation: letterBase 1000ms cubic-bezier(0.2, 0.8, 0.2, 1)
               calc(var(--i) * 200ms + 300ms) both;
  }

  /* Cyan flash: invisible → cyan → invisible (peaks at 40-60%) */
  section[data-animate="true"] .drakken-wordmark span::before {
    animation: letterFlash 1000ms cubic-bezier(0.2, 0.8, 0.2, 1)
               calc(var(--i) * 200ms + 300ms) both;
  }

  @keyframes letterBase {
    0%   { opacity: 0; }
    60%  { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes letterFlash {
    0%   { opacity: 0; }
    40%  { opacity: 1; }
    60%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* ── Name — refined caption, not a heading ──────────── */
  .hero-name {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.50);
    margin-top: 16px;
    margin-bottom: 1rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-name {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) 2.7s both;
  }

  /* ── Tagline ─────────────────────────────────────────── */
  .hero-tagline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: clamp(0.6rem, 1.1vw, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-tagline {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) 2.9s both;
  }

  .tl-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .hero-sub {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-sub {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) 3.1s both;
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 4 — SIGNATURE QUOTE LINE
     ═══════════════════════════════════════════════════════ */
  .hero-quote {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    opacity: 0;
    will-change: transform;
  }

  section[data-animate="true"] .hero-quote {
    animation: fadeUp 0.5s cubic-bezier(0.16,1,0.3,1) 3.3s both;
  }

  .quote-line {
    width: 0;
    height: 1px;
    background: var(--signal-cyan);
    opacity: 0.6;
    margin-bottom: 0.25rem;
  }

  section[data-animate="true"] .quote-line {
    animation: quoteLine 0.4s cubic-bezier(0.16,1,0.3,1) 3.1s both;
  }

  @keyframes quoteLine {
    from { width: 0; }
    to   { width: 60px; }
  }

  .quote-text {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.625rem);
    color: rgba(255, 255, 255, 0.70);
    letter-spacing: 0.04em;
    line-height: 1.4;
    text-shadow: 0 0 30px rgba(255, 255, 255, 0.10);
  }

  .quote-attr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
