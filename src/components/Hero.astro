---
---

<!-- Noto Serif JP for kanji backdrop — async, non-blocking -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200&display=swap');

  /* ── Signature character — swap here to change the kanji ── */
  :root {
    --signature-char: '守';  /* mamoru: guard / defend / protect */
  }
</style>

<section id="hero" aria-label="Drakken Labs" data-animate="false">

  <!-- VIDEO BACKGROUND — deepest layer -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/media/hero-atmosphere.mp4"
      autoplay muted loop playsinline preload="metadata"
    ></video>
    <div class="hero-video-vignette"></div>
    <div class="hero-video-grain"></div>
  </div>

  <!-- ────────────────────────────────────────────────────── -->
  <!-- LAYER 1: KANJI BACKDROP — 守 (mamoru / "protect")    -->
  <!-- ────────────────────────────────────────────────────── -->
  <!-- data-parallax drives the JS mouse offset; char lives in CSS var -->
  <div class="hero-kanji" aria-hidden="true" data-parallax="20"></div>

  <!-- LAYER 3: SAMURAI LINES — flanking the wordmark -->
  <div class="samurai-lines" aria-hidden="true">
    <div class="samurai-line samurai-line-l">
      <div class="line-dot"></div>
      <div class="line-body"></div>
      <div class="line-bracket"></div>
    </div>
    <div class="samurai-line samurai-line-r">
      <div class="line-dot"></div>
      <div class="line-body"></div>
      <div class="line-bracket"></div>
    </div>
  </div>

  <!-- LAYER 6: BLADE FLASH — idle sweep every 8s -->
  <div class="blade-flash" aria-hidden="true"></div>

  <!-- Viewport corner ticks -->
  <div class="viewport-corner tl" aria-hidden="true"></div>
  <div class="viewport-corner tr" aria-hidden="true"></div>
  <div class="viewport-corner bl" aria-hidden="true"></div>
  <div class="viewport-corner br" aria-hidden="true"></div>

  <!-- Aurora atmosphere -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-1"></div>
    <div class="aurora-2"></div>
    <div class="aurora-3"></div>
  </div>

  <!-- Vertical light beam + shimmer -->
  <div class="hero-beam" aria-hidden="true">
    <div class="beam-shimmer"></div>
  </div>

  <!-- ─────────────────────────────────────────────── -->
  <!-- MAIN CONTENT — LAYER 2 + 4 + 5 live here       -->
  <!-- ─────────────────────────────────────────────── -->
  <div class="hero-content" data-parallax="8">

    <!-- LAYER 2: SVG STROKE-DRAW WORDMARK -->
    <div class="hero-title-wrap" role="heading" aria-level="1" aria-label="DRAKKEN">
      <!-- SVG stroke layer — draws the outline of DRAKKEN -->
      <svg
        class="drakken-svg"
        viewBox="0 0 860 160"
        preserveAspectRatio="xMidYMid meet"
        aria-hidden="true"
        focusable="false"
      >
        <text
          x="430" y="140"
          text-anchor="middle"
          font-family="Cinzel, Georgia, serif"
          font-size="148"
          font-weight="400"
          letter-spacing="12"
        >
          <tspan class="drakken-l" style="--li:0">D</tspan><tspan
            class="drakken-l" style="--li:1">R</tspan><tspan
            class="drakken-l" style="--li:2">A</tspan><tspan
            class="drakken-l" style="--li:3">K</tspan><tspan
            class="drakken-l" style="--li:4">K</tspan><tspan
            class="drakken-l" style="--li:5">E</tspan><tspan
            class="drakken-l" style="--li:6">N</tspan>
        </text>
      </svg>

      <!-- Fill overlay — letters cascade in after stroke draw -->
      <div class="drakken-fill font-cinzel" aria-hidden="true">
        <span class="fl" style="--i:0">D</span><span
          class="fl" style="--i:1">R</span><span
          class="fl" style="--i:2">A</span><span
          class="fl" style="--i:3">K</span><span
          class="fl" style="--i:4">K</span><span
          class="fl" style="--i:5">E</span><span
          class="fl" style="--i:6">N</span>
      </div>
    </div>

    <p class="hero-name font-cinzel">han myo naing</p>

    <p class="hero-tagline font-mono">
      <span class="tl-seg">AI-NATIVE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">SOFTWARE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">STUDIO</span>
    </p>

    <p class="hero-sub font-inter">
      Built in Malaysia&thinsp;·&thinsp;Operating worldwide
    </p>

    <!-- LAYER 4: SIGNATURE QUOTE LINE -->
    <div class="hero-quote" data-parallax="4" aria-label="Drakken Manifesto">
      <div class="quote-line" aria-hidden="true"></div>
      <p class="quote-text font-serif">"We build what defends."</p>
      <span class="quote-attr font-mono">— DRAKKEN MANIFESTO</span>
    </div>

    <!-- LAYER 5: SLASH-IN CTAs -->
    <div class="hero-actions">
      <a href="#contact" class="btn-primary font-inter hero-cta" style="--ci:0">
        Start a Project
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class="btn-ghost font-inter hero-cta" style="--ci:1">
        Manifesto
        <span class="btn-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

  <!-- LAYER 8: SCROLL PROMPT — traveling dot -->
  <div class="hero-scroll-prompt" aria-hidden="true">
    <span class="scroll-label font-mono">SCROLL</span>
    <div class="scroll-track">
      <div class="scroll-dot"></div>
    </div>
  </div>

</section>

<!-- ──────────────────────────────────────────────────────── -->
<!--  JS — animation timing + mouse parallax                  -->
<!-- ──────────────────────────────────────────────────────── -->
<script>
  (() => {
    const hero = document.getElementById('hero') as HTMLElement | null;
    if (!hero) return;

    // ── Trigger animations after loader exits (or immediately) ──
    function startAnimations() {
      hero!.dataset['animate'] = 'true';
    }

    const loader = document.getElementById('cinematic-loader');
    if (!loader || loader.style.display === 'none' || !loader.parentElement) {
      // No loader (repeat visit or direct) — 600ms grace for render + compositing
      setTimeout(startAnimations, 600);
    } else {
      // Watch for loader curtain to finish, then wait 600ms before revealing
      const obs = new MutationObserver(() => {
        if (loader.style.display === 'none') {
          // Loader's curtain split takes ~600ms — wait for it to fully exit
          setTimeout(startAnimations, 600);
          obs.disconnect();
        }
      });
      obs.observe(loader, { attributes: true, attributeFilter: ['style'] });
    }

    // ── Mouse parallax ──────────────────────────────────────
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;

    const parallaxEls = hero.querySelectorAll<HTMLElement>('[data-parallax]');
    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    let rafId: number;
    let isHovered = false;

    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      // Normalized -1 to 1 from center
      targetX = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
      targetY = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
      isHovered = true;
    });

    hero.addEventListener('mouseleave', () => {
      targetX = 0;
      targetY = 0;
      isHovered = false;
    });

    function animateParallax() {
      rafId = requestAnimationFrame(animateParallax);

      // Damp toward target (Emil Kowalski spring feel)
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      // Skip if movement negligible
      if (Math.abs(currentX) < 0.0005 && Math.abs(currentY) < 0.0005 && !isHovered) return;

      parallaxEls.forEach((el) => {
        const strength = parseFloat(el.dataset['parallax'] ?? '8');
        const tx = currentX * strength;
        const ty = currentY * strength;
        el.style.transform = `translate(${tx}px, ${ty}px)`;
      });
    }

    animateParallax();

    // ── Scroll prompt fade on scroll ────────────────────────
    const scrollPrompt = hero.querySelector<HTMLElement>('.hero-scroll-prompt');
    if (scrollPrompt) {
      window.addEventListener('scroll', () => {
        const gone = window.scrollY > 80;
        scrollPrompt.style.opacity = gone ? '0' : '';
        scrollPrompt.style.pointerEvents = gone ? 'none' : '';
      }, { passive: true });
    }
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     BASE SECTION
     ═══════════════════════════════════════════════════════ */
  section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--void);
    z-index: var(--z-page);
  }

  /* ── VIDEO BG ──────────────────────────────────────────── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: blur(2px) brightness(0.6) saturate(1.2);
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, #030308 90%);
  }

  .hero-video-grain {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  @media (max-width: 768px) {
    .hero-video { display: none; }
    .hero-video-bg {
      background: radial-gradient(ellipse at 50% 30%, rgba(0,212,255,0.08), transparent 65%);
    }
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 1 — KANJI BACKDROP 守
     ═══════════════════════════════════════════════════════ */
  .hero-kanji {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Base transform — breathing overrides this in its keyframes */
    transform: translate(calc(-50% + 8vw), -50%);
    pointer-events: none;
    user-select: none;
    z-index: 2;
    will-change: transform;
    /* Default opacity: 0 until data-animate fires */
    opacity: 0;
  }

  /* The actual character lives here — swap via --signature-char */
  .hero-kanji::before {
    content: var(--signature-char, '\5B88'); /* 守 unicode fallback */
    display: block;
    font-family: 'Noto Serif JP', 'Hiragino Mincho Pro', 'Yu Mincho', 'MS PMincho', serif;
    font-weight: 200;
    font-size: 70vh;
    line-height: 1;
    color: var(--signal-cyan);
    text-shadow:
      0 0 120px rgba(0, 212, 255, 0.4),
      0 0 60px  rgba(0, 212, 255, 0.2);
  }

  @keyframes kanjiBreath {
    0%, 100% { transform: translate(calc(-50% + 8vw), -50%) scale(1);    }
    50%       { transform: translate(calc(-50% + 8vw), -50%) scale(1.02); }
  }

  /* Reveal + breathe — triggered by data-animate */
  section[data-animate="true"] .hero-kanji {
    animation:
      kanjiFadeIn  1.5s cubic-bezier(0, 0, 0.38, 0.9) 0ms     both,
      kanjiBreath 12s  ease-in-out                    1.5s infinite;
  }

  @keyframes kanjiFadeIn {
    from { opacity: 0;    }
    to   { opacity: 0.10; }
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 3 — SAMURAI LINES (flank the wordmark)
     ═══════════════════════════════════════════════════════ */
  .samurai-lines {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(900px, 90vw);
    height: 220px;
    pointer-events: none;
    z-index: 3;  /* above kanji z=2, below content z=4 */
    display: flex;
    justify-content: space-between;
    align-items: stretch;
  }

  .samurai-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 1px;
    opacity: 0;
    transition: opacity 200ms;
  }

  section[data-animate="true"] .samurai-line {
    animation: samuraiReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  section[data-animate="true"] .samurai-line-r {
    animation-delay: 0.36s;
  }

  @keyframes samuraiReveal {
    from { opacity: 0; transform: scaleY(0); }
    to   { opacity: 1; transform: scaleY(1); }
  }

  .line-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    margin-bottom: -2px;
    flex-shrink: 0;
  }

  .line-body {
    flex: 1;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(0, 212, 255, 0.9) 0%,
      rgba(0, 212, 255, 0.5) 55%,
      transparent 100%
    );
    min-height: 160px;
  }

  .line-bracket {
    width: 8px;
    height: 8px;
    border-color: rgba(0, 212, 255, 0.6);
    border-style: solid;
    flex-shrink: 0;
  }
  .samurai-line-l .line-bracket { border-width: 0 0 1px 1px; }
  .samurai-line-r .line-bracket { border-width: 0 1px 1px 0; }

  /* ═══════════════════════════════════════════════════════
     LAYER 6 — BLADE FLASH (idle, pure CSS)
     ═══════════════════════════════════════════════════════ */
  .blade-flash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }

  /* Base state: no animation until hero is live */
  .blade-flash::after {
    content: '';
    position: absolute;
    top: -40%;
    left: 0;
    width: 400px;
    height: 200%;
    /* Sharp blade-edge peak — bright center, abrupt fade to transparent */
    background: linear-gradient(
      108deg,
      transparent              0%,
      transparent             30%,
      rgba(0, 212, 255, 0.06) 38%,
      rgba(0, 212, 255, 0.20) 45%,
      rgba(0, 212, 255, 0.35) 50%,
      rgba(0, 212, 255, 0.20) 55%,
      rgba(0, 212, 255, 0.06) 62%,
      transparent             70%,
      transparent            100%
    );
    filter: blur(0.5px) brightness(1.2);
    opacity: 0;
    animation: none;  /* gated — no fire until data-animate="true" */
  }

  /* Only active after Hero entrance sequence started */
  section[data-animate="true"] .blade-flash::after {
    animation: bladeFlash 6s cubic-bezier(0.2, 0.6, 0.3, 1) 7.5s infinite;
  }

  @keyframes bladeFlash {
    /* 0-23% ≈ 1.38s: katana slash across viewport (top-left → bottom-right) */
    0%   { transform: translate(-30vw, -10%); opacity: 0;   }
    4%   {                                    opacity: 1;   }
    21%  {                                    opacity: 0.6; }
    23%  { transform: translate(130vw,  70%); opacity: 0;   }
    /* 23-100%: invisible, waiting for next 6s cycle */
    24%, 100% { transform: translate(130vw, 70%); opacity: 0; }
  }

  /* ─────────────────────────────────────────────────────── */
  /* AURORA                                                   */
  /* ─────────────────────────────────────────────────────── */
  .hero-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .aurora-1 {
    position: absolute;
    width: 900px; height: 900px;
    top: -200px; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(0,212,255,0.13) 0%, rgba(0,212,255,0.04) 40%, transparent 72%);
    filter: blur(40px);
    animation: auraPulse 8s ease-in-out infinite;
  }

  .aurora-2 {
    position: absolute;
    width: 500px; height: 500px;
    bottom: 10%; left: -5%;
    background: radial-gradient(ellipse at center, rgba(167,139,250,0.08) 0%, transparent 70%);
    animation: auraDrift2 17s ease-in-out infinite;
  }

  .aurora-3 {
    position: absolute;
    width: 400px; height: 400px;
    top: -5%; right: 5%;
    background: radial-gradient(ellipse at center, rgba(0,212,255,0.06) 0%, transparent 70%);
    animation: auraDrift3 21s ease-in-out infinite;
  }

  @keyframes auraPulse {
    0%,100% { opacity: 1;    transform: translateX(-50%) scale(1);    }
    50%     { opacity: 0.75; transform: translateX(-50%) scale(1.08); }
  }
  @keyframes auraDrift2 {
    0%,100% { transform: translate(0,0) scale(1);   }
    50%     { transform: translate(4%,8%) scale(1.1); }
  }
  @keyframes auraDrift3 {
    0%,100% { transform: translate(0,0) scale(1.05);  }
    50%     { transform: translate(-5%,6%) scale(0.95); }
  }

  /* ─────────────────────────────────────────────────────── */
  /* LIGHT BEAM + SHIMMER                                     */
  /* ─────────────────────────────────────────────────────── */
  .hero-beam {
    position: absolute;
    left: 50%; top: 0;
    width: 1.5px; height: 60%;
    transform: translateX(-50%) scaleY(0);
    transform-origin: top center;
    background: linear-gradient(to bottom, rgba(0,212,255,0.7) 0%, rgba(0,212,255,0.12) 80%, transparent 100%);
    box-shadow: 0 0 8px rgba(0,212,255,0.35);
    z-index: 2;
    overflow: hidden;
  }

  section[data-animate="true"] .hero-beam {
    animation: beamDrop 0.6s cubic-bezier(0.16,1,0.3,1) 0.3s both;
  }

  @keyframes beamDrop {
    from { transform: translateX(-50%) scaleY(0); }
    to   { transform: translateX(-50%) scaleY(1); }
  }

  .beam-shimmer {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 200px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.6), transparent);
    animation: beamShimmer 12s cubic-bezier(0.4,0,0.2,1) 2s infinite;
    opacity: 0;
  }

  @keyframes beamShimmer {
    0%   { transform: translateY(-100%); opacity: 0; }
    8%   { opacity: 1; }
    92%  { opacity: 1; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  /* ═══════════════════════════════════════════════════════
     HERO CONTENT WRAPPER (Layer 2, 4, 5)
     ═══════════════════════════════════════════════════════ */
  .hero-content {
    position: relative;
    z-index: 4;
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 900px;
    width: 100%;
    will-change: transform;
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 2 — SVG STROKE-DRAW WORDMARK
     ═══════════════════════════════════════════════════════ */
  .hero-title-wrap {
    position: relative;
    margin-bottom: 1.1rem;
    line-height: 1;
    display: block;
  }

  /* SVG stroke layer */
  .drakken-svg {
    width: 100%;
    height: auto;
    max-height: 160px;
    display: block;
    overflow: visible;
  }

  /* Each tspan: stroke outline draws in, then disappears */
  .drakken-l {
    fill: transparent;
    stroke: #00d4ff;
    stroke-width: 0.8;
    stroke-dasharray: 3000;
    stroke-dashoffset: 3000;
    stroke-opacity: 0.9;
  }

  section[data-animate="true"] .drakken-l {
    animation:
      /* Phase 1: draw stroke — 2s per letter, 250ms stagger */
      strokeDraw  2.0s cubic-bezier(0.16,1,0.3,1) calc(0.5s + var(--li) * 0.25s) both,
      /* Phase 2: fade stroke out — starts when fill begins */
      strokeFade  0.5s ease                        calc(2.7s + var(--li) * 0.25s) both;
  }

  @keyframes strokeDraw {
    from { stroke-dashoffset: 3000; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes strokeFade {
    from { stroke-opacity: 1; }
    to   { stroke-opacity: 0; }
  }

  /* Fill overlay — cascades in after stroke draw */
  .drakken-fill {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .drakken-fill .fl {
    font-family: 'Cinzel', Georgia, serif;
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--text-pure);
    line-height: 1;
    user-select: none;
    display: inline-block;
    /* Start invisible — fill cascades in after stroke draw */
    opacity: 0;
    text-shadow:
      0 0 40px rgba(0,212,255,0.15),
      0 0 80px rgba(0,212,255,0.08);
  }

  section[data-animate="true"] .drakken-fill .fl {
    /* Starts 200ms after each letter's stroke finishes drawing:
       stroke_start(0.5 + i*0.25) + stroke_dur(2.0) + hold(0.2) = 2.7 + i*0.25 */
    animation: fillReveal 0.6s cubic-bezier(0.16,1,0.3,1) calc(2.7s + var(--i) * 0.25s) both;
  }

  @keyframes fillReveal {
    from { opacity: 0; filter: blur(4px); }
    to   { opacity: 1; filter: blur(0);   }
  }

  /* ── Name ────────────────────────────────────────────── */
  .hero-name {
    font-size: clamp(0.55rem, 1.1vw, 0.75rem);
    font-weight: 400;
    letter-spacing: 0.4em;
    color: rgba(255,255,255,0.55);
    font-variant: small-caps;
    margin-bottom: 1.25rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-name {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) 4.6s both;
  }

  /* ── Tagline ─────────────────────────────────────────── */
  .hero-tagline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: clamp(0.6rem, 1.1vw, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-tagline {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) 4.75s both;
  }

  .tl-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .hero-sub {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
    opacity: 0;
  }

  section[data-animate="true"] .hero-sub {
