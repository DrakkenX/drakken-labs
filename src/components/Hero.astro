  .drakken-wordmark span {
    position: relative;
    display: inline-block;
    color: var(--text-pure);
    opacity: 0;
  }

  /* Cyan flash overlay — uses the data-letter attribute as content */
  .drakken-wordmark span::before {
    content: attr(data-letter);
    position: absolute;
    inset: 0;
    color: #00d4ff;
    text-shadow:
      0 0 20px rgba(0, 212, 255, 0.9),
      0 0 40px rgba(0, 212, 255, 0.5);
    opacity: 0;
    pointer-events: none;
  }

  /* Base letter: invisible → white (starts at 60% of 1000ms = 600ms in) */
  section[data-animate="true"] .drakken-wordmark span {
    animation: letterBase 1000ms cubic-bezier(0.2, 0.8, 0.2, 1)
               calc(var(--i) * 200ms + 300ms) both;
  }

  /* Cyan flash: invisible → cyan → invisible (peaks at 40-60%) */
  section[data-animate="true"] .drakken-wordmark span::before {
    animation: letterFlash 1000ms cubic-bezier(0.2, 0.8, 0.2, 1)
               calc(var(--i) * 200ms + 300ms) both;
  }

  @keyframes letterBase {
    0%   { opacity: 0; }
    60%  { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes letterFlash {
    0%   { opacity: 0; }
    40%  { opacity: 1; }
    60%  { opacity: 1; }
    100% { opacity: 0; }
  }

