---
---

<section id="hero" aria-label="Drakken Labs">
  <!-- VIDEO BACKGROUND — deepest layer, below aurora + 3D canvas -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/media/hero-atmosphere.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    ></video>
    <!-- Radial vignette over video -->
    <div class="hero-video-vignette"></div>
    <!-- Film grain (Hero-only layer) -->
    <div class="hero-video-grain"></div>
  </div>

  <!-- Viewport corner ticks — cathedral signature -->
  <div class="viewport-corner tl" aria-hidden="true"></div>
  <div class="viewport-corner tr" aria-hidden="true"></div>
  <div class="viewport-corner bl" aria-hidden="true"></div>
  <div class="viewport-corner br" aria-hidden="true"></div>

  <!-- Aurora atmosphere -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-1"></div>
    <div class="aurora-2"></div>
    <div class="aurora-3"></div>
  </div>

  <!-- Vertical light beam with shimmer -->
  <div class="hero-beam" aria-hidden="true">
    <div class="beam-shimmer"></div>
  </div>

  <!-- Main content -->
  <div class="hero-content">
    <h1 class="hero-title font-cinzel" aria-label="DRAKKEN">
      <span class="letter" style="--i:0">D</span><span
        class="letter" style="--i:1">R</span><span
        class="letter" style="--i:2">A</span><span
        class="letter" style="--i:3">K</span><span
        class="letter" style="--i:4">K</span><span
        class="letter" style="--i:5">E</span><span
        class="letter" style="--i:6">N</span>
    </h1>

    <p class="hero-name font-cinzel">han myo naing</p>

    <div class="hero-divider" aria-hidden="true"></div>

    <p class="hero-tagline font-mono">
      <span class="tl-seg">AI-NATIVE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">SOFTWARE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">STUDIO</span>
    </p>

    <p class="hero-sub font-inter">
      Built in Malaysia&thinsp;·&thinsp;Operating worldwide
    </p>

    <div class="hero-actions">
      <a href="#contact" class="btn-primary font-inter">
        Start a Project
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class="btn-ghost font-inter">
        Manifesto
        <span class="btn-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="font-mono">scroll</span>
    <div class="scroll-bar"></div>
  </div>
</section>

<style>
  section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--void);
    z-index: var(--z-page);
  }

  /* ── AURORA ──────────────────────────────────────────── */
  /* ── VIDEO BG ──────────────────────────────────────── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: blur(2px) brightness(0.6) saturate(1.2);
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 40%,
      #030308 90%
    );
  }

  .hero-video-grain {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* Mobile: disable video, keep gradient fallback */
  @media (max-width: 768px) {
    .hero-video { display: none; }
    .hero-video-bg {
      background: radial-gradient(ellipse at 50% 30%, rgba(0,212,255,0.08), transparent 65%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video { display: none; }
  }

  /* ── AURORA ──────────────────────────────────────── */
  .hero-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Primary — large cyan behind DRAKKEN */
  .aurora-1 {
    position: absolute;
    width: 900px;
    height: 900px;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(0, 212, 255, 0.13) 0%,
      rgba(0, 212, 255, 0.04) 40%,
      transparent 72%
    );
    filter: blur(40px);
    animation: auraPulse 8s ease-in-out infinite;
  }

  /* Secondary violet — bottom left */
  .aurora-2 {
    position: absolute;
    width: 500px;
    height: 500px;
    bottom: 10%;
    left: -5%;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.08) 0%,
      transparent 70%
    );
    animation: auraDrift2 17s ease-in-out infinite;
  }

  /* Tertiary cyan — top right asymmetric */
  .aurora-3 {
    position: absolute;
    width: 400px;
    height: 400px;
    top: -5%;
    right: 5%;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 212, 255, 0.06) 0%,
      transparent 70%
    );
    animation: auraDrift3 21s ease-in-out infinite;
  }

  @keyframes auraPulse {
    0%, 100% { opacity: 1; transform: translateX(-50%) scale(1); }
    50%       { opacity: 0.75; transform: translateX(-50%) scale(1.08); }
  }
  @keyframes auraDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(4%, 8%) scale(1.1); }
  }
  @keyframes auraDrift3 {
    0%, 100% { transform: translate(0, 0) scale(1.05); }
    50%       { transform: translate(-5%, 6%) scale(0.95); }
  }

  /* ── LIGHT BEAM ──────────────────────────────────────── */
  .hero-beam {
    position: absolute;
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 60%;
    transform: translateX(-50%) scaleY(0);
    transform-origin: top center;
    background: linear-gradient(
      to bottom,
      rgba(0, 212, 255, 0.7) 0%,
      rgba(0, 212, 255, 0.12) 80%,
      transparent 100%
    );
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.35);
    animation: beamDrop 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    z-index: 1;
    overflow: hidden;
  }

  @keyframes beamDrop {
    from { transform: translateX(-50%) scaleY(0); }
    to   { transform: translateX(-50%) scaleY(1); }
  }

  /* Shimmer traveling down the beam every 12s */
  .beam-shimmer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 200px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%
    );
    animation: beamShimmer 12s cubic-bezier(0.4, 0, 0.2, 1) 2s infinite;
    opacity: 0;
  }

  /* ── HERO CONTENT ────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 860px;
    width: 100%;
  }

  /* DRAKKEN — letter by letter */
  .hero-title {
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--text-pure);
    margin-bottom: 1.1rem;
    line-height: 1;
    user-select: none;
    white-space: nowrap;
    text-shadow:
      0 0 40px rgba(0, 212, 255, 0.15),
      0 0 80px rgba(0, 212, 255, 0.08);
  }

  .hero-title .letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    animation: letterReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.3s + var(--i) * 0.065s);
  }

  @keyframes letterReveal {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Name */
  .hero-name {
    font-size: clamp(0.55rem, 1.1vw, 0.75rem);
    font-weight: 400;
    letter-spacing: 0.4em;
    color: rgba(255, 255, 255, 0.55);
    font-variant: small-caps;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) calc(0.3s + 7 * 0.065s + 0.05s) both;
  }

  /* Divider */
  .hero-divider {
    width: 48px;
    height: 1px;
    background: var(--edge);
    margin: 0 auto 1.75rem;
    transform: scaleX(0);
    transform-origin: left center;
    animation: dividerDraw 0.6s cubic-bezier(0.16, 1, 0.3, 1) calc(0.3s + 7 * 0.065s + 0.15s) both;
  }

  @keyframes dividerDraw {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* Tagline — JetBrains mono with cyan dot separators */
  .hero-tagline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: clamp(0.6rem, 1.1vw, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) calc(0.3s + 7 * 0.065s + 0.35s) both;
  }

  .tl-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--signal-cyan);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .hero-sub {
    font-size: clamp(0.65rem, 1vw, 0.75rem);
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.08em;
    margin-bottom: 2.75rem;
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) calc(0.3s + 7 * 0.065s + 0.45s) both;
  }

  /* CTAs */
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) calc(0.3s + 7 * 0.065s + 0.6s) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SCROLL HINT ─────────────────────────────────────── */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
    opacity: 0;
    animation: fadeUp 0.6s ease calc(0.3s + 7 * 0.065s + 1.1s) both;
  }

  .hero-scroll-hint span {
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    color: var(--text-ghost);
  }

  .scroll-bar {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, var(--text-ghost), transparent);
    animation: scrollPulse 2.2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.35; transform: scaleY(1);    }
    50%       { opacity: 1;    transform: scaleY(1.15); }
  }

  /* ── MOBILE ──────────────────────────────────────────── */
  @media (max-width: 480px) {
    .hero-title {
      font-size: clamp(2.5rem, 16vw, 4rem);
      letter-spacing: 0.12em;
    }
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-primary, .btn-ghost {
      justify-content: center;
    }
  }
</style>
