---
---

<section id="hero" aria-label="Drakken Labs" data-animate="false">

  <!-- VIDEO BACKGROUND — deepest layer -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/media/hero-atmosphere.mp4"
      autoplay muted loop playsinline preload="metadata"
    ></video>
    <div class="hero-video-vignette"></div>
    <div class="hero-video-grain"></div>
  </div>

  <!-- ────────────────────────────────────────────────────── -->
  <!-- LAYER 1: DRAKKEN X MARK — futuristic multi-layer     -->
  <!-- ────────────────────────────────────────────────────── -->
  <div class="hero-xmark-wrap" id="hero-xmark-wrap" aria-hidden="true" data-parallax="20">

    <!-- Layer 4a: Red chromatic ghost (+1.5px right offset) -->
    <svg class="hero-xmark xm-chroma xm-red" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g fill="#ff4060">
        <polygon points="21.8,18.2 106.4,93.6 181.8,178.2 178.2,181.8 93.6,106.4 18.2,21.8"/>
        <polygon points="181.8,21.8 106.4,106.4 21.8,181.8 18.2,178.2 93.6,93.6 178.2,18.2"/>
        <polygon points="26,20 24.2,24.2 20,26 15.8,24.2 14,20 15.8,15.8 20,14 24.2,15.8"/>
        <polygon points="186,20 184.2,24.2 180,26 175.8,24.2 174,20 175.8,15.8 180,14 184.2,15.8"/>
        <polygon points="26,180 24.2,184.2 20,186 15.8,184.2 14,180 15.8,175.8 20,174 24.2,175.8"/>
        <polygon points="186,180 184.2,184.2 180,186 175.8,184.2 174,180 175.8,175.8 180,174 184.2,175.8"/>
      </g>
    </svg>

    <!-- Layer 4b: Blue chromatic ghost (-1.5px left offset) -->
    <svg class="hero-xmark xm-chroma xm-blue" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g fill="#a78bfa">
        <polygon points="21.8,18.2 106.4,93.6 181.8,178.2 178.2,181.8 93.6,106.4 18.2,21.8"/>
        <polygon points="181.8,21.8 106.4,106.4 21.8,181.8 18.2,178.2 93.6,93.6 178.2,18.2"/>
        <polygon points="26,20 24.2,24.2 20,26 15.8,24.2 14,20 15.8,15.8 20,14 24.2,15.8"/>
        <polygon points="186,20 184.2,24.2 180,26 175.8,24.2 174,20 175.8,15.8 180,14 184.2,15.8"/>
        <polygon points="26,180 24.2,184.2 20,186 15.8,184.2 14,180 15.8,175.8 20,174 24.2,175.8"/>
        <polygon points="186,180 184.2,184.2 180,186 175.8,184.2 174,180 175.8,175.8 180,174 184.2,175.8"/>
      </g>
    </svg>

    <!-- Layer 2: Scan lines — travel top to bottom over wrapper height -->
    <div class="xm-scan-wrap">
      <div class="xm-scan xm-scan-a"></div>
      <div class="xm-scan xm-scan-b"></div>
    </div>

    <!-- Layer 1: Main X SVG — arms + diamond + caps + pulse rings + glitch -->
    <svg
      class="hero-xmark xm-main"
      viewBox="0 0 200 200"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <!-- Glow filter -->
        <filter id="hero-xglow" x="-45%" y="-45%" width="190%" height="190%">
          <feGaussianBlur stdDeviation="3.5" result="glow"/>
          <feMerge>
            <feMergeNode in="glow"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      <!-- Layer 6: Endpoint caps with asynchronous glow pulses -->
      <g class="xm-endpoints">
        <polygon class="xm-ep ep-tl" points="26,20 24.2,24.2 20,26 15.8,24.2 14,20 15.8,15.8 20,14 24.2,15.8" fill="#00d4ff"/>
        <polygon class="xm-ep ep-tr" points="186,20 184.2,24.2 180,26 175.8,24.2 174,20 175.8,15.8 180,14 184.2,15.8" fill="#00d4ff"/>
        <polygon class="xm-ep ep-bl" points="26,180 24.2,184.2 20,186 15.8,184.2 14,180 15.8,175.8 20,174 24.2,175.8" fill="#00d4ff"/>
        <polygon class="xm-ep ep-br" points="186,180 184.2,184.2 180,186 175.8,184.2 174,180 175.8,175.8 180,174 184.2,175.8" fill="#00d4ff"/>
      </g>

      <!-- Layer 1: Main X body — arms + diamond + caps (with glow filter) -->
      <g filter="url(#hero-xglow)" fill="#00d4ff">
        <polygon points="21.8,18.2 106.4,93.6 181.8,178.2 178.2,181.8 93.6,106.4 18.2,21.8"/>
        <polygon points="181.8,21.8 106.4,106.4 21.8,181.8 18.2,178.2 93.6,93.6 178.2,18.2"/>
        <polygon points="100,87 113,100 100,113 87,100"/>
        <polygon points="26,20 24.2,24.2 20,26 15.8,24.2 14,20 15.8,15.8 20,14 24.2,15.8"/>
        <polygon points="186,20 184.2,24.2 180,26 175.8,24.2 174,20 175.8,15.8 180,14 184.2,15.8"/>
        <polygon points="26,180 24.2,184.2 20,186 15.8,184.2 14,180 15.8,175.8 20,174 24.2,175.8"/>
        <polygon points="186,180 184.2,184.2 180,186 175.8,184.2 174,180 175.8,175.8 180,174 184.2,175.8"/>
      </g>

      <!-- Layer 5: Pulse rings — sonar ping from center every 8s -->
      <circle class="xm-pulse-ring xm-pr-a" cx="100" cy="100" r="72" fill="none" stroke="#00d4ff" stroke-width="1.5"/>
      <circle class="xm-pulse-ring xm-pr-b" cx="100" cy="100" r="72" fill="none" stroke="#00d4ff" stroke-width="1.5"/>

      <!-- Layer 3: Glitch overlay — brief horizontal shift every ~7s -->
      <g class="xm-glitch-g" filter="url(#hero-xglow)" fill="#00d4ff">
        <polygon points="21.8,18.2 106.4,93.6 181.8,178.2 178.2,181.8 93.6,106.4 18.2,21.8"/>
        <polygon points="181.8,21.8 106.4,106.4 21.8,181.8 18.2,178.2 93.6,93.6 178.2,18.2"/>
      </g>
    </svg>

  </div>

  <!-- LAYER 6: BLADE FLASH — idle sweep every 8s -->
  <div class="blade-flash" aria-hidden="true"></div>

  <!-- Viewport corner ticks -->
  <div class="viewport-corner tl" aria-hidden="true"></div>
  <div class="viewport-corner tr" aria-hidden="true"></div>
  <div class="viewport-corner bl" aria-hidden="true"></div>
  <div class="viewport-corner br" aria-hidden="true"></div>

  <!-- Aurora atmosphere -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-1"></div>
    <div class="aurora-2"></div>
    <div class="aurora-3"></div>
  </div>

  <!-- Vertical light beam + shimmer -->
  <div class="hero-beam" aria-hidden="true">
    <div class="beam-shimmer"></div>
  </div>

  <!-- ─────────────────────────────────────────────── -->
  <!-- MAIN CONTENT — LAYER 2 + 4 + 5 live here       -->
  <!-- ─────────────────────────────────────────────── -->
  <div class="hero-content" data-parallax="8">

    <!-- LAYER 2: WORDMARK — cyan flash then white settle, per letter
         Each span: ::before = cyan overlay (flashes, then fades)
                    base     = white letter (fades in at 60% of animation)
         Approach: content: attr(data-letter) on ::before — no JS needed.
    -->
    <h1 class="drakken-wordmark font-cinzel" aria-label="DRAKKEN">
      <span data-letter="D" style="--i:0">D</span><span
        data-letter="R" style="--i:1">R</span><span
        data-letter="A" style="--i:2">A</span><span
        data-letter="K" style="--i:3">K</span><span
        data-letter="K" style="--i:4">K</span><span
        data-letter="E" style="--i:5">E</span><span
        data-letter="N" style="--i:6">N</span>
    </h1>

    <p class="hero-name font-inter">Han Myo Naing</p>

    <p class="hero-tagline font-mono">
      <span class="tl-seg">AI-NATIVE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">SOFTWARE</span>
      <span class="tl-dot" aria-hidden="true"></span>
      <span class="tl-seg">STUDIO</span>
    </p>

    <p class="hero-sub font-inter">
      Built in Malaysia&thinsp;·&thinsp;Operating worldwide
    </p>

    <!-- LAYER 4: SIGNATURE QUOTE LINE -->
    <div class="hero-quote" data-parallax="4" aria-label="Drakken Manifesto">
      <div class="quote-line" aria-hidden="true"></div>
      <p class="quote-text font-serif">"We build what defends."</p>
      <span class="quote-attr font-mono">— DRAKKEN MANIFESTO</span>
    </div>

    <!-- LAYER 5: SLASH-IN CTAs -->
    <div class="hero-actions">
      <a href="#contact" class="btn-primary font-inter hero-cta" style="--ci:0">
        Start a Project
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class="btn-ghost font-inter hero-cta" style="--ci:1">
        Manifesto
        <span class="btn-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

  <!-- LAYER 8: SCROLL PROMPT — traveling dot -->
  <div class="hero-scroll-prompt" aria-hidden="true">
    <span class="scroll-label font-mono">SCROLL</span>
    <div class="scroll-track">
      <div class="scroll-dot"></div>
    </div>
  </div>

</section>

<!-- ──────────────────────────────────────────────────────── -->
<!--  JS — animation timing + mouse parallax                  -->
<!-- ──────────────────────────────────────────────────────── -->
<script>
  (() => {
    const hero = document.getElementById('hero') as HTMLElement | null;
    if (!hero) return;

    // ── Trigger animations after loader exits (or immediately) ──
    function startAnimations() {
      hero!.dataset['animate'] = 'true';
    }

    const loader = document.getElementById('cinematic-loader');
    if (!loader || loader.style.display === 'none' || !loader.parentElement) {
      // No loader (repeat visit or direct) — 600ms grace for render + compositing
      setTimeout(startAnimations, 600);
    } else {
      // Watch for loader curtain to finish, then wait 600ms before revealing
      const obs = new MutationObserver(() => {
        if (loader.style.display === 'none') {
          // Loader's curtain split takes ~600ms — wait for it to fully exit
          setTimeout(startAnimations, 600);
          obs.disconnect();
        }
      });
      obs.observe(loader, { attributes: true, attributeFilter: ['style'] });
    }

    // ── Mouse parallax ──────────────────────────────────────
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;

    const parallaxEls = hero.querySelectorAll<HTMLElement>('[data-parallax]');
    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    let rafId: number;
    let isHovered = false;

    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      // Normalized -1 to 1 from center
      targetX = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
      targetY = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
      isHovered = true;
    });

    hero.addEventListener('mouseleave', () => {
      targetX = 0;
      targetY = 0;
      isHovered = false;
    });

    function animateParallax() {
      rafId = requestAnimationFrame(animateParallax);

      // Damp toward target (Emil Kowalski spring feel)
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      // Skip if movement negligible
      if (Math.abs(currentX) < 0.0005 && Math.abs(currentY) < 0.0005 && !isHovered) return;

      parallaxEls.forEach((el) => {
        const strength = parseFloat(el.dataset['parallax'] ?? '8');
        const tx = currentX * strength;
        const ty = currentY * strength;
        el.style.transform = `translate(${tx}px, ${ty}px)`;
      });
    }

    animateParallax();

    // ── Scroll prompt fade on scroll ────────────────────────
    const scrollPrompt = hero.querySelector<HTMLElement>('.hero-scroll-prompt');
    if (scrollPrompt) {
      window.addEventListener('scroll', () => {
        const gone = window.scrollY > 80;
        scrollPrompt.style.opacity = gone ? '0' : '';
        scrollPrompt.style.pointerEvents = gone ? 'none' : '';
      }, { passive: true });
    }

    // ── X mark proximity reaction (every 50ms, low-freq) ──────
    // Cursor near the X: opacity bumps 0.12→0.18, scan lines speed up.
    // Cursor position comes from mousemove on hero (no global dep).
    const xWrap = document.getElementById('hero-xmark-wrap') as HTMLElement | null;
    const xMain = hero.querySelector<HTMLElement>('.xm-main');

    if (xWrap && xMain && !window.matchMedia('(max-width: 768px)').matches) {
      let hMX = -9999, hMY = -9999;

      hero.addEventListener('mousemove', (e) => {
        hMX = e.clientX;
        hMY = e.clientY;
      });
      hero.addEventListener('mouseleave', () => {
        hMX = -9999; hMY = -9999;
      });

      setInterval(() => {
        const rect = xWrap.getBoundingClientRect();
        const cx = rect.left + rect.width  / 2;
        const cy = rect.top  + rect.height / 2;
        const dist = Math.hypot(hMX - cx, hMY - cy);
        // Effective proximity: 0 (far) → 1 (very close, ≤30px)
        const prox = Math.max(0, Math.min(1, 1 - (dist - 30) / 190));

        // Opacity: 0.12 base → up to 0.18 when near
        xMain.style.opacity = String(+(0.12 + prox * 0.06).toFixed(3));

        // Scan speed: accelerate from 3s → 1.5s — add/remove class
        if (prox > 0.25) {
          xWrap.classList.add('xm-near');
        } else {
          xWrap.classList.remove('xm-near');
        }
      }, 50);
    }
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     BASE SECTION
     ═══════════════════════════════════════════════════════ */
  section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--void);
    z-index: var(--z-page);
  }

  /* ── VIDEO BG ──────────────────────────────────────────── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: blur(2px) brightness(0.6) saturate(1.2);
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, #030308 90%);
  }

  .hero-video-grain {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  @media (max-width: 768px) {
    .hero-video { display: none; }
    .hero-video-bg {
      background: radial-gradient(ellipse at 50% 30%, rgba(0,212,255,0.08), transparent 65%);
    }
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 1 — DRAKKEN X MARK (futuristic multi-layer)
     ═══════════════════════════════════════════════════════ */

  /* ── Wrapper: positioning only ──────────────────────── */
  .hero-xmark-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(calc(-50% + 8vw), -50%);
    width: clamp(300px, 55vh, 560px);
    height: clamp(300px, 55vh, 560px);
    pointer-events: none;
    user-select: none;
    z-index: 2;
  }

  /* ── All SVG layers share the same base position ────── */
  .hero-xmark {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
  }

  /* ── Main X: fade to 0.12, then rotate+breathe ────── */
  section[data-animate="true"] .xm-main {
    animation:
      xMarkFadeIn 1.5s cubic-bezier(0, 0, 0.38, 0.9) 0ms   both,
      xMarkLive   60s  linear                         1.5s  infinite;
  }

  @keyframes xMarkFadeIn {
    from { opacity: 0;    }
    to   { opacity: 0.12; }
  }

  /* Rotation (60s/rev) + breathing (every 12s = every 10% of 60s) */
  @keyframes xMarkLive {
    0%   { transform: rotate(0deg)   scale(1);     }
    10%  { transform: rotate(36deg)  scale(1.022); }
    20%  { transform: rotate(72deg)  scale(1);     }
    30%  { transform: rotate(108deg) scale(1.022); }
    40%  { transform: rotate(144deg) scale(1);     }
    50%  { transform: rotate(180deg) scale(1.022); }
    60%  { transform: rotate(216deg) scale(1);     }
    70%  { transform: rotate(252deg) scale(1.022); }
    80%  { transform: rotate(288deg) scale(1);     }
    90%  { transform: rotate(324deg) scale(1.022); }
    100% { transform: rotate(360deg) scale(1);     }
  }

  /* ── Layer 4: Chromatic aberration ghosts ───────────── */
  /* Each ghost is a separate SVG offset by ±1.5px and tinted.
     mix-blend-mode: screen makes them additive — CRT lens feel. */
  .xm-chroma {
    mix-blend-mode: screen;
  }
  .xm-red  { left:  1.5px; }
  .xm-blue { left: -1.5px; }

  section[data-animate="true"] .xm-chroma {
    animation:
      xChromaFadeIn 1.5s cubic-bezier(0, 0, 0.38, 0.9) 0ms   both,
      xMarkLive     60s  linear                         1.5s  infinite;
  }
  @keyframes xChromaFadeIn {
    from { opacity: 0;    }
    to   { opacity: 0.15; }
  }

  /* ── Layer 2: Scan lines ────────────────────────────── */
  /* Full-width divs travel from top to bottom of wrapper (overflow:hidden clips them).
     --xm-scan-dur is updated by Hero JS proximity detection (default 3s). */
  .xm-scan-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 3;
  }

  .xm-scan {
    position: absolute;
    left: -5%;
    width: 110%;
    height: 3px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 212, 255, 0.55) 30%,
      rgba(0, 212, 255, 0.75) 50%,
      rgba(0, 212, 255, 0.55) 70%,
      transparent 100%
    );
    border-radius: 1px;
    will-change: transform;
  }

  .xm-scan-a {
    top: -3px;
    animation: xScanDown var(--xm-scan-dur, 3s) linear 0s infinite;
  }
  .xm-scan-b {
    top: -3px;
    animation: xScanDown var(--xm-scan-dur, 3s) linear 1.5s infinite;
  }

  /* Travel the full wrapper height (same clamp as wrapper dimensions) */
  @keyframes xScanDown {
    from { transform: translateY(-3px); }
    to   { transform: translateY(clamp(300px, 55vh, 560px)); }
  }

  /* Cursor proximity: accelerate scan lines */
  .xm-near .xm-scan-a,
  .xm-near .xm-scan-b { animation-duration: 1.5s; }

  /* ── Layer 5: Pulse rings ───────────────────────────── */
  /* SVG circles that emanate from center diamond like sonar pings */
  .xm-pulse-ring {
    transform-box: fill-box;
    transform-origin: center;
  }
  section[data-animate="true"] .xm-pr-a {
    animation: xPulseRing 8s cubic-bezier(0.2, 0.6, 0.4, 1) 2.0s infinite;
  }
  section[data-animate="true"] .xm-pr-b {
    animation: xPulseRing 8s cubic-bezier(0.2, 0.6, 0.4, 1) 6.0s infinite;
  }
  @keyframes xPulseRing {
    0%   { transform: scale(0);   opacity: 0.4; stroke-width: 2;   }
    70%  { transform: scale(1.9); opacity: 0;   stroke-width: 0.5; }
    100% { transform: scale(1.9); opacity: 0;   stroke-width: 0.5; }
  }

  /* ── Layer 3: Glitch overlay ────────────────────────── */
  /* Duplicate X arms that briefly flash with horizontal offset every ~7s.
     Simulates data corruption / CRT scan artifact. */
  .xm-glitch-g { opacity: 0; }
  section[data-animate="true"] .xm-glitch-g {
    animation: xGlitch 7s linear 4.5s infinite;
  }
  @keyframes xGlitch {
    0%, 88%, 100% { opacity: 0;    transform: translateX(0);   }
    89%           { opacity: 0.85; transform: translateX(9px);  }
    90.5%         { opacity: 0.65; transform: translateX(-6px); }
    92%           { opacity: 0;    transform: translateX(0);   }
  }

  /* ── Layer 6: Endpoint glow pulses ─────────────────── */
  /* Each octagonal cap pulses independently (asynchronous offsets) */
  .xm-ep {
    transform-box: fill-box;
    transform-origin: center;
  }
  section[data-animate="true"] .ep-tl { animation: xEpGlow 3.0s ease-in-out 0.00s infinite; }
  section[data-animate="true"] .ep-tr { animation: xEpGlow 3.0s ease-in-out 0.75s infinite; }
  section[data-animate="true"] .ep-bl { animation: xEpGlow 3.0s ease-in-out 1.50s infinite; }
  section[data-animate="true"] .ep-br { animation: xEpGlow 3.0s ease-in-out 2.25s infinite; }
  @keyframes xEpGlow {
    0%, 100% { opacity: 0.45; }
    50%       { opacity: 1.0;  }
  }

  /* ═══════════════════════════════════════════════════════
     LAYER 6 — BLADE FLASH (idle, pure CSS)
     ═══════════════════════════════════════════════════════ */
  .blade-flash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }

  /* Blade flash: position:fixed escapes all overflow:hidden clipping.
     White streak is more visible on dark backgrounds than cyan.      */
  .blade-flash::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 480px;
    height: 100vh;
    /* White core + cyan glow wings — high visibility on dark bg */
    background: linear-gradient(
      108deg,
      transparent               0%,
      transparent              30%,
      rgba(0,  212, 255, 0.08) 38%,
      rgba(255, 255, 255, 0.35) 46%,
      rgba(255, 255, 255, 0.50) 50%,
      rgba(255, 255, 255, 0.35) 54%,
      rgba(0,  212, 255, 0.08) 62%,
      transparent              70%,
      transparent             100%
    );
    box-shadow: 0 0 80px rgba(0, 212, 255, 0.6);
    filter: blur(0.5px) brightness(1.3);
    opacity: 0;
    pointer-events: none;
    z-index: 50;
    animation: none; /* gated — no fire until data-animate="true" */
  }

  /* Gate: flash only after the hero entrance sequence is complete */
  section[data-animate="true"] .blade-flash::after {
    animation: bladeFlash 6s cubic-bezier(0.2, 0.6, 0.3, 1) 5.0s infinite;
  }

  @keyframes bladeFlash {
