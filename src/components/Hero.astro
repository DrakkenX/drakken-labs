  /* ═══════════════════════════════════════════════════════
     LAYER 2 — DRAKKEN WORDMARK: CYAN FLASH → WHITE SETTLE
     Per-letter: ::before = cyan overlay (1→0 opacity = flash)
                 base     = white letter (0→1 opacity = settle)
     Stagger: 200ms between letters. Total reveal: ~2500ms.
     ═══════════════════════════════════════════════════════ */
  .drakken-wordmark {
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 400;
    letter-spacing: 0.08em;
