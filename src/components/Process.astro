---
// Geometric glyphs: triangle, square, hexagon, octagon, circle
const glyphs = [
  `<svg viewBox="0 0 24 24" fill="none" class="glyph-svg glyph-0"><polygon points="12,3 22,20 2,20" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" class="glyph-svg glyph-1"><rect x="3" y="3" width="18" height="18" stroke="currentColor" stroke-width="1.5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" class="glyph-svg glyph-2"><polygon points="12,2 20,7 20,17 12,22 4,17 4,7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" class="glyph-svg glyph-3"><polygon points="8,2 16,2 22,8 22,16 16,22 8,22 2,16 2,8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" class="glyph-svg glyph-4"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/></svg>`,
];

const steps = [
  {
    num: '01',
    name: 'DISCOVERY',
    duration: '1–2 days',
    desc: 'Map the problem space, define success, surface the real constraints. No bloated briefs.',
  },
  {
    num: '02',
    name: 'ARCHITECTURE',
    duration: '1–2 days',
    desc: 'Stack chosen for the work, not the resume. Tradeoffs documented. Scope locked.',
  },
  {
    num: '03',
    name: 'EXECUTION',
    duration: '5–14 days',
    desc: 'AI-augmented sprints. Daily builds. No black holes between check-ins.',
  },
  {
    num: '04',
    name: 'CRAFT',
    duration: '2–5 days',
    desc: 'The 20% that determines perception. Micro-interactions, edge cases, taste-driven iteration.',
  },
  {
    num: '05',
    name: 'SHIP',
    duration: 'Delivery',
    desc: 'Documented handoff. Deployment-ready. Post-ship support included.',
  },
];
---

<section id="process" aria-labelledby="process-heading">
  <!-- Full-bleed photographic background -->
  <div class="section-bg process-bg" aria-hidden="true">
    <img
      src="/media/texture-3.jpg"
      alt=""
      class="section-bg-img"
      loading="lazy"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="section-bg-vignette"></div>
  </div>

  <div class="section-inner">
    <div class="section-header reveal">
      <div class="section-label"><span>PROCESS</span></div>
      <h2 id="process-heading" class="section-heading">
        How It <em class="heading-accent font-serif">Works</em>
      </h2>
    </div>

    <!-- Animated SVG connector line (replaces plain div) -->
    <div class="process-track" aria-hidden="true">
      <svg class="process-svg-line" viewBox="0 0 1200 2" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%"   stop-color="#00d4ff"/>
            <stop offset="50%"  stop-color="#a78bfa"/>
            <stop offset="100%" stop-color="#00d4ff"/>
          </linearGradient>
        </defs>
        <!-- Static base line -->
        <line x1="0" y1="1" x2="1200" y2="1" stroke="#1f2330" stroke-width="1"/>
        <!-- Animated gradient dash that draws on scroll-trigger -->
        <line
          class="process-line-draw"
          x1="0" y1="1" x2="1200" y2="1"
          stroke="url(#lineGrad)"
          stroke-width="1.5"
          stroke-dasharray="1200"
          stroke-dashoffset="1200"
        />
        <!-- Continuous flowing dash on top -->
        <line
          class="process-line-flow"
          x1="0" y1="1" x2="1200" y2="1"
          stroke="url(#lineGrad)"
          stroke-width="1"
          stroke-dasharray="60 40"
          stroke-dashoffset="0"
          opacity="0.5"
        />
      </svg>
    </div>

    <!-- Steps -->
    <div class="process-steps" data-stagger data-stagger-step="80">
      {steps.map(({ num, name, duration, desc }, i) => (
        <article class="process-step stagger-child" data-step={i}>
          <div class="step-glyph" aria-hidden="true" set:html={glyphs[i]} />
          <div class="step-num font-mono">{num}</div>
          <div class="step-name font-cinzel">{name}</div>
          <div class="step-duration font-mono">{duration}</div>
          <p class="step-desc font-inter">{desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  (() => {
    // Active step pulse on viewport intersection
    const steps = document.querySelectorAll<HTMLElement>('.process-step');
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle('step-active', entry.isIntersecting);
        });
      },
      { threshold: 0.6, rootMargin: '-20% 0px -20% 0px' }
    );
    steps.forEach((s) => obs.observe(s));

    // Process background parallax
    const bg = document.querySelector<HTMLElement>('.process-bg .section-bg-img');
    if (!bg) return;
    if (window.matchMedia('(max-width: 768px)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const loadParallax = async () => {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      gsap.to(bg, {
        yPercent: -30,
        ease: 'none',
        scrollTrigger: {
          trigger: '#process',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      });
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadParallax, { timeout: 3000 });
    } else {
      setTimeout(loadParallax, 600);
    }
  })();
</script>

<style>
  section {
    padding: 8rem 2rem;
    background: var(--void);
    overflow: hidden;
    z-index: var(--z-page);
    position: relative;
  }

  .section-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .section-header { margin-bottom: 3.5rem; }

  /* Instrument Serif italic accent */
  .heading-accent {
    font-style: italic;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1em;
  }

  /* ── SECTION BG ─────────────────────────────────────── */
  .section-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .section-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    filter: brightness(0.2) blur(3px);
    will-change: transform;
  }

  .section-bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 60% 50%,
      transparent 20%,
      #030308 80%
    );
  }

  /* ── SVG CONNECTOR LINE ─────────────────────────────── */
  .process-track {
    width: 100%;
    height: 2px;
    overflow: visible;
  }

  .process-svg-line {
    width: 100%;
    height: 2px;
    overflow: visible;
    display: block;
  }

  /* Draw-on reveal (triggered by transitions.ts observer) */
  .process-line-draw {
    transition: stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }

  /* Continuous flowing dash — 8s loop */
  .process-line-flow {
    animation: dashFlow 8s linear infinite;
  }

  @keyframes dashFlow {
    to { stroke-dashoffset: -200; }
  }

  /* ── STEPS ──────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border: 1px solid var(--edge);
    border-top: none;
    background: var(--edge);
    gap: 1px;
  }

  .process-step {
    padding: 2rem 1.5rem;
    background: var(--mid);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    cursor: default;
    transition:
      background var(--t-base) var(--ease-out-expo),
      box-shadow var(--t-base) var(--ease-out-expo);
  }

  .process-step:hover,
  .process-step.step-active {
    background: var(--rise);
    box-shadow: 0 -2px 0 var(--signal-cyan) inset;
  }

  /* Geometric glyph */
  .step-glyph {
    width: 20px;
    height: 20px;
    color: var(--signal-cyan);
    opacity: 0.55;
    transition:
      opacity var(--t-base),
      transform var(--t-deliberate) var(--ease-spring);
  }

  /* Each glyph rotates at its own speed */
  .glyph-svg { width: 100%; height: 100%; }

  .glyph-0 { animation: glyphSpin 14s linear infinite; }
  .glyph-1 { animation: glyphSpin 18s linear infinite reverse; }
  .glyph-2 { animation: glyphSpin 12s linear infinite; }
  .glyph-3 { animation: glyphSpin 22s linear infinite reverse; }
  .glyph-4 { animation: glyphSpin 10s linear infinite; }

  @keyframes glyphSpin {
    to { transform: rotate(360deg); }
  }

  /* Active step: pulse cyan + scale */
  .process-step.step-active .step-glyph,
  .process-step:hover .step-glyph {
    opacity: 1;
    transform: scale(1.15);
  }

  .step-num {
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: var(--signal-cyan);
  }

  .step-name {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--text-pure);
    line-height: 1.3;
  }

  .step-duration {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-ghost);
  }

  .step-desc {
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: auto;
    flex-grow: 1;
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .process-steps { grid-template-columns: 1fr 1fr; }
    .process-track  { display: none; }
  }
  @media (max-width: 520px) {
    .process-steps { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .section-bg-img { filter: brightness(0.15) blur(4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .glyph-0, .glyph-1, .glyph-2, .glyph-3, .glyph-4 { animation: none; }
    .process-line-flow { animation: none; }
  }
</style>
