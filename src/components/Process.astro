---
const steps = [
  {
    num: '01',
    name: 'DISCOVERY',
    duration: '1–2 days',
    desc: 'Map the problem space, define success, surface the real constraints. No bloated briefs.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5" stroke="currentColor" stroke-width="1"/><circle cx="8" cy="8" r="2" fill="currentColor"/></svg>`,
  },
  {
    num: '02',
    name: 'ARCHITECTURE',
    duration: '1–2 days',
    desc: 'Stack chosen for the work, not the resume. Tradeoffs documented. Scope locked.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="1" stroke="currentColor" stroke-width="1"/><path d="M2 6H14M6 6V14" stroke="currentColor" stroke-width="1"/></svg>`,
  },
  {
    num: '03',
    name: 'EXECUTION',
    duration: '5–14 days',
    desc: 'AI-augmented sprints. Daily builds. No black holes between check-ins.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L7 12L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '04',
    name: 'CRAFT',
    duration: '2–5 days',
    desc: 'The 20% that determines perception. Micro-interactions, edge cases, taste-driven iteration.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L10 6.5H15L11 9.5L12.5 14L8 11L3.5 14L5 9.5L1 6.5H6L8 2Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '05',
    name: 'SHIP',
    duration: 'Delivery',
    desc: 'Documented handoff. Deployment-ready. Post-ship support included.',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2V14M2 8L8 2L14 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];
---

<section id="process" aria-labelledby="process-heading">
  <div class="section-inner">
    <div class="section-header reveal">
      <div class="section-label"><span>PROCESS</span></div>
      <h2 id="process-heading" class="section-heading">How It Works</h2>
    </div>

    <!-- Animated connector line -->
    <div class="process-track" aria-hidden="true">
      <div class="process-line-fill"></div>
    </div>

    <!-- Steps -->
    <div class="process-steps" data-stagger data-stagger-step="80">
      {steps.map(({ num, name, duration, desc, icon }) => (
        <article class="process-step stagger-child">
          <div class="step-icon" aria-hidden="true" set:html={icon} />
          <div class="step-num font-mono">{num}</div>
          <div class="step-name font-cinzel">{name}</div>
          <div class="step-duration font-mono">{duration}</div>
          <p class="step-desc font-inter">{desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 8rem 2rem;
    background: var(--void);
    overflow: hidden;
    z-index: var(--z-page);
    position: relative;
  }

  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-header { margin-bottom: 3.5rem; }

  /* ── CONNECTOR LINE ─────────────────────────────────── */
  .process-track {
    position: relative;
    height: 1px;
    background: var(--edge);
    overflow: hidden;
  }

  .process-line-fill {
    position: absolute;
    inset-block: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(
      to right,
      var(--signal-cyan) 0%,
      var(--signal-violet) 50%,
      var(--signal-mint) 100%
    );
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
    box-shadow: 0 0 8px rgba(0,212,255,0.4);
  }

  /* ── STEPS ──────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border: 1px solid var(--edge);
    border-top: none;
    background: var(--edge);
    gap: 1px;
  }

  .process-step {
    padding: 2rem 1.5rem;
    background: var(--mid);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    cursor: default;
    transition:
      background var(--t-base) var(--ease-out-expo),
      box-shadow var(--t-base) var(--ease-out-expo);
  }

  .process-step:hover {
    background: var(--rise);
    box-shadow: 0 -2px 0 var(--signal-cyan) inset;
  }

  .step-icon {
    width: 16px;
    height: 16px;
    color: var(--signal-cyan);
    opacity: 0.6;
    transition: opacity var(--t-base);
  }
  .process-step:hover .step-icon { opacity: 1; }

  .step-num {
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: var(--signal-cyan);
  }

  .step-name {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--text-pure);
    line-height: 1.3;
  }

  .step-duration {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-ghost);
  }

  .step-desc {
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: auto;
    flex-grow: 1;
  }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .process-steps { grid-template-columns: 1fr 1fr; }
    .process-track  { display: none; }
  }
  @media (max-width: 520px) {
    .process-steps { grid-template-columns: 1fr; }
  }
</style>
