---
// Scroll-pinned stats section.
// 4 chapters cycle at 25% scroll-progress intervals.
// Section is 400vh tall — pin matches exactly so no phantom space after.
---

<section id="hero-stats" aria-label="Studio statistics">
  <div class="hero-stats-frame" id="hero-stats-frame">

    <!-- Left vertical thread line -->
    <div class="stats-thread" aria-hidden="true"></div>

    <!-- Chapter 0: INTENTION — no 'active' in HTML, GSAP controls all opacity -->
    <div class="stat-chapter" data-chapter="0" role="region" aria-label="Intention">
      <p class="chapter-eyebrow font-cinzel">[ INTENTION ]</p>
      <p class="chapter-stat font-serif">
        <span class="stat-num font-mono" data-final="8959">0</span>&hairsp;lines
      </p>
      <p class="chapter-sub font-inter">
        AEGIS v1.0 — civilian cyber defense, shipped in 5 days
      </p>
    </div>

    <!-- Chapter 1: VELOCITY -->
    <div class="stat-chapter" data-chapter="1" role="region" aria-label="Velocity">
      <p class="chapter-eyebrow font-cinzel">[ VELOCITY ]</p>
      <p class="chapter-stat font-serif">
        5–10<span style="font-size:0.5em; vertical-align:super">×</span>&thinsp;output
      </p>
      <p class="chapter-sub font-inter">
        AI-leveraged engineering, memory-driven, end to end
      </p>
    </div>

    <!-- Chapter 2: CRAFT -->
    <div class="stat-chapter" data-chapter="2" role="region" aria-label="Craft">
      <p class="chapter-eyebrow font-cinzel">[ CRAFT ]</p>
      <p class="chapter-stat font-serif">
        60&thinsp;fps&nbsp;·&nbsp;0&thinsp;errors
      </p>
      <p class="chapter-sub font-inter">
        Spring physics, sacred frames, surgical iteration
      </p>
    </div>

    <!-- Chapter 3: PURPOSE -->
    <div class="stat-chapter" data-chapter="3" role="region" aria-label="Purpose">
      <p class="chapter-eyebrow font-cinzel">[ PURPOSE ]</p>
      <p class="chapter-stat font-serif">
        Built for those<br />who need defending
      </p>
      <p class="chapter-sub font-inter">
        Software that ships. Code that compounds.
      </p>
    </div>

    <!-- Right ambient glow -->
    <div class="stats-ambient" aria-hidden="true"></div>

  </div>
</section>

<script>
  (() => {
    // ── Reduced motion: static chapter 0 only ──────────────
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const ch0 = document.querySelector<HTMLElement>('.stat-chapter[data-chapter="0"]');
      if (ch0) {
        ch0.style.opacity = '1';
        ch0.style.transform = 'translateY(0)';
      }
      return;
    }

    // ── Mobile: static, show only chapter 0 ────────────────
    if (window.matchMedia('(max-width: 768px)').matches) {
      const ch0 = document.querySelector<HTMLElement>('.stat-chapter[data-chapter="0"]');
      if (ch0) {
        ch0.style.opacity = '1';
        ch0.style.transform = 'translateY(0)';
        // Tween the number on mobile
        const numEl = ch0.querySelector<HTMLElement>('.stat-num');
        if (numEl && numEl.dataset['final']) {
          tweenNumber(numEl, parseInt(numEl.dataset['final'], 10));
        }
      }
      return;
    }

    // ── GSAP setup ──────────────────────────────────────────
    const loadGSAP = async () => {
      const [{ gsap }, { ScrollTrigger }] = await Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
      ]);
      gsap.registerPlugin(ScrollTrigger);

      const frame    = document.getElementById('hero-stats-frame');
      const section  = document.getElementById('hero-stats');
      const chapters = document.querySelectorAll<HTMLElement>('.stat-chapter');

      if (!frame || !section || !chapters.length) return;

      // ── CRITICAL: set ALL chapters to opacity 0 first ───
      // Never rely on CSS class for the initial visible state —
      // use GSAP inline styles exclusively to avoid conflicts.
      gsap.set(chapters, { opacity: 0, y: 20, pointerEvents: 'none' });
      // Show chapter 0 immediately
      gsap.set(chapters[0]!, { opacity: 1, y: 0, pointerEvents: 'auto' });

      // Tween the number in chapter 0 on load
      const initNum = chapters[0]?.querySelector<HTMLElement>('.stat-num');
      if (initNum && initNum.dataset['final']) {
        tweenNumber(initNum, parseInt(initNum.dataset['final'], 10));
      }

      let activeIndex = 0;

      function showChapter(index: number) {
        if (index === activeIndex) return;

        const outEl = chapters[activeIndex];
        const inEl  = chapters[index];
        if (!outEl || !inEl) return;

        // ── Use overwrite: true to kill conflicting animations ──
        // This is the fix for the "all chapters visible" bug:
        // without overwrite, rapid scroll fires multiple competing
        // gsap.to() calls on the same element.
        gsap.to(outEl, {
          opacity: 0,
          y: -24,
          duration: 0.35,
          ease: 'power2.out',
          overwrite: true,
          onComplete: () => {
            gsap.set(outEl, { pointerEvents: 'none' });
          },
        });

        gsap.fromTo(
          inEl,
          { opacity: 0, y: 24 },
          {
            opacity: 1,
            y: 0,
            duration: 0.35,
            ease: 'power2.out',
            delay: 0.08,
            overwrite: true,
            onStart: () => {
              gsap.set(inEl, { pointerEvents: 'auto' });
            },
          }
        );

        // Tween numbers in the incoming chapter
        const numEl = inEl.querySelector<HTMLElement>('.stat-num');
        if (numEl && numEl.dataset['final']) {
          tweenNumber(numEl, parseInt(numEl.dataset['final'], 10));
        }

        activeIndex = index;
      }

      ScrollTrigger.create({
        trigger: '#hero-stats',
        pin: '#hero-stats-frame',
        start: 'top top',
        end: '+=400vh',
        pinSpacing: false,
        anticipatePin: 1,
        onUpdate(self) {
          // Floor progress × 4 to get chapter index 0–3
          const idx = Math.min(Math.floor(self.progress * 4), 3);
          showChapter(idx);
        },
      });
    };

    // Load immediately — pin must be set before user scrolls to this section
    setTimeout(loadGSAP, 0);
  })();

  // ── Number tween utility ─────────────────────────────────
  function tweenNumber(el: HTMLElement, target: number) {
    const start = performance.now();
    const dur   = 800;
    function step(now: number) {
      const p = Math.min((now - start) / dur, 1);
      const e = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
      el.textContent = String(Math.round(e * target));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
</script>

<style>
  /* Outer section — scroll runway. Height matches GSAP pin end (+=400vh). */
  #hero-stats {
    position: relative;
    height: 400vh;
    background: var(--void);
    z-index: var(--z-page);
  }

  /* Inner frame — pinned by GSAP ScrollTrigger */
  .hero-stats-frame {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 0 12vw;
    overflow: hidden;
  }

  /* Left vertical thread line */
  .stats-thread {
    position: absolute;
    left: calc(12vw - 2rem);
    top: 15%;
    bottom: 15%;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(0, 212, 255, 0.45) 25%,
      rgba(0, 212, 255, 0.45) 75%,
      transparent
    );
  }

  /* Ambient glow */
  .stats-ambient {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: 40vw;
    height: 40vw;
    max-width: 600px;
    max-height: 600px;
    background: radial-gradient(
      ellipse at center,
      rgba(167, 139, 250, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ── CHAPTERS ────────────────────────────────────────────
   * ALL chapters start hidden via CSS.
   * GSAP controls opacity from this 0 baseline using inline
   * styles + overwrite:true — no CSS class toggles.
   * ──────────────────────────────────────────────────────── */
  .stat-chapter {
    position: absolute;
    left: 12vw;
    right: 12vw;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    pointer-events: none;
    max-width: 700px;
    /* CRITICAL: CSS baseline opacity:0 so all chapters are
     * invisible before GSAP initialises. Without this, all 4
     * chapters render at full opacity (browser default = 1). */
    opacity: 0;
    transform: translateY(20px);
  }

  /* Eyebrow label */
  .chapter-eyebrow {
    font-size: 0.6875rem;
    letter-spacing: 0.24em;
    color: var(--signal-cyan);
    font-variant: small-caps;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Main stat — large Instrument Serif italic */
  .chapter-stat {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.1;
    color: var(--text-pure);
    letter-spacing: -0.02em;
  }

  /* Numeric counter */
  .stat-num {
    font-style: normal;
    font-family: 'JetBrains Mono', monospace;
    font-variant-numeric: tabular-nums;
  }

  /* Sub-line */
  .chapter-sub {
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    color: rgba(232, 237, 245, 0.6);
    line-height: 1.6;
    max-width: 480px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* ── MOBILE ──────────────────────────────────────────────
   * Collapse to static single chapter — pinning is too complex.
   * ──────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    #hero-stats {
      height: auto;
      min-height: 70vh;
    }
    .hero-stats-frame {
      height: auto;
      padding: 6rem 2rem;
    }
    .stat-chapter {
      position: relative;
      left: 0;
      right: 0;
    }
    .stat-chapter:not([data-chapter="0"]) {
      display: none;
    }
  }
</style>
