---
// Persistent 3D scene — fixed behind all content at z-index 0.
// Lazy-loads Three.js after first paint.
---

<canvas id="scene-canvas" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('scene-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const load = async () => {
      const { initScene } = await import('../scene/index');
      initScene(canvas);
    };
    if ('requestIdleCallback' in window) {
      requestIdleCallback(load, { timeout: 2500 });
    } else {
      setTimeout(load, 200);
    }
  }
</script>

<style>
  #scene-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    #scene-canvas { display: none; }
  }
</style>
