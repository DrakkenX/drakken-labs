---
// Signal colors fixed: card 3 = mint, card 4 = amber (was: cyan/mint)
const caps = [
  {
    num: '01',
    signal: 'cyan',
    cardClass: 'card-ai',
    title: 'AI-NATIVE\nENGINEERING',
    desc: 'Systems where AI isn\'t a feature — it\'s the architecture. Built from first principles, not retrofitted.',
    stack: 'Claude API · Tauri · Rust · TypeScript',
  },
  {
    num: '02',
    signal: 'violet',
    cardClass: 'card-frontend',
    title: 'PREMIUM\nFRONTEND',
    desc: 'Interfaces that feel alive. Spring physics, 60fps Three.js, cinematic scroll choreography.',
    stack: 'Three.js · Motion · Astro · GSAP',
  },
  {
    num: '03',
    signal: 'mint',
    cardClass: 'card-desktop',
    title: 'NATIVE DESKTOP\nAPPLICATIONS',
    desc: 'Code-signed, installer-ready apps for Windows, macOS, Linux. Performance without compromise.',
    stack: 'Tauri · Rust · Windows · macOS · Linux',
  },
  {
    num: '04',
    signal: 'amber',
    cardClass: 'card-automation',
    title: 'STRATEGIC\nAUTOMATION',
    desc: 'Workflows that think. Memory systems, multi-agent pipelines, tools that compound over time.',
    stack: 'Memory architecture · Multi-agent · Custom APIs',
  },
];
---

<section id="capabilities" aria-labelledby="cap-heading">
  <div class="section-inner">

    <!-- Section heading -->
    <div class="section-header">
      <div class="section-label">
        <span>CAPABILITIES</span>
      </div>
      <h2 id="cap-heading" class="section-heading">
        What We <em class="heading-accent font-serif">Build</em>
      </h2>
      <p class="cap-subtitle font-mono">[ FOUR DISCIPLINES · ONE STUDIO ]</p>
    </div>

    <!-- Card grid — stagger reveal via IntersectionObserver below -->
    <div class="cap-grid" id="cap-grid">

      <!-- ═══════════════════════════════════════════════
           CARD 1 — AI-NATIVE ENGINEERING (cyan)
           Personality: precise, computational, alive
           ═══════════════════════════════════════════════ -->
      <article class="sacred-frame accent-top cap-card card-ai" data-signal="cyan" data-card-idx="0">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <!-- Card number prefix -->
        <div class="cap-num font-mono" style="color: rgba(0,212,255,0.4)">01</div>

        <!-- Glyph: octagonal node with 6 radiating lines -->
        <div class="cap-icon" aria-hidden="true">
          <svg class="glyph-ai" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="10,2 18,2 26,10 26,18 18,26 10,26 2,18 2,10"
              stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="14" cy="14" r="2.5" fill="currentColor" opacity="0.8"/>
            <line class="ray r1" x1="14" y1="9.5" x2="14" y2="5"   stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            <line class="ray r2" x1="18"  y1="10"  x2="22" y2="6"   stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            <line class="ray r3" x1="19"  y1="14"  x2="23" y2="14"  stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            <line class="ray r4" x1="14"  y1="18.5" x2="14" y2="23" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            <line class="ray r5" x1="10"  y1="18"  x2="6"  y2="22"  stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            <line class="ray r6" x1="9"   y1="14"  x2="5"  y2="14"  stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
          </svg>
        </div>

        <h3 class="cap-title font-cinzel">AI-NATIVE<br/>ENGINEERING</h3>
        <p class="cap-desc font-inter">Systems where AI isn't a feature — it's the architecture. Built from first principles, not retrofitted.</p>
        <p class="cap-stack font-mono">Claude API · Tauri · Rust · TypeScript</p>

        <!-- Bottom hover line -->
        <div class="cap-bottom-line"></div>
        <span class="cap-bottom-hint font-mono">USED IN: AEGIS · MAVIS</span>

        <!-- Card 1 exclusive: data stream waveform bars -->
        <div class="data-stream" aria-hidden="true">
          <div class="bar b1"></div>
          <div class="bar b2"></div>
          <div class="bar b3"></div>
          <div class="bar b4"></div>
          <div class="bar b5"></div>
        </div>
      </article>

      <!-- ═══════════════════════════════════════════════
           CARD 2 — PREMIUM FRONTEND (violet)
           Personality: artful, fluid, expressive
           ═══════════════════════════════════════════════ -->
      <article class="sacred-frame accent-top cap-card card-frontend" data-signal="violet" data-card-idx="1">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="cap-num font-mono" style="color: rgba(167,139,250,0.4)">02</div>

        <!-- Glyph: bezier wave that morphs on hover -->
        <div class="cap-icon" aria-hidden="true">
          <svg class="glyph-frontend" width="28" height="18" viewBox="0 0 28 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="wave-path"
              d="M2 12 C7 12, 10 4, 14 4 C18 4, 21 12, 26 12"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Second subtle wave below -->
            <path
              d="M2 14 C7 14, 10 8, 14 8 C18 8, 21 14, 26 14"
              stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.35"/>
          </svg>
        </div>

        <h3 class="cap-title font-cinzel">PREMIUM<br/>FRONTEND</h3>
        <p class="cap-desc font-inter">Interfaces that feel alive. Spring physics, 60fps Three.js, cinematic scroll choreography.</p>
        <p class="cap-stack font-mono">Three.js · Motion · Astro · GSAP</p>

        <div class="cap-bottom-line"></div>
        <span class="cap-bottom-hint font-mono">USED IN: AEGIS · MAVIS</span>

        <!-- Card 2 exclusive: horizontal line draws across card on hover -->
        <div class="card-hline" aria-hidden="true"></div>
      </article>

      <!-- ═══════════════════════════════════════════════
           CARD 3 — NATIVE DESKTOP APPLICATIONS (mint)
           Personality: solid, foundational, structural
           ═══════════════════════════════════════════════ -->
      <article class="sacred-frame accent-top cap-card card-desktop" data-signal="mint" data-card-idx="2">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="cap-num font-mono" style="color: rgba(74,222,128,0.4)">03</div>

        <!-- Glyph: stacked layers (3 rects that shift apart on hover) -->
        <div class="cap-icon" aria-hidden="true">
          <svg class="glyph-desktop" width="28" height="22" viewBox="0 0 28 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect class="layer-top" x="4" y="1.5"  width="20" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect class="layer-mid" x="4" y="8.5"  width="20" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect class="layer-bot" x="4" y="15.5" width="20" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>

        <h3 class="cap-title font-cinzel">NATIVE DESKTOP<br/>APPLICATIONS</h3>
        <p class="cap-desc font-inter">Code-signed, installer-ready apps for Windows, macOS, Linux. Performance without compromise.</p>
        <p class="cap-stack font-mono">Tauri · Rust · Windows · macOS · Linux</p>

        <div class="cap-bottom-line"></div>
        <span class="cap-bottom-hint font-mono">USED IN: AEGIS · MAVIS</span>

        <!-- Card 3 exclusive: interior corner accents on hover -->
        <div class="inner-corners" aria-hidden="true">
          <span class="ic ic-tl"></span>
          <span class="ic ic-tr"></span>
          <span class="ic ic-bl"></span>
          <span class="ic ic-br"></span>
        </div>
      </article>

      <!-- ═══════════════════════════════════════════════
           CARD 4 — STRATEGIC AUTOMATION (amber)
           Personality: orchestrated, looping, intentional
           ═══════════════════════════════════════════════ -->
      <article class="sacred-frame accent-top cap-card card-automation" data-signal="amber" data-card-idx="3">
        <span class="corner-tl"></span><span class="corner-tr"></span>
        <span class="corner-bl"></span><span class="corner-br"></span>

        <div class="cap-num font-mono" style="color: rgba(251,191,36,0.4)">04</div>

        <!-- Glyph: nested circles (gear) with dashed outer ring -->
        <div class="cap-icon" aria-hidden="true">
          <svg class="glyph-automation" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle class="ring-outer" cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 2"/>
            <circle cx="14" cy="14" r="7" stroke="currentColor" stroke-width="1.5"/>
            <circle class="ring-inner" cx="14" cy="14" r="3" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 1.5"/>
            <line x1="14" y1="11" x2="14" y2="7" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
          </svg>
        </div>

        <h3 class="cap-title font-cinzel">STRATEGIC<br/>AUTOMATION</h3>
        <p class="cap-desc font-inter">Workflows that think. Memory systems, multi-agent pipelines, tools that compound over time.</p>
        <p class="cap-stack font-mono">Memory architecture · Multi-agent · Custom APIs</p>

        <div class="cap-bottom-line"></div>
        <span class="cap-bottom-hint font-mono">USED IN: AEGIS · MAVIS</span>

        <!-- Card 4 exclusive: loop indicator (rotating arrows) -->
        <div class="loop-indicator" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.5 8 A5.5 5.5 0 1 1 8 13.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M8 13.5 L5.5 11 L10.5 11 Z" fill="currentColor"/>
          </svg>
        </div>
      </article>

    </div>
  </div>
</section>

<script>
  (() => {
    // ── Card entrance stagger via IntersectionObserver ──────────
    const cards = document.querySelectorAll<HTMLElement>('.cap-card');
    if (!cards.length) return;

    // prefers-reduced-motion: snap to final state
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cards.forEach((c) => { c.style.opacity = '1'; c.style.transform = 'none'; });
      return;
    }

    // Set initial hidden state
    cards.forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(30px)';
      card.style.transition = `opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1)`;
      card.style.transitionDelay = `${i * 120}ms`;
    });

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const card = entry.target as HTMLElement;
          card.style.opacity = '1';
          card.style.transform = 'none';
          obs.unobserve(card);
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((c) => obs.observe(c));
  })();
</script>

<style>
  section {
    padding: 8rem 2rem;
    background: var(--void);
    z-index: var(--z-page);
    position: relative;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 4rem;
  }

  /* Section subtitle */
  .cap-subtitle {
    font-size: 10px;
    letter-spacing: 0.32em;
    color: rgba(0, 212, 255, 0.5);
    margin-top: 16px;
  }

  /* Instrument Serif italic accent on "Build" */
  .heading-accent {
    font-style: italic;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1em;
  }

  /* ═══════════════════════════════════════════════════════
     GRID
     ═══════════════════════════════════════════════════════ */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--edge);
    border: 1px solid var(--edge);
  }

  /* ═══════════════════════════════════════════════════════
     BASE CARD — shared across all four
     ═══════════════════════════════════════════════════════ */
  .cap-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--mid);
    border: none;
    border-radius: 0;
    min-height: 340px;
    position: relative;
    overflow: hidden;
    cursor: default;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    /* Hover lift override — overrides sacred-frame:hover global */
    transition:
      transform    0.28s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow   0.28s cubic-bezier(0.16, 1, 0.3, 1),
      background   0.22s ease,
      border-color 0.22s ease;
  }

  .cap-card:hover {
    transform: translateY(-6px) scale(1.005);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    background: var(--rise);
  }

  /* ═══════════════════════════════════════════════════════
     PER-CARD BACKGROUND PATTERNS + GRADIENTS (via ::after)
     ═══════════════════════════════════════════════════════ */

  /* All cards need ::after for background pattern + color gradient */
  .cap-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Card 1 — dot grid (cyan) */
  .card-ai::after {
    background:
      radial-gradient(circle, rgba(0,212,255,0.06) 1.5px, transparent 1.5px),
      radial-gradient(ellipse at 100% 0%, rgba(0,212,255,0.10), transparent 70%);
    background-size: 24px 24px, 100% 100%;
  }

  /* Card 2 — diagonal lines (violet) */
  .card-frontend::after {
    background:
      repeating-linear-gradient(
        45deg,
        rgba(167,139,250,0.04) 0px,
        rgba(167,139,250,0.04) 1px,
        transparent 1px,
        transparent 32px
      ),
      radial-gradient(ellipse at 0% 100%, rgba(167,139,250,0.10), transparent 70%);
  }

  /* Card 3 — isometric grid (mint) */
  .card-desktop::after {
    background:
      repeating-linear-gradient(
        60deg,
        rgba(74,222,128,0.04) 0px,
        rgba(74,222,128,0.04) 1px,
        transparent 1px,
        transparent 24px
      ),
      repeating-linear-gradient(
        -60deg,
        rgba(74,222,128,0.04) 0px,
        rgba(74,222,128,0.04) 1px,
        transparent 1px,
        transparent 24px
      ),
      radial-gradient(ellipse at 0% 0%, rgba(74,222,128,0.08), transparent 70%);
  }

  /* Card 4 — concentric arcs from bottom-right (amber) */
  .card-automation::after {
    background:
      repeating-radial-gradient(
        circle at 100% 100%,
        transparent 0px,
        transparent 48px,
        rgba(251,191,36,0.05) 50px,
        transparent 52px,
        transparent 82px,
        rgba(251,191,36,0.05) 84px,
        transparent 86px,
        transparent 116px,
        rgba(251,191,36,0.05) 118px,
        transparent 120px
      ),
      radial-gradient(ellipse at 100% 100%, rgba(251,191,36,0.08), transparent 70%);
  }

  /* ═══════════════════════════════════════════════════════
     TOP ACCENT LINE (::before — signal color on hover)
     ═══════════════════════════════════════════════════════ */
  .cap-card[data-signal="cyan"]::before   { background: rgba(0,212,255,0.50); }
  .cap-card[data-signal="violet"]::before { background: rgba(167,139,250,0.50); }
  .cap-card[data-signal="mint"]::before   { background: rgba(74,222,128,0.50); }
  .cap-card[data-signal="amber"]::before  { background: rgba(251,191,36,0.50); }

  /* ═══════════════════════════════════════════════════════
     CORNER TICKS — signal colors
     ═══════════════════════════════════════════════════════ */
  .cap-card[data-signal="cyan"]   .corner-tl, .cap-card[data-signal="cyan"]   .corner-tr,
  .cap-card[data-signal="cyan"]   .corner-bl, .cap-card[data-signal="cyan"]   .corner-br
    { border-color: var(--signal-cyan); }

  .cap-card[data-signal="violet"] .corner-tl, .cap-card[data-signal="violet"] .corner-tr,
  .cap-card[data-signal="violet"] .corner-bl, .cap-card[data-signal="violet"] .corner-br
    { border-color: var(--signal-violet); }

  .cap-card[data-signal="mint"]   .corner-tl, .cap-card[data-signal="mint"]   .corner-tr,
  .cap-card[data-signal="mint"]   .corner-bl, .cap-card[data-signal="mint"]   .corner-br
    { border-color: var(--signal-mint); }

  .cap-card[data-signal="amber"]  .corner-tl, .cap-card[data-signal="amber"]  .corner-tr,
  .cap-card[data-signal="amber"]  .corner-bl, .cap-card[data-signal="amber"]  .corner-br
    { border-color: var(--signal-amber); }

  /* ═══════════════════════════════════════════════════════
     HOVER BOX SHADOWS — per signal
     ═══════════════════════════════════════════════════════ */
  .cap-card[data-signal="cyan"]:hover {
    box-shadow:
      0 -2px 0 var(--signal-cyan) inset,
      0 24px 60px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .cap-card[data-signal="violet"]:hover {
    box-shadow:
      0 -2px 0 var(--signal-violet) inset,
      0 24px 60px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .cap-card[data-signal="mint"]:hover {
    box-shadow:
      0 -2px 0 var(--signal-mint) inset,
      0 24px 60px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .cap-card[data-signal="amber"]:hover {
    box-shadow:
      0 -2px 0 var(--signal-amber) inset,
      0 24px 60px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  /* ═══════════════════════════════════════════════════════
     CARD CONTENT ELEMENTS
     ═══════════════════════════════════════════════════════ */
  .cap-num {
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    position: relative;
    z-index: 1;
  }

  .cap-icon {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    width: 28px;
    height: 28px;
    /* Override global sacred-frame:hover rotate(90deg) */
    transition: opacity 0.22s ease;
  }
  .cap-icon svg { width: 100%; height: auto; }
  .cap-card:hover .cap-icon { opacity: 1; }

  .cap-title {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--text-pure);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  .cap-desc {
    font-size: 0.825rem;
    line-height: 1.7;
    color: var(--text-secondary);
    flex-grow: 1;
    position: relative;
    z-index: 1;
  }

  .cap-stack {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--edge);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  /* Bottom draw line on hover */
  .cap-bottom-line {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 1px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 3;
  }
  .cap-card[data-signal="cyan"]   .cap-bottom-line { background: var(--signal-cyan);   }
  .cap-card[data-signal="violet"] .cap-bottom-line { background: var(--signal-violet); }
  .cap-card[data-signal="mint"]   .cap-bottom-line { background: var(--signal-mint);   }
  .cap-card[data-signal="amber"]  .cap-bottom-line { background: var(--signal-amber);  }
  .cap-card:hover .cap-bottom-line { transform: scaleX(1); }

  /* Bottom micro-hint */
  .cap-bottom-hint {
    position: absolute;
    bottom: 0.85rem; left: 2rem;
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.35);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 240ms ease, transform 240ms ease;
    transition-delay: 60ms;
    z-index: 3;
    pointer-events: none;
  }
  .cap-card:hover .cap-bottom-hint { opacity: 1; transform: translateY(0); }

  /* ═══════════════════════════════════════════════════════
     CARD 1 — AI ENGINEERING — GLYPH + DATA STREAM
     ═══════════════════════════════════════════════════════ */

  /* Glyph: rotate 45° on hover */
  .card-ai:hover .glyph-ai {
    transform: rotate(45deg);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .glyph-ai {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    color: var(--signal-cyan);
  }

  /* Radiating lines pulse outward with stagger */
  .ray {
    transform-origin: 14px 14px;
    transform-box: fill-box;
  }
  .card-ai:hover .ray { animation: rayPulse 0.6s ease-out infinite; }
  .card-ai:hover .r1 { animation-delay: 0ms;   }
  .card-ai:hover .r2 { animation-delay: 40ms;  }
  .card-ai:hover .r3 { animation-delay: 80ms;  }
  .card-ai:hover .r4 { animation-delay: 120ms; }
  .card-ai:hover .r5 { animation-delay: 160ms; }
  .card-ai:hover .r6 { animation-delay: 200ms; }

  @keyframes rayPulse {
    0%, 100% { opacity: 0.5; transform: scale(0.8); }
    50%       { opacity: 1.0; transform: scale(1.2); }
  }

  /* Data stream — waveform bars */
  .data-stream {
    position: absolute;
    bottom: 12px;
    right: 16px;
    display: flex;
    align-items: flex-end;
    gap: 3px;
    opacity: 0;
    transition: opacity 200ms ease;
    z-index: 2;
  }
  .card-ai:hover .data-stream { opacity: 1; }

  .bar {
    width: 2px;
    background: var(--signal-cyan);
    opacity: 0.55;
    border-radius: 1px;
    animation: barOscillate 1.4s ease-in-out infinite alternate;
  }
  .b1 { animation-duration: 1.2s; animation-delay: 0s;     height: 8px; }
  .b2 { animation-duration: 1.7s; animation-delay: -0.25s; height: 12px; }
