---
const caps = [
  {
    title: 'AI-NATIVE\nDESKTOP APPS',
    stack: 'Tauri · Rust · Three.js · AI',
    for: 'Businesses needing premium native Windows tools with AI intelligence built in.',
    from: 'From RM 8,000',
    signal: 'cyan',
    icon: '⬡',
  },
  {
    title: 'CUSTOM AI\nAUTOMATION',
    stack: 'Claude API · Workflow design · Integrations',
    for: 'Founders scaling operations with intelligent automation systems.',
    from: 'From RM 5,000',
    signal: 'violet',
    icon: '◈',
  },
  {
    title: 'PREMIUM\nFRONTEND',
    stack: 'React · Three.js · Astro · Motion',
    for: 'Brands that need a digital presence worthy of their ambition.',
    from: 'From RM 4,000',
    signal: 'mint',
    icon: '◎',
  },
  {
    title: 'AI WORKFLOW\nARCHITECTURE',
    stack: 'Memory systems · Prompt engineering',
    for: 'Builders who want 10× output without 10× cost.',
    from: 'Consultation',
    signal: 'amber',
    icon: '◇',
  },
];
---

<section id="capabilities" aria-labelledby="cap-heading">
  <div class="section-inner">
    <div class="section-header reveal">
      <p class="section-label font-mono">CAPABILITIES</p>
      <h2 id="cap-heading" class="section-title font-cinzel">
        What We Build
      </h2>
    </div>

    <div class="cap-grid" data-stagger>
      {caps.map(({ title, stack, for: forText, from, signal, icon }) => (
        <article class="sacred-frame cap-card stagger-child" data-signal={signal}>
          <span class="corner-tl"></span>
          <span class="corner-tr"></span>
          <span class="corner-bl"></span>
          <span class="corner-br"></span>

          <div class="cap-icon font-mono" aria-hidden="true">{icon}</div>
          <h3 class="cap-title font-cinzel">{title}</h3>
          <p class="cap-stack font-mono">{stack}</p>
          <p class="cap-for font-inter">{forText}</p>
          <div class="cap-price font-inter">{from}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 7rem 2rem;
    background: var(--void);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-pure);
  }

  /* ── GRID ─────────────────────────────────────────── */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--edge);
    border: 1px solid var(--edge);
  }

  .cap-card {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--mid);
    border: none;
    border-radius: 0;
    transition:
      background var(--t-base) var(--ease-expressive),
      transform var(--t-base) var(--ease-expressive);
  }
  .cap-card:hover { background: var(--rise); transform: translateY(-3px); }

  /* Signal color on hover */
  .cap-card[data-signal="cyan"]:hover    { box-shadow: 0 -2px 0 var(--signal-cyan) inset; }
  .cap-card[data-signal="violet"]:hover  { box-shadow: 0 -2px 0 var(--signal-violet) inset; }
  .cap-card[data-signal="mint"]:hover    { box-shadow: 0 -2px 0 var(--signal-mint) inset; }
  .cap-card[data-signal="amber"]:hover   { box-shadow: 0 -2px 0 var(--signal-amber) inset; }

  /* Corner ticks color per signal */
  .cap-card[data-signal="cyan"]   .corner-tl,
  .cap-card[data-signal="cyan"]   .corner-tr,
  .cap-card[data-signal="cyan"]   .corner-bl,
  .cap-card[data-signal="cyan"]   .corner-br { border-color: var(--signal-cyan); }
  .cap-card[data-signal="violet"] .corner-tl,
  .cap-card[data-signal="violet"] .corner-tr,
  .cap-card[data-signal="violet"] .corner-bl,
  .cap-card[data-signal="violet"] .corner-br { border-color: var(--signal-violet); }
  .cap-card[data-signal="mint"]   .corner-tl,
  .cap-card[data-signal="mint"]   .corner-tr,
  .cap-card[data-signal="mint"]   .corner-bl,
  .cap-card[data-signal="mint"]   .corner-br { border-color: var(--signal-mint); }
  .cap-card[data-signal="amber"]  .corner-tl,
  .cap-card[data-signal="amber"]  .corner-tr,
  .cap-card[data-signal="amber"]  .corner-bl,
  .cap-card[data-signal="amber"]  .corner-br { border-color: var(--signal-amber); }

  .cap-icon {
    font-size: 1.2rem;
    color: var(--text-ghost);
    line-height: 1;
  }

  .cap-title {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--text-pure);
    white-space: pre-line;
    line-height: 1.5;
  }

  .cap-stack {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    line-height: 1.6;
    margin-top: auto;
  }

  .cap-for {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cap-price {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--signal-cyan);
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--edge);
  }

  /* ── STAGGER ──────────────────────────────────────── */
  .stagger-child {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-entrance), transform 0.5s var(--ease-entrance);
  }
  .stagger-child.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 1024px) {
    .cap-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .cap-grid { grid-template-columns: 1fr; }
    .cap-card:hover { transform: none; }
  }
</style>
